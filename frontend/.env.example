# Frontend Environment Variables
VITE_API_URL=http://localhost:3000

# CJ → eBay USA vertical (must align with backend ENABLE_CJ_EBAY_MODULE)
# VITE_ENABLE_CJ_EBAY_MODULE=true
# CJ → ML Chile vertical (must align with backend ENABLE_CJ_ML_CHILE_MODULE)
# VITE_ENABLE_CJ_ML_CHILE_MODULE=true
VITE_WS_URL=ws://localhost:3000
VITE_ENABLE_DEVTOOLS=true

# Vercel (production): set one of these so /api proxy and/or direct API calls use your Railway backend.
# BACKEND_URL=https://your-backend.up.railway.app
# VITE_API_URL=https://your-backend.up.railway.app
