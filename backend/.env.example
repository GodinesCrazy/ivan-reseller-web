# ====================================
# SERVER CONFIGURATION
# ====================================
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# ====================================
# DATABASE
# ====================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ivan_reseller

# ====================================
# REDIS (CACHE & SESSIONS)
# ====================================
REDIS_URL=redis://localhost:6379

# ====================================
# JWT AUTHENTICATION
# ====================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ====================================
# EBAY API
# ====================================
EBAY_APP_ID=your-ebay-app-id
# Habilitar publicacion real en eBay (obligatorio para que Autopilot publique)
# ENABLE_EBAY_PUBLISH=true
EBAY_DEV_ID=your-ebay-dev-id
EBAY_CERT_ID=your-ebay-cert-id
EBAY_SANDBOX=true
EBAY_AUTH_TOKEN=your-ebay-auth-token

# ====================================
# MERCADOLIBRE API
# ====================================
MERCADOLIBRE_CLIENT_ID=your-mercadolibre-client-id
MERCADOLIBRE_CLIENT_SECRET=your-mercadolibre-client-secret
MERCADOLIBRE_ACCESS_TOKEN=your-mercadolibre-access-token
MERCADOLIBRE_REFRESH_TOKEN=your-mercadolibre-refresh-token
# OAuth: URL del backend (debe coincidir con redirect URI en MercadoLibre Portal)
# Railway: https://ivanreseller.com o https://ivan-reseller-backend-production.up.railway.app
BACKEND_URL=http://localhost:4000
# Opcional: redirect URI explícito si difiere de BACKEND_URL + path
# Debe coincidir EXACTAMENTE con MercadoLibre Developer Portal (sin trailing slash)
# MERCADOLIBRE_REDIRECT_URI=https://ivanreseller.com/api/marketplace-oauth/oauth/callback/mercadolibre
MERCADOLIBRE_SITE_ID=MLC
# Webhooks: secret de Notificaciones en MercadoLibre Portal
# WEBHOOK_SECRET_MERCADOLIBRE=your-webhook-secret
# Habilitar publicacion real en ML (obligatorio para que Autopilot publique)
# ENABLE_ML_PUBLISH=true

# ====================================
# WEBHOOKS (ventas -> Order -> fulfill -> Sale)
# ====================================
# eBay: Signing Key de developer.ebay.com -> Notifications
# WEBHOOK_SECRET_EBAY=your-ebay-signing-key

# ====================================
# AMAZON API
# ====================================
AMAZON_ACCESS_KEY=your-amazon-access-key
AMAZON_SECRET_KEY=your-amazon-secret-key
AMAZON_MARKETPLACE_ID=your-amazon-marketplace-id
AMAZON_SELLER_ID=your-amazon-seller-id

# ====================================
# PAYPAL API
# ====================================
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
# sandbox (testing) | production or live (real payments)
# For production: use Live app credentials from PayPal Dashboard
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# Allow purchase when PayPal balance is low (PayPal may use linked card as backup)
# ALLOW_PURCHASE_WHEN_LOW_BALANCE=true
# PURCHASE_LOW_BALANCE_MAX_ORDER_USD=500

# ====================================
# SCRAPING SERVICES
# ====================================
SCRAPERAPI_KEY=your-scraperapi-key
ZENROWS_API_KEY=your-zenrows-api-key
GROQ_API_KEY=your-groq-api-key

# ====================================
# EMAIL (OPTIONAL)
# ====================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password

# ====================================
# EXTERNAL SERVICES
# ====================================
EXCHANGERATE_API_KEY=your-exchangerate-api-key

# ====================================
# LOGGING
# ====================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ====================================
# CORS
# ====================================
CORS_ORIGIN=http://localhost:5173

# ====================================
# RATE LIMITING
# ====================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ====================================
# DASHBOARD
# ====================================
# Si true, el dashboard devuelve ceros/vacío sin consultar BD (modo seguro ante fallos).
# Para datos reales en vivo, dejar en false o no definir.
# SAFE_DASHBOARD_MODE=false

# ====================================
# AUTOPILOT START SCRIPT / E2E
# ====================================
# Same credentials as dashboard login (used by scripts/start-autopilot.ts and E2E tests)
# AUTOPILOT_LOGIN_USER=admin
# AUTOPILOT_LOGIN_PASSWORD=your-password
