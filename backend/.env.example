# ====================================
# SERVER CONFIGURATION
# ====================================
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# ====================================
# DATABASE
# ====================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ivan_reseller
# Optional: cap Prisma connection pool (shared Postgres with low max_connections). Not applied to Prisma Accelerate URLs.
# PRISMA_CONNECTION_LIMIT=10
# Railway preDeploy migrate retries if DB is saturated (see scripts/railway-migrate-deploy.js):
# MIGRATE_MAX_ATTEMPTS=18
# MIGRATE_RETRY_DELAY_SEC=20
# Production: sales with orderId starting with test/mock/demo are excluded from stats. See docs/DATA_REAL_VS_DEMO.md

# ====================================
# REDIS (CACHE & SESSIONS)
# ====================================
# Required for automatic listing sync with marketplaces: workers run reconciliation every 30 min. Without REDIS_URL, run POST /api/publisher/listings/run-reconciliation-audit manually or scripts/run-reconciliation-audit.ts
# Production (Railway): set REDIS_URL from Redis service so Control Center shows Redis/Workers ok. See docs/RAILWAY_REDIS_SETUP.md
REDIS_URL=redis://localhost:6379
# Run one reconciliation pass on server start (requires Redis). Use to sync DB with eBay/ML/Amazon soon after deploy.
# RUN_LISTING_RECONCILIATION_ON_STARTUP=true

# ====================================
# SHIPPING (default when product has no shippingCost)
# ====================================
# Used for margin/totalCost when AliExpress does not return shipping cost (default 5.99 USD).
# DEFAULT_SHIPPING_COST_USD=5.99
# eBay: shipping amount in the single fulfillment policy (create via /api/internal/ebay-fulfillment-policy).
# Set same as DEFAULT_SHIPPING_COST_USD for consistent margins (e.g. 4.99 or 5.99).
# EBAY_DEFAULT_SHIPPING_USD=4.99

# Phase 51 — block ALL new marketplace publications (eBay / ML / Amazon) until validation audit is done. Railway: set to true during incidents.
# BLOCK_NEW_PUBLICATIONS=true

# Phase 53 — pre-publish AliExpress DS validation (SKU/stock, shipping, profit vs fees)
# PRE_PUBLISH_VALIDATION_DISABLED=true
# PRE_PUBLISH_MIN_NET_PROFIT=0.01
# PRE_PUBLISH_MIN_MARGIN_RATIO=0.05
# PRE_PUBLISH_SHIPPING_FALLBACK=false
# Strict real E2E: reject publish when only estimated shipping (RISKY). Combine with MIN_MARGIN_RATIO=0.2 for ≥20% net margin.
# PRE_PUBLISH_REJECT_RISKY=true
# PRE_PUBLISH_MIN_MARGIN_RATIO=0.2

# ====================================
# JWT AUTHENTICATION
# ====================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ====================================
# EBAY API
# ====================================
EBAY_APP_ID=your-ebay-app-id
# Habilitar publicacion real en eBay (obligatorio para que Autopilot publique)
# ENABLE_EBAY_PUBLISH=true
EBAY_DEV_ID=your-ebay-dev-id
EBAY_CERT_ID=your-ebay-cert-id
EBAY_SANDBOX=true
EBAY_AUTH_TOKEN=your-ebay-auth-token

# ====================================
# MERCADOLIBRE API
# ====================================
MERCADOLIBRE_CLIENT_ID=your-mercadolibre-client-id
MERCADOLIBRE_CLIENT_SECRET=your-mercadolibre-client-secret
MERCADOLIBRE_ACCESS_TOKEN=your-mercadolibre-access-token
MERCADOLIBRE_REFRESH_TOKEN=your-mercadolibre-refresh-token
# OAuth: URL del backend (debe coincidir con redirect URI en MercadoLibre Portal)
# Railway: https://ivanreseller.com o https://ivan-reseller-backend-production.up.railway.app
BACKEND_URL=http://localhost:4000
# Opcional: redirect URI explícito si difiere de BACKEND_URL + path
# Debe coincidir EXACTAMENTE con MercadoLibre Developer Portal (sin trailing slash)
# MERCADOLIBRE_REDIRECT_URI=https://ivanreseller.com/api/marketplace-oauth/oauth/callback/mercadolibre
MERCADOLIBRE_SITE_ID=MLC
# Webhooks: secret de Notificaciones en MercadoLibre Portal
# WEBHOOK_SECRET_MERCADOLIBRE=your-webhook-secret
# Habilitar publicacion real en ML (obligatorio para que Autopilot publique)
# ENABLE_ML_PUBLISH=true

# ====================================
# WEBHOOKS (ventas -> Order -> fulfill -> Sale)
# ====================================
# eBay: Signing Key de developer.ebay.com -> Notifications
# WEBHOOK_SECRET_EBAY=your-ebay-signing-key

# ====================================
# AMAZON API
# ====================================
AMAZON_ACCESS_KEY=your-amazon-access-key
AMAZON_SECRET_KEY=your-amazon-secret-key
AMAZON_MARKETPLACE_ID=your-amazon-marketplace-id
AMAZON_SELLER_ID=your-amazon-seller-id

# ====================================
# PAYPAL API
# ====================================
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
# sandbox (testing) | production or live (real payments)
# For production: use Live app credentials from PayPal Dashboard
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# Allow purchase when PayPal balance is low (PayPal may use linked card as backup)
# Permitir compra cuando el saldo PayPal es bajo (PayPal puede cobrar a la tarjeta vinculada)
ALLOW_PURCHASE_WHEN_LOW_BALANCE=true
PURCHASE_LOW_BALANCE_MAX_ORDER_USD=500

# ====================================
# SCRAPING SERVICES
# ====================================
SCRAPERAPI_KEY=your-scraperapi-key
ZENROWS_API_KEY=your-zenrows-api-key
GROQ_API_KEY=your-groq-api-key

# ====================================
# EMAIL (OPTIONAL)
# ====================================
# Set to true to send in-app notifications (e.g. sale alerts) to user's email
# EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
# SMTP_FROM=noreply@yourdomain.com
# Extra copy of every sale notification (or only recipient if user has no email). Example:
# SALE_NOTIFICATION_EMAIL=ivanmarty5338@gmail.com

# ====================================
# EXTERNAL SERVICES
# ====================================
EXCHANGERATE_API_KEY=your-exchangerate-api-key

# ====================================
# LOGGING
# ====================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ====================================
# CORS
# ====================================
CORS_ORIGIN=http://localhost:5173

# ====================================
# RATE LIMITING
# ====================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ====================================
# DASHBOARD
# ====================================
# Si true, el dashboard devuelve ceros/vacío sin consultar BD (modo seguro ante fallos).
# Para datos reales en vivo, dejar en false o no definir.
# SAFE_DASHBOARD_MODE=false

# ====================================
# AUTOPILOT START SCRIPT / E2E
# ====================================
# Same credentials as dashboard login (used by scripts/start-autopilot.ts and E2E tests)
# AUTOPILOT_LOGIN_USER=admin
# AUTOPILOT_LOGIN_PASSWORD=your-password

# ====================================
# PHASE 12 — AUTONOMOUS OPERATION & SAFETY
# ====================================
# Enable full autonomous dropshipping cycles (only after readiness checks pass)
# AUTONOMOUS_OPERATION_MODE=false
# Max new listings per day when autonomous (safety cap)
# AUTONOMOUS_MAX_LISTINGS_PER_DAY=50
# Min margin % to allow price changes / scaling
# AUTONOMOUS_MIN_MARGIN_PCT=10
# Marketplace rate limits (respect API throttling)
# RATE_LIMIT_LISTINGS_PER_HOUR=20

# ====================================
# PHASE 13 — LAUNCH AUDIT & FEE INTELLIGENCE
# ====================================
# Copy to .env and adjust. Min margin % to allow publish/scale (below this, listing is flagged and not published)
MIN_ALLOWED_MARGIN=5
# MercadoLibre Chile commission % (default 12)
ML_COMMISSION_PCT=12
# eBay US insertion fee (USD) and FVF %
EBAY_INSERTION_FEE_USD=0.35
EBAY_FVF_PCT=13.25
EBAY_FVF_PER_ORDER_USD=0.4
# When launch-report shows systemReadyForAutonomousOperation=true, uncomment below and restart backend
# AUTONOMOUS_OPERATION_MODE=true

# ====================================
# PHASE 23 — SALES ACCELERATION MODE
# ====================================
# Enable to increase early sales velocity (DMO, CRO, dynamic pricing every 3h)
# SALES_ACCELERATION_MODE=false
# Cron for sales acceleration runs (default: every 3 hours)
# SALES_ACCELERATION_CRON=0 */3 * * *

# ====================================
# ALIEXPRESS DROPSHIPPING — ALTERNATIVE PRODUCT FALLBACK
# ====================================
# When placeOrder fails with SKU_NOT_EXIST or no stock, search for the same product (by title, same or cheaper price) with stock and buy that instead. Requires Affiliate API and Dropshipping API configured.
# ALIEXPRESS_FALLBACK_ALTERNATIVE_PRODUCT=true
