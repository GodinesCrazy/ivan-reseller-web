# =============================================================================
# Ivan Reseller Backend - Local Environment Template
# Copy to .env.local:  cp env.local.example .env.local  (then replace REPLACE_ME)
# Or run: npm run bootstrap-env  (creates .env.local from this file if missing)
# Load order: .env then .env.local (override).
# =============================================================================
#
# PRODUCTION REQUIRED (do not use REPLACE_ME in production):
#   INTERNAL_RUN_SECRET  - Auth for /api/internal/* endpoints
#   SERP_API_KEY or GOOGLE_TRENDS_API_KEY - Real trends API
#   ALIEXPRESS_APP_KEY, ALIEXPRESS_APP_SECRET - AliExpress affiliate/OAuth
#   PAYPAL_CLIENT_ID, PAYPAL_CLIENT_SECRET - Checkout (create-order, capture-order)
#   DATABASE_URL - PostgreSQL connection string
#   JWT_SECRET - Min 32 chars, for JWT signing
#   ENCRYPTION_KEY - Min 32 chars, for credential encryption
#
# =============================================================================

INTERNAL_RUN_SECRET=REPLACE_ME
SERP_API_KEY=REPLACE_ME
GOOGLE_TRENDS_API_KEY=REPLACE_ME
ALIEXPRESS_APP_KEY=REPLACE_ME
ALIEXPRESS_APP_SECRET=REPLACE_ME
PAYPAL_CLIENT_ID=REPLACE_ME
PAYPAL_CLIENT_SECRET=REPLACE_ME
# sandbox (testing) | production or live (real payments)
# For production: use Live app credentials; set PAYPAL_WEBHOOK_ID from Live webhook
PAYPAL_ENVIRONMENT=sandbox
DATABASE_URL=REPLACE_ME
# Cap DB connections (avoids "too many clients" on shared Postgres, e.g. Railway). See database.ts.
# PRISMA_CONNECTION_LIMIT=8
#
# Redis — caching, jobs, some preflight paths. From backend/ with Railway CLI linked:
#   npm run sync:redis-url
# writes REDIS_PUBLIC_URL (TCP proxy) into .env.local. Do not use redis.railway.internal from your PC.
# REDIS_URL=REPLACE_ME
JWT_SECRET=REPLACE_ME
ENCRYPTION_KEY=REPLACE_ME
PORT=4000

# Scraping (set from APIS2.txt in production)
SCRAPER_API_KEY=
SCRAPERAPI_KEY=
ZENROWS_API_KEY=
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_IMAGE_MODEL=
OPENAI_VISION_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_IMAGE_MODEL=
GEMINI_REVIEW_MODEL=
SELF_HOSTED_IMAGE_PROVIDER_ENABLED=
SELF_HOSTED_IMAGE_PROVIDER_BASE_URL=
SELF_HOSTED_IMAGE_PROVIDER_MODE=automatic1111
SELF_HOSTED_IMAGE_PROVIDER_API_KEY=
SELF_HOSTED_IMAGE_PROVIDER_MODEL=
SELF_HOSTED_IMAGE_PROVIDER_NEGATIVE_PROMPT=
SELF_HOSTED_IMAGE_PROVIDER_SAMPLER=
SELF_HOSTED_IMAGE_PROVIDER_STEPS=
SELF_HOSTED_IMAGE_PROVIDER_CFG_SCALE=
SELF_HOSTED_IMAGE_PROVIDER_WIDTH=
SELF_HOSTED_IMAGE_PROVIDER_HEIGHT=
SELF_HOSTED_IMAGE_PROVIDER_TIMEOUT_MS=

# MercadoLibre Chile — P76 canonical image pipeline (policy + conversion dual gate). Default on if unset. Set 0 or false to disable.
# ML_CANONICAL_IMAGE_PIPELINE=

# P79 — Hero/portada composition gate (trim-based subject dominance). Default on if unset. Set 0 or false to disable (break-glass only).
# ML_HERO_COVER_GATE=
# P80 output-integrity gate (near-blank cover blocker). Default on. Break-glass:
# ML_OUTPUT_INTEGRITY_GATE=

# P82 — preview remediation simulation ranking before final remediation. Default on. Break-glass:
# ML_REMEDIATION_SIMULATION=
# ML_REMEDIATION_SIM_MAX_CANDIDATES=5
# ML_REMEDIATION_SIM_PREVIEW_MAX_INPUT=900
# P83 — higher-fidelity preview for top N simulated candidates (default on). Break-glass:
# ML_REMEDIATION_SIM_HIFI=
# ML_REMEDIATION_SIM_HIFI_TOP_N=2
# ML_REMEDIATION_SIM_HIFI_MAX_INPUT=1400

# P84 — among gate-passing remediated covers, pick strongest commercial portada (default on). Break-glass:
# ML_FINAL_COVER_PREFERENCE=
# ML_FINAL_COVER_PREFERENCE_MAX_FINALISTS=3

# P85 — absolute commercial bar on provisional final-cover winner (default on). Break-glass:
# ML_COMMERCIAL_FINALIST_FLOOR=
# P86 calibrated defaults (override only when needed):
# ML_COMMERCIAL_FLOOR_MIN_READABILITY=58
# ML_COMMERCIAL_FLOOR_MIN_SILHOUETTE=52
# ML_COMMERCIAL_FLOOR_MAX_DEAD_SPACE=0.5
# ML_COMMERCIAL_FLOOR_MIN_CENTER_SIGNAL=0.22
# ML_COMMERCIAL_FLOOR_MAX_WASHOUT=0.42
# ML_COMMERCIAL_FLOOR_MIN_SUBJECT_AREA=0.42
# ML_COMMERCIAL_FLOOR_MIN_PREFERENCE_SCORE=95000

# P77 break-glass only: allow publishing from an on-disk ML pack when audit is reject_hard (e.g. empty images). Prefer productData.mlImagePipeline.allowStalePackWhenRejectHard for per-SKU intent.
# ML_IMAGE_STALE_PACK_OVERRIDE_REJECT_HARD=

# eBay production (set from APIS2.txt in production)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REDIRECT_URI=
EBAY_APP_ID=
EBAY_DEV_ID=
EBAY_CERT_ID=
# Token OAuth (obligatorio para publicar). Obtener: 1) OAuth en UI, o 2) copiar de Railway
EBAY_REFRESH_TOKEN=

# AliExpress Dropshipping (Ivan Reseller 522578 - set from rail.txt via inject-apis)
ALIEXPRESS_DROPSHIPPING_APP_KEY=
ALIEXPRESS_DROPSHIPPING_APP_SECRET=
# Access token (obligatorio para API dropshipping). Alias aceptado: ALIEXPRESS_DROPSHIPPING_TOKEN
ALIEXPRESS_DROPSHIPPING_ACCESS_TOKEN=
# Opcional renovación. Alias: ALIEXPRESS_DROPSHIPPING_REFRESH
ALIEXPRESS_DROPSHIPPING_REFRESH_TOKEN=
ALIEXPRESS_DROPSHIPPING_REDIRECT_URI=https://ivanreseller.com/api/marketplace-oauth/callback
# Product ID for post-OAuth / refresh health probe (read-only). Optional; default used if unset.
# ALIEXPRESS_DROPSHIPPING_VERIFY_PRODUCT_ID=1005009130509159

# P89 — block Mercado Libre publish from API/web when ML webhook HMAC secret is missing (honest post-sale readiness). Default false.
# ML_WEB_PUBLISH_REQUIRE_ML_WEBHOOK_SECRET=true
# WEBHOOK_SECRET_MERCADOLIBRE=
