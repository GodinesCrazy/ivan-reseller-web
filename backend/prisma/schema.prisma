// Key differences: Shopify API Custom App token storage, REST/GraphQL based.
// ====================================

model CjShopifyUsaAccountSettings {
  id                         Int      @id @default(autoincrement())
  userId                     Int      @unique
  minMarginPct               Decimal? @db.Decimal(6, 4)
  minProfitUsd               Decimal? @db.Decimal(18, 2)
  maxShippingUsd             Decimal? @db.Decimal(18, 2)
  handlingBufferDays         Int      @default(3)
  minStock                   Int      @default(1)
  rejectOnUnknownShipping    Boolean  @default(true)
  maxRiskScore               Int?
  priceChangePctReevaluate   Decimal? @db.Decimal(6, 4)
  incidentBufferPct          Decimal? @db.Decimal(6, 4)
  
  // Shopify specific credentials and settings
  shopifyStoreUrl            String?  @db.Text
  shopifyAccessToken         String?  @db.Text // Should be a custom app token
  shopifyLocationId          String?  // The explicit Shopify location ID for inventory

  minCostUsd                 Decimal? @db.Decimal(18, 2)
  defaultPaymentFeePct       Decimal? @db.Decimal(6, 4)
  defaultPaymentFixedFeeUsd  Decimal? @db.Decimal(18, 2)
  cjPostCreateCheckoutMode   String   @default("MANUAL")
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cj_shopify_usa_account_settings")
}

model CjShopifyUsaProduct {
  id               Int       @id @default(autoincrement())
