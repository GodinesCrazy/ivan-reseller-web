// Prisma Schema - Ivan Reseller Database (PostgreSQL Version)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ====================================
// MODELS
// ====================================

model User {
  id               Int       @id @default(autoincrement())
  username         String    @unique
  email            String    @unique
  password         String
  fullName         String?
  role             String    @default("USER") // "ADMIN" or "USER"
  commissionRate   Decimal   @default(0.20) @db.Decimal(6, 4) // Porcentaje de comisión sobre utilidad de operación exitosa (ej: 0.20 = 20%)
  fixedMonthlyCost Decimal   @default(0.00) @db.Decimal(18, 2) // Costo fijo mensual en USD (ej: 0.00 = sin costo fijo)
  balance          Decimal   @default(0) @db.Decimal(18, 2) // Balance del usuario en moneda base
  totalEarnings    Decimal   @default(0) @db.Decimal(18, 2) // Ganancias totales acumuladas en moneda base
  totalSales       Int       @default(0)
  isActive         Boolean   @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdBy            Int?     // ID del admin que creó este usuario (null si es admin o auto-creado)
  paypalPayoutEmail    String?  // Email PayPal para recibir ganancias (payouts)
  payoneerPayoutEmail  String?  // Email Payoneer para recibir pagos de eBay y otros marketplaces
  onboardingStep      Int      @default(0)
  onboardingCompleted Boolean  @default(false)
  ebayConnected       Boolean  @default(false)
  amazonConnected     Boolean  @default(false)
  mercadolibreConnected Boolean @default(false)

  // Relations
  products                Product[]
  sales                   Sale[]
  commissions             Commission[]
  apiCredentials          ApiCredential[]
  activities              Activity[]
  workflowConfig          UserWorkflowConfig?
  createdUsers            User[]                  @relation("UserCreator") // Usuarios creados por este admin
  creator                 User?                   @relation("UserCreator", fields: [createdBy], references: [id])
  adminCommissions        AdminCommission[] // Comisiones que recibe como admin de usuarios creados
  successfulOperations    SuccessfulOperation[] // Operaciones exitosas del usuario
  marketplaceListings     MarketplaceListing[]
  marketplacePublications MarketplacePublication[]
  opportunities           Opportunity[]
  aiSuggestions           AISuggestion[]
  winningProducts         WinningProduct[]
  marketOpportunities      MarketOpportunity[]
  autoListingDecisions    AutoListingDecision[]
  strategyDecisions       StrategyDecision[]
  scalingActions          ScalingAction[]
  manualAuthSessions      ManualAuthSession[]
  marketplaceAuthStatuses MarketplaceAuthStatus[]
  sharedCredentials       ApiCredential[]         @relation("SharedCredentialOwner")
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  apiStatusHistory        APIStatusHistory[]
  apiStatusSnapshots      APIStatusSnapshot[]
  reportHistory           ReportHistory[]
  scheduledReports        ScheduledReport[]
  userSettings            UserSettings?
  accessRequestsReviewed  AccessRequest[]         @relation("AccessRequestReviewer") // Solicitudes de acceso revisadas por este admin
  autopilotWorkflows      AutopilotWorkflow[] // Workflows personalizados del usuario
  userMeetings            MeetingRoom[]           @relation("UserMeetings") // Reuniones iniciadas por el usuario
  adminMeetings           MeetingRoom[]           @relation("AdminMeetings") // Reuniones donde el usuario es admin
  orders                  Order[]                 // Órdenes de checkout (PayPal → AliExpress)
  purchaseLogs            PurchaseLog[] // Logs de compras automáticas
  competitorInsights      CompetitorInsight[]
  pilotLaunchApprovals    PilotLaunchApproval[]
  pilotDecisionLedgers    PilotDecisionLedger[]
  pilotControlStates      PilotControlState[]

  // CJ → eBay USA vertical (isolated module; FASE 3A+)
  cjEbayAccountSettings   CjEbayAccountSettings?
  cjEbayProducts          CjEbayProduct[]
  cjEbayShippingQuotes    CjEbayShippingQuote[]
  cjEbayProductEvaluations CjEbayProductEvaluation[]
  cjEbayListings          CjEbayListing[]
  cjEbayOrders            CjEbayOrder[]
  cjEbayAlerts            CjEbayAlert[]
  cjEbayProfitSnapshots   CjEbayProfitSnapshot[]
  cjEbayExecutionTraces   CjEbayExecutionTrace[]

  @@index([email])
  @@index([username])
  @@index([role, isActive])
  @@index([createdAt])
  @@map("users")
}

// Platform-wide commission config (only ADMIN can change)
model PlatformConfig {
  id                     Int      @id @default(autoincrement())
  platformCommissionPct   Decimal  @db.Decimal(5, 2) @default(10.00) // Default 10%
  adminPaypalEmail        String
  updatedAt               DateTime @updatedAt

  @@map("platform_config")
}

model ApiCredential {
  id          Int             @id @default(autoincrement())
  userId      Int
  apiName     String // ebay, mercadolibre, amazon, paypal, groq, email, twilio, slack, stripe, etc.
  environment String          @default("production") // sandbox, production
  credentials String // JSON string with encrypted API keys
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  scope       CredentialScope @default(user)
  sharedById  Int?

  // Relations
  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sharedBy User? @relation("SharedCredentialOwner", fields: [sharedById], references: [id], onDelete: SetNull)

  @@unique([userId, apiName, environment, scope])
  @@index([userId, apiName, environment])
  @@index([apiName, environment, isActive])
  @@index([scope, isActive])
  @@map("api_credentials")
}

enum CredentialScope {
  user
  global
}

model Product {
  id              Int       @id @default(autoincrement())
  userId          Int
  aliexpressUrl   String
  title           String
  description     String?
  aliexpressPrice Decimal   @db.Decimal(18, 2) // Precio en AliExpress en moneda original
  suggestedPrice  Decimal   @db.Decimal(18, 2) // Precio sugerido de venta en moneda base
  finalPrice      Decimal?  @db.Decimal(18, 2) // Precio final (opcional) en moneda base
  currency        String    @default("USD") // Moneda original del precio de AliExpress (CLP, USD, EUR, etc.)
  category        String?
  images          String // JSON string with array of image URLs
  productData     String? // JSON string with full scraped data
  // ✅ MEJORADO: Costos adicionales para cálculo preciso de márgenes
  shippingCost    Decimal?  @db.Decimal(18, 2) // Costo de envío internacional en moneda base
  importTax       Decimal?  @db.Decimal(18, 2) // Impuestos de importación (IVA/aranceles) en moneda base
  totalCost       Decimal?  @db.Decimal(18, 2) // Costo total (producto + envío + impuestos) en moneda base
  targetCountry   String? // País destino para cálculo de impuestos (CL, ES, US, etc.)
  originCountry   String? // País de origen (CN para AliExpress/China)
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED, PUBLISHED, INACTIVE
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  approvalId      String? // Marketplace approval ID
  winnerDetectedAt DateTime? // Spec: set when sales in last N days >= threshold (winner detection)
  // Phase 1: Inventory sync — supplier stock from AliExpress, last check time
  supplierStock         Int?      // Last known stock from supplier (AliExpress)
  supplierStockCheckedAt DateTime? // When supplier stock was last checked
  aliexpressSku         String?   // AliExpress sku_id from getProductInfo (for placeOrder when product has variants/stock)
  // Phase 1: real packed dimensions/weight — required for safe Mercado Libre publish
  packageWeightGrams  Int?
  packageLengthCm     Int?
  packageWidthCm      Int?
  packageHeightCm     Int?
  maxUnitsPerOrder    Int?      @default(1) // max buyer units per order
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sales                Sale[]
  successfulOperations SuccessfulOperation[]
  marketplaceListings  MarketplaceListing[]
  marketplacePublications MarketplacePublication[]
  purchaseLogs         PurchaseLog[] // Logs de compras relacionadas
  winningProducts      WinningProduct[]
  marketOpportunities  MarketOpportunity[]
  autoListingDecisions AutoListingDecision[]
  strategyDecisions    StrategyDecision[]
  scalingActions       ScalingAction[]
  unprofitableListingFlags UnprofitableListingFlag[]
  orders                   Order[] // Post-sale checkout orders linked to this product
  pilotLaunchApprovals     PilotLaunchApproval[]
  pilotDecisionLedgers     PilotDecisionLedger[]
  pilotControlStates       PilotControlState[]

  @@index([userId, status])
  @@index([status, isPublished])
  @@index([createdAt])
  @@map("products")
}

// Phase 9: Autonomous Scaling Engine — scaling_actions (republish | expand_marketplace | increase_quantity | trigger_optimization)
model ScalingAction {
  id           Int       @id @default(autoincrement())
  userId       Int
  productId    Int
  marketplace  String    // target marketplace
  actionType   String    // republish | expand_marketplace | increase_quantity | trigger_optimization
  score        Decimal   @db.Decimal(5, 2)   // 0–100 scaleScore
  executed     Boolean   @default(false)
  createdAt    DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productId])
  @@index([marketplace])
  @@index([actionType])
  @@index([createdAt])
  @@index([executed])
  @@map("scaling_actions")
}

// Phase 8: AI Strategy Brain — strategic decisions (scale_listing | expand_marketplace | adjust_price | pause_listing)
model StrategyDecision {
  id           Int       @id @default(autoincrement())
  userId       Int
  productId    Int
  decisionType String
  score        Decimal   @db.Decimal(5, 2)   // 0–100
  reason       String
  executed     Boolean   @default(false)
  createdAt    DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productId])
  @@index([decisionType])
  @@index([createdAt])
  @@index([executed])
  @@map("strategy_decisions")
}

// Phase 5: Auto Listing Strategy Engine — decisions (productId, marketplace, priorityScore, executed)
model AutoListingDecision {
  id              Int       @id @default(autoincrement())
  userId          Int
  productId       Int
  marketplace     String    // mercadolibre | ebay | amazon
  priorityScore   Decimal   @db.Decimal(5, 2)   // 0–100
  decisionReason  String    // e.g. "high_opportunity_winner"
  executed        Boolean   @default(false)
  createdAt       DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productId])
  @@index([marketplace])
  @@index([createdAt])
  @@index([executed])
  @@map("auto_listing_decisions")
}

model Sale {
  id               Int       @id @default(autoincrement())
  userId           Int
  productId        Int
  orderId          String    @unique
  marketplace      String // ebay, mercadolibre, amazon
  salePrice        Decimal   @db.Decimal(18, 2) // Precio de venta en moneda de venta
  aliexpressCost   Decimal   @db.Decimal(18, 2) // Costo en AliExpress en moneda base
  marketplaceFee   Decimal   @db.Decimal(18, 2) // Fee del marketplace en moneda de venta
  grossProfit        Decimal   @db.Decimal(18, 2) // Ganancia bruta en moneda de venta
  commissionAmount   Decimal   @db.Decimal(18, 2) // Comisión plataforma (admin) en moneda de venta
  netProfit          Decimal   @db.Decimal(18, 2) // Ganancia neta del usuario (grossProfit - commission) en moneda de venta
  currency           String    @default("USD") // Moneda de la venta (CLP, USD, EUR, etc.)
  status             String    @default("PENDING") // PENDING, PROCESSING, SHIPPED, DELIVERED, CANCELLED, RETURNED, PAYOUT_FAILED
  trackingNumber     String?
  isCompleteCycle    Boolean   @default(false) // Si completó ciclo completo sin devoluciones
  completedAt        DateTime? // Fecha de completado del ciclo
  adminPayoutId      String? // PayPal batch/item ID del payout al admin
  userPayoutId       String? // PayPal batch/item ID del payout al usuario
  payoutExecuted     Boolean  @default(false) // Idempotency: prevent double payout

  // ✅ MEJORADO: Información del comprador
  buyerEmail      String? // Email del comprador (si está disponible)
  buyerName       String? // Nombre del comprador
  shippingAddress String? // Dirección completa de envío (JSON string o texto)

  environment String @default("sandbox") // sandbox | production

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  product             Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  commission          Commission?
  adminCommissions    AdminCommission[]
  successfulOperation SuccessfulOperation? // Relación one-to-one con SuccessfulOperation
  purchaseLogs        PurchaseLog[] // Logs de compras relacionadas

  @@index([userId, status])
  @@index([userId, environment])
  @@index([marketplace, status])
  @@index([createdAt])
  @@index([orderId])
  @@map("sales")
}

model Commission {
  id            Int       @id @default(autoincrement())
  userId        Int
  saleId        Int       @unique
  amount        Decimal   @db.Decimal(18, 2) // Monto de la comisión en moneda de venta
  currency      String    @default("USD") // Moneda de la comisión (debe coincidir con Sale.currency)
  status        String    @default("PENDING") // PENDING, SCHEDULED, PAID, FAILED
  environment   String    @default("sandbox") // sandbox | production
  scheduledAt   DateTime?
  paidAt        DateTime?
  failureReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([userId, environment])
  @@index([status, createdAt])
  @@map("commissions")
}

model Activity {
  id          Int      @id @default(autoincrement())
  userId      Int?
  action      String // login, logout, product_created, sale_completed, etc.
  description String
  ipAddress   String?
  userAgent   String?
  metadata    String? // JSON string with additional data
  createdAt   DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("activities")
}

// ✅ CONFIGURACIÓN DE WORKFLOW POR USUARIO
model UserWorkflowConfig {
  id           Int    @id @default(autoincrement())
  userId       Int    @unique
  environment  String @default("sandbox") // sandbox, production
  workflowMode String @default("manual") // manual, automatic, hybrid

  // Configuración por etapa del dropshipping
  stageScrape          String @default("automatic") // manual, automatic, guided
  stageAnalyze         String @default("automatic") // manual, automatic, guided
  stagePublish         String @default("manual") // manual, automatic, guided
  stagePurchase        String @default("manual") // manual, automatic, guided
  stageFulfillment     String @default("manual") // manual, automatic, guided
  stageCustomerService String @default("manual") // manual, automatic, guided

  // Configuraciones de automatización
  autoApproveThreshold Float? // Confianza mínima para auto-aprobar
  autoPublishThreshold Float? // Confianza mínima para auto-publicar
  maxAutoInvestment    Decimal? @db.Decimal(18, 2) // Inversión máxima para auto-operaciones en moneda base
  workingCapital       Decimal  @default(500) @db.Decimal(18, 2) // Capital de trabajo disponible en PayPal (USD)
  minProfitUsd         Float? // Mínimo beneficio USD para publicar (override global)
  minRoiPct            Float? // Mínimo ROI % para publicar (override global)

  // Configuración de envío para publicaciones
  mlHandlingTimeDays   Int    @default(30) // Días de despacho declarados al comprador en MercadoLibre (plazo envío dropshipping CN→CL)
  mlChannelMode String @default("local_only") // local_only, international_candidate, foreign_seller_enabled, blocked
  mlForeignSellerEnabled Boolean @default(false)
  mlInternationalPublishingEnabled Boolean @default(false)
  mlReturnAddressConfigured Boolean @default(false)
  mlReturnPolicyConfigured Boolean @default(false)
  mlPostSaleContactConfigured Boolean @default(false)
  mlResponseSlaEnabled Boolean @default(false)
  mlAlertsConfigured Boolean @default(false)
  mlPilotModeEnabled Boolean @default(false)
  mlPilotRequireManualAck Boolean @default(true)
  mlPilotMaxActivePublications Int @default(1)
  mlProgramVerificationManualOverride String?
  mlShippingOriginCountry String? // ISO-3166 alpha-2 (ej: CN, CL)
  mlSellerOriginCountry String? // ISO-3166 alpha-2 (ej: CN, CL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_workflow_configs")
}

// ✅ CONFIGURACIÓN DE SETTINGS POR USUARIO
model UserSettings {
  id             Int    @id @default(autoincrement())
  userId         Int    @unique
  language       String @default("en") // en, es, pt, etc.
  timezone       String @default("America/New_York") // Timezone IANA
  dateFormat     String @default("MM/DD/YYYY") // MM/DD/YYYY, DD/MM/YYYY, etc.
  currencyFormat String @default("USD") // USD, EUR, GBP, CLP, MXN, BRL, etc.
  theme          String @default("light") // light, dark, auto

  /// Tamaños de paquete permitidos en búsqueda de oportunidades (CSV): small, medium, large
  opportunityAllowedPackageTiers String @default("small")
  /// Precio unitario proveedor (USD) máximo para clasificar como "small" (heurística)
  opportunitySmallMaxPriceUsd      Decimal @default(45) @db.Decimal(10, 2)
  /// Precio unitario proveedor (USD) máximo para clasificar como "medium"
  opportunityMediumMaxPriceUsd   Decimal @default(120) @db.Decimal(10, 2)
  /// Envío China→USA asumido (USD) si no hay cotización real (paquete pequeño por defecto)
  defaultChinaUsShippingUsd       Decimal @default(5.99) @db.Decimal(10, 2)

  /// Preferencia de fuente en descubrimiento de oportunidades: aliexpress | cj | auto (null = env OPPORTUNITY_SUPPLIER_PREFERENCE)
  opportunitySupplierPreference String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ✅ COMISIONES DE ADMIN POR USUARIOS CREADOS
model AdminCommission {
  id             Int       @id @default(autoincrement())
  adminId        Int // ID del admin que recibe la comisión
  userId         Int // ID del usuario que generó la venta
  saleId         Int // ID de la venta que generó la comisión
  amount         Decimal   @db.Decimal(18, 2) // Monto de la comisión del admin en moneda de venta
  currency       String    @default("USD") // Moneda de la comisión (debe coincidir con Sale.currency)
  commissionType String    @default("user_sale") // user_sale, monthly_fee, etc.
  status         String    @default("PENDING") // PENDING, PAID, FAILED
  environment    String    @default("sandbox") // sandbox | production
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)
  sale  Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("admin_commissions")
}

// ✅ TRACKING DE OPERACIONES EXITOSAS (CICLOS COMPLETOS)
model SuccessfulOperation {
  id            Int    @id @default(autoincrement())
  userId        Int
  productId     Int
  saleId        Int    @unique // Una venta solo puede tener una operación exitosa registrada
  operationType String @default("full_cycle") // full_cycle, partial, etc.

  // Datos de la operación
  startDate      DateTime
  completionDate DateTime
  daysToComplete Int
  totalProfit    Decimal  @db.Decimal(18, 2) // Ganancia total en moneda base
  expectedProfit Decimal  @db.Decimal(18, 2) // Ganancia esperada en moneda base
  profitAccuracy Float // % de diferencia entre esperado y real

  // Estado de la operación
  hadReturns           Boolean @default(false)
  hadIssues            Boolean @default(false)
  issuesDescription    String?
  customerSatisfaction Int? // 1-5 rating

  // Datos de aprendizaje
  aiPredictionScore Float?
  aiConfidence      Float?
  actualSuccess     Boolean @default(true)
  learningPattern   String? // JSON con patrones identificados

  createdAt DateTime @default(now())

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("successful_operations")
}

// ✅ CONFIGURACIÓN DEL SISTEMA (SystemConfig)
model SystemConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String // JSON string
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

// ✅ LISTINGS DE MARKETPLACE
model MarketplaceListing {
  id          Int       @id @default(autoincrement())
  productId   Int
  userId      Int
  marketplace String // ebay, mercadolibre, amazon
  listingId   String // ID del listing en el marketplace
  listingUrl  String?
  supplierUrl String? // URL del proveedor (AliExpress) en el momento de publicar; para rescate en fulfillment
  sku         String?
  viewCount   Int?      @default(0) // Synced from eBay Analytics (traffic report)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Phase 15: Listing state reconciliation — sync with marketplace reality
  status            String    @default("active") // active | paused | failed_publish | not_found
  lastReconciledAt  DateTime?
  // ML Chile Import Compliance (Phase 51+ import/dropshipping truth model)
  shippingTruthStatus   String?  // me2_enforced | me2_attempted_not_enforced | not_specified | unknown
  legalTextsAppended    Boolean  @default(false) // Whether ML Chile import legal footer was appended to description
  importHandlingTimeDays Int?    // Configured handling time (days) used at publish time

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingMetrics ListingMetric[]
  winningProducts WinningProduct[]
  listingOptimizationActions ListingOptimizationAction[]
  conversionOptimizationActions ConversionOptimizationAction[]
  listingAuditActions ListingAuditAction[]
  listingPublishErrors ListingPublishError[]
  competitorInsights   CompetitorInsight[]

  @@unique([marketplace, listingId])
  @@index([status])
  @@index([userId, marketplace])
  @@map("marketplace_listings")
}

// Phase 15: Publish error classification (marketplace_rejection | validation_error | api_error | rate_limit)
model ListingPublishError {
  id          Int      @id @default(autoincrement())
  listingId   Int      // FK MarketplaceListing.id
  marketplace String
  errorType   String   // marketplace_rejection | validation_error | api_error | rate_limit
  errorMessage String?
  createdAt   DateTime @default(now())

  marketplaceListing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([marketplace])
  @@index([errorType])
  @@index([createdAt])
  @@map("listing_publish_errors")
}

// Phase 13: Launch Audit — listing compliance repair actions (title_restructuring | attribute_completion | description_improvement | image_regeneration | price_correction | category_correction)
model ListingAuditAction {
  id         Int       @id @default(autoincrement())
  listingId  Int       // FK MarketplaceListing.id
  marketplace String   // mercadolibre, ebay
  actionType String   // title_restructuring | attribute_completion | description_improvement | image_regeneration | price_correction | category_correction
  reason     String
  executed   Boolean   @default(false)
  createdAt  DateTime @default(now())

  marketplaceListing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([marketplace])
  @@index([actionType])
  @@index([executed])
  @@index([createdAt])
  @@map("listing_audit_actions")
}

// Phase 13: Profitability Safeguard — flag when expected margin < MIN_ALLOWED_MARGIN (do not publish/scale)
model UnprofitableListingFlag {
  id              Int       @id @default(autoincrement())
  productId       Int
  marketplace     String    // mercadolibre, ebay
  expectedMargin  Decimal   @db.Decimal(8, 4) // e.g. -5.25 or 2.50 (percent)
  reason         String
  createdAt       DateTime  @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([marketplace])
  @@index([createdAt])
  @@map("unprofitable_listing_flags")
}

// Phase 11: Conversion Rate Optimization Engine — CRO actions (image_optimization | price_adjustment | title_restructuring | description_improvement | attribute_completion)
model ConversionOptimizationAction {
  id         Int       @id @default(autoincrement())
  listingId  Int       // FK MarketplaceListing.id
  actionType String    // image_optimization | price_adjustment | title_restructuring | description_improvement | attribute_completion
  reason     String    // e.g. high_impressions_low_ctr, high_ctr_low_conversion, competitor_price_advantage, low_image_engagement
  score      Decimal   @db.Decimal(5, 2)   // 0–100 priority/impact score
  executed   Boolean   @default(false)
  createdAt  DateTime  @default(now())

  marketplaceListing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([actionType])
  @@index([createdAt])
  @@index([executed])
  @@map("conversion_optimization_actions")
}

// Phase 6: Dynamic Marketplace Optimization — actions (price_adjustment, title_seo_update, image_rotation, marketplace_expansion)
model ListingOptimizationAction {
  id          Int       @id @default(autoincrement())
  listingId   Int       // FK MarketplaceListing.id
  actionType  String    // price_adjustment | title_seo_update | image_rotation | marketplace_expansion
  reason      String    // e.g. low_ctr, low_conversion, competitor_lower, declining_velocity
  executed    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  marketplaceListing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([actionType])
  @@index([createdAt])
  @@index([executed])
  @@map("listing_optimization_actions")
}

// Phase 1: Listing performance metrics (aggregated by listing, by date)
model ListingMetric {
  id            Int      @id @default(autoincrement())
  listingId     Int      // FK to MarketplaceListing.id (our internal id)
  marketplace   String   // ebay, mercadolibre, amazon
  impressions   Int      @default(0)
  clicks        Int      @default(0)
  sales         Int      @default(0)
  conversionRate Decimal? @db.Decimal(8, 4) // 0-1 or percentage stored as decimal
  price         Decimal? @db.Decimal(18, 2)
  competitorPrice Decimal? @db.Decimal(18, 2)
  date          DateTime @db.Date // Calendar date for aggregation

  marketplaceListing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, date])
  @@index([listingId])
  @@index([marketplace, date])
  @@map("listing_metrics")
}

// Phase 3: Winner Product Detection — stores detected winners per listing (score, reason, criteria)
model WinningProduct {
  id                   Int       @id @default(autoincrement())
  productId            Int
  marketplaceListingId Int?      // FK to MarketplaceListing.id (null if product-level only)
  marketplace          String    // ebay, mercadolibre, amazon
  userId               Int
  score                Decimal   @db.Decimal(10, 4)   // 0-100 or similar
  reason               String    // e.g. "high_conversion_sales_velocity"
  detectedAt           DateTime  @default(now())
  metadata             Json?     // optional: { impressions, clicks, sales, conversionRate, salesVelocity }

  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  marketplaceListing MarketplaceListing? @relation(fields: [marketplaceListingId], references: [id], onDelete: Cascade)
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productId])
  @@index([marketplace])
  @@index([detectedAt])
  @@map("winning_products")
}

// Phase 4: Market Intelligence Engine — discovered high-potential products (0–100 score)
model MarketOpportunity {
  id                Int       @id @default(autoincrement())
  userId             Int
  productId          Int?      // Our internal Product.id (null when from external source only)
  externalProductId  String?   // e.g. AliExpress product id
  source             String    // aliexpress | listing_metrics | competitor | google_trends
  score              Decimal   @db.Decimal(5, 2)   // 0–100 composite
  trendScore         Decimal?  @db.Decimal(5, 2)
  demandScore        Decimal?  @db.Decimal(5, 2)
  competitionScore   Decimal?  @db.Decimal(5, 2)
  marginScore        Decimal?  @db.Decimal(5, 2)
  supplierScore      Decimal?  @db.Decimal(5, 2)
  detectedAt         DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([productId])
  @@index([source])
  @@index([detectedAt])
  @@index([score])
  @@map("market_opportunities")
}

// Phase 7: Global Demand Radar — external demand signals (trendScore 0–100)
model DemandSignal {
  id                 Int       @id @default(autoincrement())
  source             String    // google_trends | amazon_bestsellers | ebay_sold | aliexpress_trending
  externalProductId  String?   // External ID when applicable
  keyword            String
  trendScore         Decimal   @db.Decimal(5, 2)   // 0–100
  demandScore        Decimal?  @db.Decimal(5, 2)
  confidence         Decimal   @db.Decimal(5, 4)   // 0–1
  detectedAt         DateTime  @default(now())
  metadata           Json?     // Extra payload per source

  @@index([source])
  @@index([keyword])
  @@index([detectedAt])
  @@index([trendScore])
  @@map("demand_signals")
}

model MarketplacePublication {
