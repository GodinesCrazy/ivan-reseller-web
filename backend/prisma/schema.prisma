// ====================================
// CJ → ML Chile — módulo aislado (MVP)
// Vertical completamente independiente de CJ→eBay USA y legacy ML.
// Tabla prefix: cj_ml_chile_*
// ====================================

model CjMlChileAccountSettings {
  id                    Int       @id @default(autoincrement())
  userId                Int       @unique
  /// Margen neto mínimo sobre precio venta (%). null = no configurado.
  minMarginPct          Decimal?  @db.Decimal(8, 4)
  /// Ganancia neta mínima en USD. null = no configurado.
  minProfitUsd          Decimal?  @db.Decimal(18, 2)
  /// Stock mínimo requerido para APPROVED.
  minStock              Int       @default(1)
  /// Costo de shipping máximo permitido (USD). null = sin límite.
  maxShippingUsd        Decimal?  @db.Decimal(18, 2)
  /// % comisión ML Chile. Default 12 (MLC estándar). Sobre precio venta.
  mlcFeePct             Decimal   @default(12) @db.Decimal(8, 4)
  /// % fee Mercado Pago (procesamiento de pago). Default 5.18%.
  mpPaymentFeePct       Decimal   @default(5.18) @db.Decimal(8, 4)
  /// % buffer incidentes sobre (costo + envío). Default 2%.
  incidentBufferPct     Decimal   @default(2) @db.Decimal(8, 4)
  /// Si true, rechaza productos sin shipping Chile confirmado (MVP: siempre true).
  requireChileWarehouse Boolean   @default(true)
  /// Si true, rechaza productos si no hay ETA de envío conocida.
  rejectOnUnknownShipping Boolean @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cj_ml_chile_account_settings")
}

model CjMlChileProduct {
  id           Int       @id @default(autoincrement())
  userId       Int
  cjProductId  String
  title        String    @db.Text
  description  String?   @db.Text
  images       Json?
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user     User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  variants CjMlChileProductVariant[]
  shippingQuotes CjMlChileShippingQuote[]
  evaluations    CjMlChileProductEvaluation[]
  listings       CjMlChileListing[]

  @@unique([userId, cjProductId])
  @@index([userId])
  @@map("cj_ml_chile_products")
}

model CjMlChileProductVariant {
  id             Int       @id @default(autoincrement())
  productId      Int
  cjSku          String
  cjVid          String?
  /// Costo unitario CJ en USD (precio neto del proveedor).
  unitCostUsd    Decimal?  @db.Decimal(18, 2)
  stockLastKnown Int       @default(0)
  stockCheckedAt DateTime?
  attributes     Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  product        CjMlChileProduct             @relation(fields: [productId], references: [id], onDelete: Cascade)
  shippingQuotes CjMlChileShippingQuote[]
  evaluations    CjMlChileProductEvaluation[]
  listings       CjMlChileListing[]

  @@unique([productId, cjSku])
  @@index([productId])
  @@index([productId, cjVid])
  @@map("cj_ml_chile_product_variants")
}

model CjMlChileShippingQuote {
  id                    Int       @id @default(autoincrement())
  userId                Int
  productId             Int
  variantId             Int?
  quantity              Int       @default(1)
  amountUsd             Decimal   @db.Decimal(18, 2)
  currency              String    @default("USD")
  serviceName           String?
  carrier               String?
  estimatedMinDays      Int?
  estimatedMaxDays      Int?
  /// CONFIRMED | ESTIMATED | UNKNOWN — certeza del warehouse Chile.
  confidence            String    @default("UNKNOWN")
  /// Código del país de origen CJ para este envío (CL = confirmado Chile warehouse, CN = cross-border).
  originCountryCode     String?   @default("CN")
  validFrom             DateTime  @default(now())
  validUntil            DateTime?
  createdAt             DateTime  @default(now())

  user        User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     CjMlChileProduct             @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant     CjMlChileProductVariant?     @relation(fields: [variantId], references: [id], onDelete: SetNull)
  evaluations CjMlChileProductEvaluation[]
  listings    CjMlChileListing[]

  @@index([userId])
  @@index([productId])
  @@map("cj_ml_chile_shipping_quotes")
}

model CjMlChileProductEvaluation {
  id                 Int      @id @default(autoincrement())
  userId             Int
  productId          Int
  variantId          Int?
  shippingQuoteId    Int?
  /// APPROVED | REJECTED | PENDING | NOT_VIABLE
  decision           String
  reasons            Json?
  estimatedMarginPct Decimal? @db.Decimal(8, 4)
  /// Costo aterrizado estimado (costo + envío + IVA 19%) en USD.
  landedCostUsd      Decimal? @db.Decimal(18, 2)
  /// Precio sugerido de lista en CLP (entero, sin decimales).
  suggestedPriceCLP  Decimal? @db.Decimal(18, 0)
  /// Tasa FX usada en la evaluación (CLP por USD).
  fxRateUsed         Decimal? @db.Decimal(12, 4)
  /// Timestamp de la tasa FX usada.
  fxRateAt           DateTime?
  evaluatedAt        DateTime @default(now())

  user          User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  product       CjMlChileProduct              @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant       CjMlChileProductVariant?      @relation(fields: [variantId], references: [id], onDelete: SetNull)
  shippingQuote CjMlChileShippingQuote?       @relation(fields: [shippingQuoteId], references: [id], onDelete: SetNull)
  listings      CjMlChileListing[]

  @@index([userId])
  @@index([userId, decision])
  @@index([productId])
  @@map("cj_ml_chile_product_evaluations")
}

model CjMlChileListing {
  id              Int       @id @default(autoincrement())
  userId          Int
  productId       Int
  variantId       Int?
  evaluationId    Int?
  shippingQuoteId Int?
  /// ID del listing en Mercado Libre Chile (MLC...).
  mlListingId     String?
  /// ID de la publicación/item en ML (puede coincidir con mlListingId).
  mlItemId        String?
  /// SKU interno usado en la publicación ML.
  mlSku           String?
  /// DRAFT | PUBLISHING | ACTIVE | FAILED | PAUSED | ARCHIVED | NOT_VIABLE
  status          String    @default("DRAFT")
  /// Precio de lista en CLP (entero). Fuente de verdad para ML.
  listedPriceCLP  Decimal?  @db.Decimal(18, 0)
  /// Precio de lista en USD (referencia para P&L).
  listedPriceUsd  Decimal?  @db.Decimal(18, 2)
  /// Tasa FX usada al fijar precio (CLP/USD).
  fxRateUsed      Decimal?  @db.Decimal(12, 4)
  quantity        Int?
  lastSyncedAt    DateTime?
  /// Snapshot del borrador (título, categoría, atributos, imágenes, pricing breakdown, SKU).
  draftPayload    Json?
  lastError       String?   @db.Text
  /// Si el footer legal ML Chile fue añadido (Ley 19.496, IVA, garantía).
  legalTextsAppended Boolean @default(false)
  handlingTimeDays   Int?
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user          User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  product       CjMlChileProduct              @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant       CjMlChileProductVariant?      @relation(fields: [variantId], references: [id], onDelete: SetNull)
  evaluation    CjMlChileProductEvaluation?   @relation(fields: [evaluationId], references: [id], onDelete: SetNull)
