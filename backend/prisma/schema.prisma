}

model CjEbayProfitSnapshot {
  id                   Int      @id @default(autoincrement())
  userId               Int
  snapshotDate         DateTime @db.Date
  estimatedRevenueUsd  Decimal  @default(0) @db.Decimal(18, 2)
  estimatedFeesUsd     Decimal  @default(0) @db.Decimal(18, 2)
  estimatedCjCostUsd   Decimal  @default(0) @db.Decimal(18, 2)
  estimatedProfitUsd   Decimal  @default(0) @db.Decimal(18, 2)
  metadata             Json?
  createdAt            DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, snapshotDate])
  @@index([userId])
  @@map("cj_ebay_profit_snapshots")
}

model CjEbayExecutionTrace {
  id             String   @id @default(cuid())
  userId         Int
  correlationId  String?
  route          String?
  step           String
  message        String   @db.Text
  meta           Json?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([correlationId])
  @@map("cj_ebay_execution_traces")
}

// ====================================
// CJ → eBay USA — AI Opportunity Discovery (FASE 3G)
// Flujo: trend discovery → CJ match → pricing → scoring → shortlist → human review → handoff
// No contamina tablas legacy; totalmente independiente del flujo de evaluación.
// ====================================

model CjEbayOpportunityRun {
  id                String    @id @default(cuid())
  userId            Int
  /// PENDING | RUNNING | COMPLETED | FAILED
  status            String    @default("PENDING")
  /// STARTER (restricted, account-new safe) | STANDARD
  mode              String    @default("STARTER")
  seedCount         Int       @default(0)
  candidateCount    Int       @default(0)
  shortlistedCount  Int       @default(0)
  approvedCount     Int       @default(0)
  rejectedCount     Int       @default(0)
  deferredCount     Int       @default(0)
  /// Scoring weights + filter settings used for this run (snapshot for auditability).
  settings          Json?
  errorMessage      String?   @db.Text
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user       User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidates CjEbayOpportunityCandidate[]

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("cj_ebay_opportunity_runs")
}

model CjEbayOpportunityCandidate {
  id                    String   @id @default(cuid())
  runId                 String
  userId                Int
  /// Keyword or concept that originated this candidate.
  seedKeyword           String
  seedCategory          String?
  /// 0.0–1.0 confidence from the trend provider.
  seedTrendConfidence   Decimal  @default(0.5) @db.Decimal(4, 3)
  /// MOCK_TREND | EBAY_RESEARCH | MANUAL
  seedSource            String   @default("MOCK_TREND")
  cjProductId           String
  cjProductTitle        String
  cjVariantSku          String
  cjVariantVid          String?
  images                Json?
  supplierCostUsd       Decimal  @db.Decimal(18, 2)
  shippingUsd           Decimal  @db.Decimal(18, 2)
  /// KNOWN | ESTIMATED | UNKNOWN
  shippingConfidence    String   @default("UNKNOWN")
  shippingDaysMin       Int?
  shippingDaysMax       Int?
  stockCount            Int?
  /// Observed competing price on eBay market (null = not fetched).
  marketObservedPriceUsd Decimal? @db.Decimal(18, 2)
  /// Full pricing breakdown (JSON snapshot of CjOpportunityPricingResult).
  pricingBreakdown      Json?
  /// Full score breakdown (JSON snapshot of OpportunityScoreBreakdown).
  scoreBreakdown        Json?
  totalScore            Decimal  @default(0) @db.Decimal(6, 3)
  /// Human-readable explanation of recommendation.
  recommendationReason  String?  @db.Text
  /// SHORTLISTED | APPROVED | REJECTED | DEFERRED
  status                String   @default("SHORTLISTED")
  reviewNotes           String?  @db.Text
  reviewedAt            DateTime?
  /// Set when candidate is handed off to evaluation pipeline.
  handedOffAt           DateTime?
  /// evaluationId from cj_ebay_product_evaluations if handoff completed.
  linkedEvaluationId    Int?
  // ---- FASE 3G.1: data quality & market reality ----
  /// REAL | ESTIMATED | HYBRID | MOCK — origin of the trend signal.
  trendSourceType       String   @default("MOCK")
  /// REAL | ESTIMATED | HYBRID | MOCK — origin of the market price data.
  marketPriceSourceType String   @default("ESTIMATED")
  /// 0–100: composite quality of all underlying data signals.
  dataConfidenceScore   Decimal  @default(30) @db.Decimal(5, 2)
  /// HIGH | MEDIUM | LOW
  recommendationConfidence String @default("LOW")
  /// GOOD_FOR_STARTER | CAUTION_FOR_STARTER | NOT_RECOMMENDED_FOR_STARTER
  starterSuitability    String   @default("CAUTION_FOR_STARTER")
  /// Human-readable evidence summary (market + trend + shipping sources).
  evidenceSummary       String?  @db.Text
  /// Full MarketObservedPriceResult snapshot (JSON).
  marketPriceDetail     Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  run  CjEbayOpportunityRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  user User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([userId, status])
  @@index([userId, totalScore])
  @@map("cj_ebay_opportunity_candidates")
}

// ====================================
// CJ → eBay UK vertical (cj_ebay_uk_*)
// Mirror of CJ→eBay USA architecture; destination = United Kingdom (GB).
// Key differences: GBP currency, UK VAT (20% marketplace-facilitated for ≤£135),
// eBay UK (siteId=3 / ebay.co.uk), GB warehouse probing via startCountryCode=GB.
// ====================================

model CjEbayUkAccountSettings {
  id                         Int      @id @default(autoincrement())
  userId                     Int      @unique
  minMarginPct               Decimal? @db.Decimal(6, 4)
  minProfitGbp               Decimal? @db.Decimal(18, 2)
  maxShippingUsd             Decimal? @db.Decimal(18, 2)
  handlingBufferDays         Int      @default(3)
  minStock                   Int      @default(1)
  rejectOnUnknownShipping    Boolean  @default(true)
  maxRiskScore               Int?
  priceChangePctReevaluate   Decimal? @db.Decimal(6, 4)
  incidentBufferPct          Decimal? @db.Decimal(6, 4)
  /// eBay UK FVF effective % on listed price. Default ~12.8%.
  defaultEbayFeePct          Decimal? @db.Decimal(6, 4)
  defaultPaymentFeePct       Decimal? @db.Decimal(6, 4)
  defaultPaymentFixedFeeGbp  Decimal? @db.Decimal(18, 2)
  /// UK VAT rate applied by eBay as marketplace facilitator (default 20).
  ukVatPct                   Decimal  @default(20) @db.Decimal(6, 4)
  /// When true, eBay UK collects VAT from buyer and deducts from seller payout (applies ≤£135).
  vatMarketplaceFacilitated  Boolean  @default(true)
  /// USD→GBP exchange rate used for cost conversion. Operator-set; updated manually.
  fxRateUsdToGbp             Decimal  @default(0.79) @db.Decimal(10, 6)
  cjPostCreateCheckoutMode   String   @default("MANUAL")
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cj_ebay_uk_account_settings")
}

model CjEbayUkProduct {
  id               Int       @id @default(autoincrement())
  userId           Int
  cjProductId      String
  title            String
  description      String?   @db.Text
  images           Json?
  rawPayloadHash   String?
  snapshotStatus   String    @default("SYNCED")
  lastSyncedAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  variants         CjEbayUkProductVariant[]
  shippingQuotes   CjEbayUkShippingQuote[]
  evaluations      CjEbayUkProductEvaluation[]
  listings         CjEbayUkListing[]
  orders           CjEbayUkOrder[]

  @@unique([userId, cjProductId])
  @@index([userId])
  @@index([userId, snapshotStatus])
  @@map("cj_ebay_uk_products")
}

model CjEbayUkProductVariant {
  id             Int       @id @default(autoincrement())
  productId      Int
  cjSku          String
  cjVid          String?
  attributes     Json?
  unitCostUsd    Decimal?  @db.Decimal(18, 2)
  stockLastKnown Int?
  stockCheckedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  product        CjEbayUkProduct             @relation(fields: [productId], references: [id], onDelete: Cascade)
  shippingQuotes CjEbayUkShippingQuote[]
  evaluations    CjEbayUkProductEvaluation[]
  listings       CjEbayUkListing[]
  orders         CjEbayUkOrder[]

  @@unique([productId, cjSku])
  @@index([productId])
  @@index([productId, cjVid])
  @@map("cj_ebay_uk_product_variants")
}

model CjEbayUkShippingQuote {
  id                Int       @id @default(autoincrement())
  userId            Int
  productId         Int
  variantId         Int?
  quantity          Int       @default(1)
  /// Shipping cost in USD (raw from CJ API).
  amountUsd         Decimal   @db.Decimal(18, 2)
  /// Shipping cost converted to GBP at snapshot FX rate.
  amountGbp         Decimal?  @db.Decimal(18, 2)
  /// FX rate used for USD→GBP conversion.
  fxRateUsed        Decimal?  @db.Decimal(10, 6)
  currency          String    @default("GBP")
  serviceName       String?
  carrier           String?
  estimatedMinDays  Int?
  estimatedMaxDays  Int?
  confidence        String    @default("unknown")
  /// GB = GB warehouse confirmed; CN = ships from China.
  fulfillmentOrigin String?
  /// CJ freight API raw payload for audit.
  requestPayload    Json?
  responseRaw       Json?
  originCountryCode String?
  quotedAt          DateTime  @default(now())
  expiresAt         DateTime?

  product   CjEbayUkProduct         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   CjEbayUkProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, productId])
  @@map("cj_ebay_uk_shipping_quotes")
}

model CjEbayUkProductEvaluation {
  id                    Int       @id @default(autoincrement())
  userId                Int
  productId             Int
  variantId             Int?
  shippingQuoteId       Int?
  decision              String    @default("PENDING")
  reasons               Json?
  /// Supplier cost in USD at evaluation time.
  supplierCostUsd       Decimal?  @db.Decimal(18, 2)
  shippingUsd           Decimal?  @db.Decimal(18, 2)
  /// Shipping cost in GBP.
  shippingGbp           Decimal?  @db.Decimal(18, 2)
  fxRateUsed            Decimal?  @db.Decimal(10, 6)
  estimatedListPriceGbp Decimal?  @db.Decimal(18, 2)
  estimatedMarginPct    Decimal?  @db.Decimal(6, 4)
  estimatedProfitGbp    Decimal?  @db.Decimal(18, 2)
  vatDeductedGbp        Decimal?  @db.Decimal(18, 2)
  riskScore             Int?
  fulfillmentOrigin     String?
  rawBreakdown          Json?
  evaluatedAt           DateTime  @default(now())
  expiresAt             DateTime?

  user    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product CjEbayUkProduct         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant CjEbayUkProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([userId, decision])
  @@index([productId])
  @@map("cj_ebay_uk_product_evaluations")
}

model CjEbayUkListing {
  id              Int       @id @default(autoincrement())
  userId          Int
  productId       Int
  variantId       Int?
  status          String    @default("DRAFT")
  ebayListingId   String?
