  @@map("topdawg_shopify_usa_order_events")
}

model TopDawgShopifyUsaTracking {
  id              Int     @id @default(autoincrement())
  orderId         Int
  trackingNumber  String? @db.Text
  carrierCode     String? @db.VarChar(100)
  status          String? @db.VarChar(50)
  syncedToShopify Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order TopDawgShopifyUsaOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("topdawg_shopify_usa_tracking")
}

model TopDawgShopifyUsaAlert {
  id         Int       @id @default(autoincrement())
  userId     Int
  type       String    @db.VarChar(100)
  severity   String    @default("WARNING")
  status     String    @default("OPEN")
  title      String    @db.Text
  message    String    @db.Text
  meta       Json?
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("topdawg_shopify_usa_alerts")
}

model TopDawgShopifyUsaExecutionTrace {
  id            Int      @id @default(autoincrement())
  userId        Int?
  correlationId String?  @db.VarChar(100)
  step          String   @db.VarChar(100)
  status        String   @db.VarChar(20)
  message       String   @db.Text
  durationMs    Int?
  meta          Json?
  createdAt     DateTime @default(now())

  @@map("topdawg_shopify_usa_execution_traces")
}

model TopDawgShopifyUsaProfitSnapshot {
  id         Int     @id @default(autoincrement())
  userId     Int
  date       DateTime @db.Date
  revenueUsd Decimal  @db.Decimal(12, 2)
  costUsd    Decimal  @db.Decimal(12, 2)
  feesUsd    Decimal  @db.Decimal(12, 2)
  profitUsd  Decimal  @db.Decimal(12, 2)
  orderCount Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("topdawg_shopify_usa_profit_snapshots")
}
