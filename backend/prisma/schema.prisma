model APIStatusHistory {
  id             Int      @id @default(autoincrement())
  userId         Int
  apiName        String
  environment    String   @default("production")
  status         String // "healthy", "degraded", "unhealthy", "unknown"
  previousStatus String? // Estado anterior
  isAvailable    Boolean
