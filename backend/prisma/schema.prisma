  product  CjEbayUkProduct?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant  CjEbayUkProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  listing  CjEbayUkListing?        @relation(fields: [listingId], references: [id], onDelete: SetNull)
