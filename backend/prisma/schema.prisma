model CjEbayUkOrder {
  id                   Int       @id @default(autoincrement())
  userId               Int
  productId            Int?
  variantId            Int?
  listingId            Int?
  ebayOrderId          String
  cjOrderId            String?
  status               String    @default("DETECTED")
  paymentBlockReason   String?
  /// eBay order total in GBP.
  totalGbp             Decimal?  @db.Decimal(18, 2)
  rawEbaySummary       Json?
  buyerPayload         Json?
