  @@index([userId, type])
  @@index([enabled, nextRun])
  @@index([nextRun])
  @@map("autopilot_workflows")
}

// ✅ LOGS DE CICLOS AUTOPILOT - Persist every cycle execution, decision, failure
model AutopilotCycleLog {
