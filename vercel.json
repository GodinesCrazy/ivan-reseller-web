{
  "framework": null,
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://ivan-reseller-backend-production.up.railway.app/api/$1"
    },
    {
      "src": "/aliexpress/callback",
      "dest": "https://ivan-reseller-backend-production.up.railway.app/aliexpress/callback"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
