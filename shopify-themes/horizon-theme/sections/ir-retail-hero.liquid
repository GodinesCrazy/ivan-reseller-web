{%- comment -%}
  IvanReseller retail commerce hero.
  Dense premium electronics-store composition with category entry, promo tiles,
  live product imagery, and direct catalog paths.
{%- endcomment -%}

{%- liquid
  assign hero_collection = collections[section.settings.collection]
  if hero_collection == blank
    assign hero_collection = collections['all']
  endif

  assign hero_product = section.settings.hero_product
  if hero_product == blank
    assign hero_product = hero_collection.products.first
  endif

  assign side_product = blank
  for product in hero_collection.products offset: 1 limit: 1
    assign side_product = product
  endfor

  if side_product == blank
    assign side_product = hero_product
  endif
-%}

<section class="ir-retail-hero" data-section-id="{{ section.id }}">
  <div class="ir-retail-hero__container">
    <div class="ir-retail-hero__utility">
      <a href="{{ routes.all_products_collection_url }}">Returns and exchanges</a>
      <a href="{{ routes.search_url }}?q=order">Track order</a>
      <a href="{{ routes.all_products_collection_url }}">Help and support</a>
      <span>support@ivanreseller.com</span>
      <span>English (USD)</span>
    </div>

    <div class="ir-retail-hero__category-row" aria-label="Featured categories">
      {% for block in section.blocks %}
        {% if block.type == 'category' %}
          {%- liquid
            assign category_collection = collections[block.settings.collection]
            assign category_product = blank
            if category_collection != blank
              assign category_product = category_collection.products.first
            endif
            if category_product == blank
              assign category_product = hero_collection.products[forloop.index0]
            endif
          -%}
          <a href="{{ block.settings.link | default: routes.all_products_collection_url }}" class="ir-retail-cat" {{ block.shopify_attributes }}>
            <span class="ir-retail-cat__copy">
              <strong>{{ block.settings.title }}</strong>
              <small>{{ block.settings.caption }}</small>
            </span>
            <span class="ir-retail-cat__visual">
              {% if category_product.featured_image != blank %}
                {{ category_product.featured_image | image_url: width: 180 | image_tag: class: 'ir-retail-cat__image', loading: 'lazy', alt: category_product.title }}
              {% else %}
                <span class="ir-retail-cat__fallback"></span>
              {% endif %}
            </span>
          </a>
        {% endif %}
      {% endfor %}
    </div>

    <div class="ir-retail-hero__grid">
      <a href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}" class="ir-retail-hero__feature">
        <div class="ir-retail-hero__feature-copy">
          <p class="ir-retail-hero__eyebrow">{{ section.settings.eyebrow }}</p>
          <h1>{{ section.settings.title }}</h1>
          <p>{{ section.settings.description }}</p>
          <span class="ir-retail-hero__button">{{ section.settings.button_text }}</span>
        </div>

        {% if hero_product != blank and hero_product.featured_image != blank %}
          <div class="ir-retail-hero__product-stage">
            {{ hero_product.featured_image | image_url: width: 1000 | image_tag: class: 'ir-retail-hero__product-image', loading: 'eager', alt: hero_product.title }}
            <div class="ir-retail-hero__product-card">
              <span>Featured pick</span>
              <strong>{{ hero_product.title | truncate: 42 }}</strong>
              <small>{{ hero_product.price | money }}</small>
            </div>
          </div>
        {% endif %}

        <div class="ir-retail-hero__save-badge">
          <span>Save</span>
          <strong>{{ section.settings.discount_text }}</strong>
        </div>
      </a>

      <div class="ir-retail-hero__side">
        <a href="{{ section.settings.side_link | default: routes.all_products_collection_url }}" class="ir-retail-hero__promo ir-retail-hero__promo--light">
          <div>
            <span>{{ section.settings.side_eyebrow }}</span>
            <strong>{{ section.settings.side_title }}</strong>
            <small>{{ section.settings.side_text }}</small>
          </div>
          {% if side_product != blank and side_product.featured_image != blank %}
            {{ side_product.featured_image | image_url: width: 620 | image_tag: class: 'ir-retail-hero__side-image', loading: 'eager', alt: side_product.title }}
          {% endif %}
        </a>

        <div class="ir-retail-hero__mini-grid">
          <a href="{{ routes.search_url }}?q=charging" class="ir-retail-hero__mini">
            <span>Power</span>
            <strong>Charging picks</strong>
            <small>Portable power and cables</small>
          </a>
          <a href="{{ routes.search_url }}?q=travel" class="ir-retail-hero__mini ir-retail-hero__mini--dark">
            <span>Travel</span>
            <strong>Carry smarter</strong>
            <small>Compact everyday utility</small>
          </a>
        </div>
      </div>
    </div>

    <div class="ir-retail-hero__deal-strip">
      <span>Fast product discovery</span>
      <span>Real product images</span>
      <span>Clear pricing</span>
      <span>Secure checkout path</span>
    </div>
  </div>
</section>

<style>
  .ir-retail-hero {
    background: #f3f5f7;
    padding: 1rem 0 3.4rem;
  }

  .ir-retail-hero__container {
    width: min(1560px, calc(100vw - 48px));
    margin: 0 auto;
  }

  .ir-retail-hero__utility {
    min-height: 3rem;
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.4vw, 2.2rem);
    color: #4b5563;
    font-size: 0.86rem;
    border-bottom: 1px solid rgba(15, 23, 42, 0.06);
  }

  .ir-retail-hero__utility a,
  .ir-retail-hero__utility span {
    color: inherit;
    text-decoration: none;
    white-space: nowrap;
  }

  .ir-retail-hero__utility span:nth-last-child(2) {
    margin-left: auto;
  }

  .ir-retail-hero__category-row {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 0.65rem;
    padding: 1rem 0 1.55rem;
  }

  .ir-retail-cat {
    min-height: 5rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 4.5rem;
    gap: 0.75rem;
    align-items: center;
    padding: 0.78rem 0.9rem;
    border: 1px solid rgba(15, 23, 42, 0.06);
    border-radius: 10px;
    background: #ffffff;
    color: #111827;
    text-decoration: none;
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.04);
  }

  .ir-retail-cat__copy {
    min-width: 0;
  }

  .ir-retail-cat strong {
    display: block;
    color: #111827;
    font-size: 1rem;
    line-height: 1.1;
    font-weight: 790;
  }

  .ir-retail-cat small {
    display: block;
    margin-top: 0.25rem;
    color: #596273;
    font-size: 0.82rem;
  }

  .ir-retail-cat__visual {
    width: 4.2rem;
    height: 3.2rem;
    display: grid;
    place-items: center;
    border-radius: 8px;
    background: #eef3ff;
    overflow: hidden;
  }

  .ir-retail-cat__image {
    width: 86%;
    height: 86%;
    object-fit: contain;
    filter: drop-shadow(0 8px 12px rgba(15, 23, 42, 0.16));
  }

  .ir-retail-cat__fallback {
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 8px;
    background: linear-gradient(135deg, #0f766e, #1d4ed8);
  }

  .ir-retail-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.65fr) minmax(20rem, 0.55fr);
    gap: 0.75rem;
  }

  .ir-retail-hero__feature,
  .ir-retail-hero__promo,
  .ir-retail-hero__mini {
    position: relative;
    overflow: hidden;
    min-height: 29rem;
    border-radius: 12px;
    text-decoration: none;
  }

  .ir-retail-hero__feature {
    display: grid;
    grid-template-columns: minmax(20rem, 0.68fr) minmax(22rem, 1fr);
    align-items: end;
    padding: clamp(2rem, 4vw, 4rem);
    color: #ffffff;
    background:
      radial-gradient(circle at 62% 45%, rgba(255,255,255,0.12), transparent 24%),
      linear-gradient(112deg, #111827 0%, #202833 52%, #4b5563 100%);
  }

  .ir-retail-hero__feature::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(0,0,0,0.18), transparent 54%);
    pointer-events: none;
  }

  .ir-retail-hero__feature-copy,
  .ir-retail-hero__product-stage,
  .ir-retail-hero__save-badge {
    position: relative;
    z-index: 1;
  }

  .ir-retail-hero__eyebrow {
    margin: 0 0 0.85rem;
    color: rgba(255,255,255,0.72);
    font-size: 0.76rem;
    font-weight: 820;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .ir-retail-hero h1 {
    max-width: 12ch;
    margin: 0;
    color: #ffffff;
    font-size: clamp(3rem, 6vw, 6.4rem);
    line-height: 0.88;
    font-weight: 850;
    letter-spacing: 0;
  }

  .ir-retail-hero__feature-copy p:not(.ir-retail-hero__eyebrow) {
    max-width: 33rem;
    margin: 1.15rem 0 0;
    color: rgba(255,255,255,0.78);
    font-size: 1.05rem;
    line-height: 1.65;
  }

  .ir-retail-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    margin-top: 1.55rem;
    padding: 0 1.15rem;
    border-radius: 8px;
    background: #ffffff;
    color: #111827;
    font-size: 0.95rem;
    font-weight: 820;
  }

  .ir-retail-hero__product-stage {
    align-self: stretch;
    display: grid;
    place-items: center;
  }

  .ir-retail-hero__product-image {
    width: min(82%, 35rem);
    max-height: 25rem;
    object-fit: contain;
    filter: drop-shadow(0 34px 42px rgba(0,0,0,0.35));
    transform: rotate(-4deg);
  }

  .ir-retail-hero__product-card {
    position: absolute;
    right: clamp(1.5rem, 3vw, 3rem);
    bottom: 2rem;
    max-width: 16rem;
    padding: 1rem;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 10px;
    background: rgba(255,255,255,0.14);
    backdrop-filter: blur(18px);
  }

  .ir-retail-hero__product-card span,
  .ir-retail-hero__product-card small {
    display: block;
    color: rgba(255,255,255,0.72);
    font-size: 0.74rem;
    font-weight: 760;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .ir-retail-hero__product-card strong {
    display: block;
    margin: 0.28rem 0;
    color: #ffffff;
    font-size: 0.98rem;
    line-height: 1.25;
  }

  .ir-retail-hero__save-badge {
    position: absolute;
    right: 0;
    top: 0;
    width: 6.8rem;
    height: 7.6rem;
    display: grid;
    place-items: center;
    align-content: center;
    border-radius: 0 0 48px 48px;
    background: #b91c1c;
    color: #ffffff;
    box-shadow: 0 20px 34px rgba(185, 28, 28, 0.28);
  }

  .ir-retail-hero__save-badge span {
    font-size: 1rem;
    font-weight: 760;
  }

  .ir-retail-hero__save-badge strong {
    display: block;
    font-size: 1.9rem;
    line-height: 1;
  }

  .ir-retail-hero__side {
    display: grid;
    gap: 0.75rem;
  }

  .ir-retail-hero__promo {
    min-height: 18.5rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(9rem, 0.85fr);
    align-items: center;
    padding: 1.7rem;
    color: #111827;
    background: #e8e5df;
  }

  .ir-retail-hero__promo span,
  .ir-retail-hero__mini span {
    display: block;
    margin-bottom: 0.45rem;
    color: #4b5563;
    font-size: 0.78rem;
    font-weight: 820;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .ir-retail-hero__promo strong {
    display: block;
    max-width: 11ch;
    color: #111827;
    font-size: clamp(1.6rem, 2.4vw, 2.3rem);
    line-height: 1.02;
    font-weight: 820;
  }

  .ir-retail-hero__promo small,
  .ir-retail-hero__mini small {
    display: block;
    margin-top: 0.75rem;
    color: #4b5563;
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .ir-retail-hero__side-image {
    width: 100%;
    max-height: 15rem;
    object-fit: contain;
    filter: drop-shadow(0 18px 24px rgba(15, 23, 42, 0.18));
    transform: rotate(7deg) scale(1.08);
  }

  .ir-retail-hero__mini-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .ir-retail-hero__mini {
    min-height: 9.75rem;
    padding: 1.15rem;
    color: #111827;
    background: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.06);
  }

  .ir-retail-hero__mini strong {
    display: block;
    color: #111827;
    font-size: 1.25rem;
    line-height: 1.06;
  }

  .ir-retail-hero__mini--dark {
    background: #111827;
    color: #ffffff;
  }

  .ir-retail-hero__mini--dark strong {
    color: #ffffff;
  }

  .ir-retail-hero__mini--dark span,
  .ir-retail-hero__mini--dark small {
    color: rgba(255,255,255,0.72);
  }

  .ir-retail-hero__deal-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  .ir-retail-hero__deal-strip span {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 3.2rem;
    border-radius: 10px;
    background: #ffffff;
    color: #263242;
    font-size: 0.9rem;
    font-weight: 740;
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.04);
  }

  @media screen and (max-width: 1100px) {
    .ir-retail-hero__category-row {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .ir-retail-hero__grid {
      grid-template-columns: 1fr;
    }

    .ir-retail-hero__feature {
      min-height: 34rem;
    }
  }

  @media screen and (max-width: 749px) {
    .ir-retail-hero {
      padding-top: 0.75rem;
    }

    .ir-retail-hero__container {
      width: calc(100vw - 28px);
    }

    .ir-retail-hero__utility {
      overflow-x: auto;
      gap: 1.2rem;
      scrollbar-width: none;
    }

    .ir-retail-hero__utility::-webkit-scrollbar {
      display: none;
    }

    .ir-retail-hero__category-row {
      display: flex;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .ir-retail-hero__category-row::-webkit-scrollbar {
      display: none;
    }

    .ir-retail-cat {
      min-width: 15rem;
    }

    .ir-retail-hero__feature {
      grid-template-columns: 1fr;
      min-height: 38rem;
      padding: 1.5rem;
    }

    .ir-retail-hero h1 {
      font-size: clamp(3.1rem, 16vw, 4.8rem);
    }

    .ir-retail-hero__product-image {
      width: min(92%, 26rem);
    }

    .ir-retail-hero__product-card {
      left: 1.25rem;
      right: 1.25rem;
      bottom: 1.25rem;
      max-width: none;
    }

    .ir-retail-hero__save-badge {
      width: 5.8rem;
      height: 6.6rem;
    }

    .ir-retail-hero__promo,
    .ir-retail-hero__mini-grid,
    .ir-retail-hero__deal-strip {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "IR - Retail Hero",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Product collection"
    },
    {
      "type": "product",
      "id": "hero_product",
      "label": "Hero product"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "IvanReseller deal room"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Tech savings, made easier."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Shop practical electronics, travel accessories, workspace tools, and everyday gadgets in one focused storefront."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop the catalog"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary link"
    },
    {
      "type": "text",
      "id": "discount_text",
      "label": "Discount badge",
      "default": "45%"
    },
    {
      "type": "text",
      "id": "side_eyebrow",
      "label": "Side eyebrow",
      "default": "Smartphones"
    },
    {
      "type": "text",
      "id": "side_title",
      "label": "Side title",
      "default": "You will love"
    },
    {
      "type": "text",
      "id": "side_text",
      "label": "Side text",
      "default": "New practical picks at accessible prices."
    },
    {
      "type": "url",
      "id": "side_link",
      "label": "Side link"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Power"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "default": "12 items"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "IR - Retail Hero",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
