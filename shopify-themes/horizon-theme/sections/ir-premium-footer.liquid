{%- comment -%}
  IVAN RESELLER - Premium Footer
  Executive-grade footer with comprehensive structure
{%- endcomment -%}

{%- liquid
  assign menu_1 = section.settings.menu_1
  assign menu_2 = section.settings.menu_2
  assign menu_3 = section.settings.menu_3
  assign menu_1_title = section.settings.menu_1_title
  assign menu_2_title = section.settings.menu_2_title
  assign menu_3_title = section.settings.menu_3_title
-%}

<footer class="ir-premium-footer color-{{ section.settings.color_scheme }}" data-section-id="{{ section.id }}">
  {% comment %}Main Footer Content{% endcomment %}
  <div class="ir-premium-footer__main">
    <div class="ir-premium-footer__container">
      {% comment %}Brand Column{% endcomment %}
      <div class="ir-premium-footer__brand">
        <a href="{{ routes.root_url }}" class="ir-premium-footer__logo-link">
          {% render 'ir-logo' %}
        </a>
        
        {% if section.settings.brand_description != blank %}
          <p class="ir-premium-footer__description">{{ section.settings.brand_description }}</p>
        {% endif %}
        
        {% comment %}Social Links{% endcomment %}
        {% if section.settings.show_social %}
          <div class="ir-premium-footer__social">
            {% if settings.social_facebook_link != blank %}
              <a href="{{ settings.social_facebook_link }}" class="ir-premium-footer__social-link" aria-label="Facebook" target="_blank" rel="noopener">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
              </a>
            {% endif %}
            {% if settings.social_instagram_link != blank %}
              <a href="{{ settings.social_instagram_link }}" class="ir-premium-footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </a>
            {% endif %}
            {% if settings.social_twitter_link != blank %}
              <a href="{{ settings.social_twitter_link }}" class="ir-premium-footer__social-link" aria-label="Twitter" target="_blank" rel="noopener">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
            {% endif %}
            {% if settings.social_tiktok_link != blank %}
              <a href="{{ settings.social_tiktok_link }}" class="ir-premium-footer__social-link" aria-label="TikTok" target="_blank" rel="noopener">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
              </a>
            {% endif %}
            {% if settings.social_youtube_link != blank %}
              <a href="{{ settings.social_youtube_link }}" class="ir-premium-footer__social-link" aria-label="YouTube" target="_blank" rel="noopener">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>
      
      {% comment %}Navigation Columns{% endcomment %}
      <div class="ir-premium-footer__nav">
        {% if menu_1 != blank %}
          <div class="ir-premium-footer__column">
            <h3 class="ir-premium-footer__title">{{ menu_1_title | default: 'Shop' }}</h3>
            <ul class="ir-premium-footer__menu">
              {% for link in linklists[menu_1].links %}
                <li>
                  <a href="{{ link.url }}" class="ir-premium-footer__link">{{ link.title }}</a>
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
        
        {% if menu_2 != blank %}
          <div class="ir-premium-footer__column">
            <h3 class="ir-premium-footer__title">{{ menu_2_title | default: 'Support' }}</h3>
            <ul class="ir-premium-footer__menu">
              {% for link in linklists[menu_2].links %}
                <li>
                  <a href="{{ link.url }}" class="ir-premium-footer__link">{{ link.title }}</a>
                </li>
              {% endfor %}
            </ul>
          </div>
        {% else %}
          <div class="ir-premium-footer__column">
            <h3 class="ir-premium-footer__title">{{ menu_2_title | default: 'Support' }}</h3>
            <ul class="ir-premium-footer__menu">
              <li><a href="{{ routes.search_url }}" class="ir-premium-footer__link">Search products</a></li>
              <li><a href="{{ routes.cart_url }}" class="ir-premium-footer__link">View cart</a></li>
              <li><a href="mailto:{{ shop.email | default: 'support@ivanreseller.com' }}" class="ir-premium-footer__link">Contact support</a></li>
            </ul>
          </div>
        {% endif %}
        
        {% if menu_3 != blank %}
          <div class="ir-premium-footer__column">
            <h3 class="ir-premium-footer__title">{{ menu_3_title | default: 'Company' }}</h3>
            <ul class="ir-premium-footer__menu">
              {% for link in linklists[menu_3].links %}
                <li>
                  <a href="{{ link.url }}" class="ir-premium-footer__link">{{ link.title }}</a>
                </li>
              {% endfor %}
            </ul>
          </div>
        {% else %}
          <div class="ir-premium-footer__column">
            <h3 class="ir-premium-footer__title">{{ menu_3_title | default: 'Company' }}</h3>
            <ul class="ir-premium-footer__menu">
              <li><a href="{{ routes.all_products_collection_url }}" class="ir-premium-footer__link">All products</a></li>
              <li><a href="{{ routes.search_url }}?q=travel" class="ir-premium-footer__link">Travel accessories</a></li>
              <li><a href="{{ routes.search_url }}?q=workspace" class="ir-premium-footer__link">Workspace tools</a></li>
              <li><a href="{{ routes.search_url }}?q=pet+grooming" class="ir-premium-footer__link">Pet essentials</a></li>
            </ul>
          </div>
        {% endif %}
      </div>
      
      {% comment %}Newsletter Column{% endcomment %}
      {% if section.settings.show_newsletter %}
        <div class="ir-premium-footer__newsletter">
          <h3 class="ir-premium-footer__title">{{ section.settings.newsletter_title | default: 'Stay Updated' }}</h3>
          <p class="ir-premium-footer__newsletter-text">{{ section.settings.newsletter_text | default: 'Subscribe for exclusive deals and new arrivals.' }}</p>
          
          {% form 'customer', id: 'footer-newsletter', class: 'ir-premium-footer__form' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="ir-premium-footer__form-group">
              <input
                type="email"
                name="contact[email]"
                class="ir-premium-footer__input"
                placeholder="{{ section.settings.placeholder | default: 'Enter your email' }}"
                required
                aria-label="{{ section.settings.placeholder | default: 'Enter your email' }}"
              >
              <button type="submit" class="ir-premium-footer__submit" aria-label="Subscribe">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="22" y1="2" x2="11" y2="13"/>
                  <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                </svg>
              </button>
            </div>
            {% if form.posted_successfully? %}
              <p class="ir-premium-footer__success">{{ section.settings.success_message | default: 'Thanks for subscribing!' }}</p>
            {% elsif form.errors %}
              <p class="ir-premium-footer__error">{{ form.errors.messages.email }}</p>
            {% endif %}
          {% endform %}
        </div>
      {% endif %}
    </div>
  </div>
  
  {% comment %}Trust Bar{% endcomment %}
  {% if section.settings.show_trust %}
    <div class="ir-premium-footer__trust">
      <div class="ir-premium-footer__trust-container">
        {% if section.settings.show_payment_icons %}
          <div class="ir-premium-footer__payments">
            <span class="ir-premium-footer__trust-label">Secure Payment</span>
            <div class="ir-premium-footer__payment-icons">
              {% if section.settings.show_visa %}
                <span class="ir-premium-footer__payment-icon" aria-label="Visa">
                  <svg width="32" height="20" viewBox="0 0 48 32" fill="none"><rect width="48" height="32" rx="4" fill="#1A1F71"/><path d="M19.2 11l-3.2 10h2.2l3.2-10h-2.2zM35.4 11l-2.8 7-1.2-6c-.2-.8-.8-1-1.6-1h-5l-.1.2c1.4.4 2.4 1 3 1.6l-2.6 6.2h2.4l3.8-10h-2.4zM27.6 11h-4v10h2.4v-3h1.6c2 0 3.4-1.2 3.4-3.2 0-2.4-1.2-3.8-3.4-3.8zm-.6 4.4h-1v-2.8h1c.8 0 1.4.4 1.4 1.4 0 1-.6 1.4-1.4 1.4zM12.4 11h-4v10h2.4v-3h1.6c2 0 3.4-1.2 3.4-3.2 0-2.4-1.2-3.8-3.4-3.8zm-.6 4.4h-1v-2.8h1c.8 0 1.4.4 1.4 1.4 0 1-.6 1.4-1.4 1.4z" fill="white"/></svg>
                </span>
              {% endif %}
              {% if section.settings.show_mastercard %}
                <span class="ir-premium-footer__payment-icon" aria-label="Mastercard">
                  <svg width="32" height="20" viewBox="0 0 48 32" fill="none"><rect width="48" height="32" rx="4" fill="#F5F5F5"/><circle cx="18" cy="16" r="8" fill="#EB001B"/><circle cx="30" cy="16" r="8" fill="#F79E1B"/><path d="M24 10c2.2 2.4 2.2 5.6 0 8 2.2-2.4 2.2-5.6 0-8z" fill="#FF5F00"/></svg>
                </span>
              {% endif %}
              {% if section.settings.show_amex %}
                <span class="ir-premium-footer__payment-icon" aria-label="American Express">
                  <svg width="32" height="20" viewBox="0 0 48 32" fill="none"><rect width="48" height="32" rx="4" fill="#016FD0"/><path d="M8 8h10l4 8 4-8h10v16H8V8zm4 2v12h32V10H12z" fill="white" opacity="0.2"/><path d="M12 14h6v2h-6v-2zm8 0h6v2h-6v-2z" fill="white"/></svg>
                </span>
              {% endif %}
              {% if section.settings.show_paypal %}
                <span class="ir-premium-footer__payment-icon" aria-label="PayPal">
                  <svg width="32" height="20" viewBox="0 0 48 32" fill="none"><rect width="48" height="32" rx="4" fill="#F5F5F5"/><path d="M18 12h6c2 0 3 1 3 2.5 0 2-1.2 3.5-3.8 3.5H20l-.5 3h-2l2-9z" fill="#003087"/><path d="M26 12h2l-.8 5h2.3c1.5 0 2.5-.5 2.8-2l.4-2c.3-1-.2-1-1.2-1h-4.5z" fill="#0070E0"/><path d="M26 12h2l-.8 5h2.3c1.5 0 2.5-.5 2.8-2l.4-2c.3-1-.2-1-1.2-1h-4.5z" fill="#0070E0"/></svg>
                </span>
              {% endif %}
            </div>
          </div>
        {% endif %}
        
        {% if section.settings.show_trust_badges %}
          <div class="ir-premium-footer__trust-badges">
            {% if section.settings.badge_1_text != blank %}
              <div class="ir-premium-footer__badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8 12l3 3 5-6"/></svg>
                <span>{{ section.settings.badge_1_text }}</span>
              </div>
            {% endif %}
            {% if section.settings.badge_2_text != blank %}
              <div class="ir-premium-footer__badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                <span>{{ section.settings.badge_2_text }}</span>
              </div>
            {% endif %}
            {% if section.settings.badge_3_text != blank %}
              <div class="ir-premium-footer__badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                <span>{{ section.settings.badge_3_text }}</span>
              </div>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  {% endif %}
  
  {% comment %}Bottom Bar{% endcomment %}
  <div class="ir-premium-footer__bottom">
    <div class="ir-premium-footer__bottom-container">
      <p class="ir-premium-footer__copyright">
        &copy; {{ "now" | date: "%Y" }} {{ shop.name }}. {{ section.settings.copyright_text | default: 'All rights reserved.' }}
      </p>
      
      {% if section.settings.show_legal_links and section.settings.legal_menu != blank %}
        <nav class="ir-premium-footer__legal">
          <ul>
            {% for link in linklists[section.settings.legal_menu].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        </nav>
      {% endif %}
    </div>
  </div>
</footer>

<style>
  .ir-premium-footer {
    background: #fafaf9;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }
  
  .ir-premium-footer.color-scheme-2 {
    background: #ffffff;
  }
  
  .ir-premium-footer.color-scheme-3 {
    background: #0f172a;
    color: rgba(255, 255, 255, 0.8);
    border-top: none;
  }
  
  .ir-premium-footer.color-scheme-3 .ir-premium-footer__title,
  .ir-premium-footer.color-scheme-3 .ir-premium-footer__link,
  .ir-premium-footer.color-scheme-3 .ir-premium-footer__copyright,
  .ir-premium-footer.color-scheme-3 .ir-premium-footer__newsletter-text {
    color: white;
  }
  
  /* Main Footer */
  .ir-premium-footer__main {
    padding: 64px 0 48px;
  }
  
  .ir-premium-footer__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 48px;
    display: grid;
    grid-template-columns: 1.5fr 2fr 1.2fr;
    gap: 64px;
  }
  
  /* Brand Column */
  .ir-premium-footer__brand {
    max-width: 320px;
  }
  
  .ir-premium-footer__logo-link {
    display: inline-block;
    margin-bottom: 20px;
  }
  
  .ir-premium-footer__logo-link svg {
    height: 32px;
    width: auto;
  }
  
  .ir-premium-footer__description {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #525252;
    margin-bottom: 24px;
  }
  
  .ir-premium-footer.color-scheme-3 .ir-premium-footer__description {
    color: rgba(255, 255, 255, 0.7);
  }
  
  /* Social Links */
  .ir-premium-footer__social {
    display: flex;
    gap: 12px;
  }
  
  .ir-premium-footer__social-link {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #f5f5f4;
    color: #525252;
    transition: all 0.2s ease;
  }
  
  .ir-premium-footer.color-scheme-3 .ir-premium-footer__social-link {
    background: rgba(255, 255, 255, 0.1);
    color: white;
  }
  
  .ir-premium-footer__social-link:hover {
    background: #0f172a;
    color: white;
    transform: translateY(-2px);
  }
  
  .ir-premium-footer.color-scheme-3 .ir-premium-footer__social-link:hover {
    background: white;
    color: #0f172a;
  }
  
  /* Navigation */
  .ir-premium-footer__nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  
  .ir-premium-footer__title {
    font-size: 0.875rem;
    font-weight: 600;
    color: #171717;
    margin-bottom: 16px;
    letter-spacing: 0;
  }
  
  .ir-premium-footer__menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .ir-premium-footer__menu li {
    margin-bottom: 10px;
  }
  
  .ir-premium-footer__link {
    font-size: 0.9375rem;
    color: #525252;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  
  .ir-premium-footer__link:hover {
    color: #0f172a;
  }
  
  .ir-premium-footer.color-scheme-3 .ir-premium-footer__link:hover {
    color: white;
    opacity: 0.8;
  }
  
  /* Newsletter */
  .ir-premium-footer__newsletter-text {
    font-size: 0.9375rem;
    color: #525252;
    margin-bottom: 16px;
  }
  
  .ir-premium-footer__form-group {
    display: flex;
    gap: 8px;
  }
  
  .ir-premium-footer__input {
    flex: 1;
    padding: 12px 16px;
    border: 1.5px solid #e5e5e5;
    border-radius: 100px;
    font-size: 0.9375rem;
    background: white;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  
  .ir-premium-footer__input:focus {
    border-color: #0f172a;
    box-shadow: 0 0 0 3px rgba(15, 23, 42, 0.08);
    outline: none;
  }
  
  .ir-premium-footer.color-scheme-3 .ir-premium-footer__input {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    color: white;
  }
  
  .ir-premium-footer.color-scheme-3 .ir-premium-footer__input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }
  
  .ir-premium-footer__submit {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #0f172a;
    color: white;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }
  
  .ir-premium-footer__submit:hover {
    background: #1e293b;
    transform: scale(1.05);
  }
  
  .ir-premium-footer.color-scheme-3 .ir-premium-footer__submit {
    background: white;
    color: #0f172a;
  }
  
  .ir-premium-footer__success {
    font-size: 0.875rem;
    color: #22c55e;
    margin-top: 8px;
  }
  
  .ir-premium-footer__error {
    font-size: 0.875rem;
    color: #dc2626;
    margin-top: 8px;
  }
  
  /* Trust Bar */
  .ir-premium-footer__trust {
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    padding: 24px 0;
    background: rgba(255, 255, 255, 0.5);
  }
  
  .ir-premium-footer.color-scheme-3 .ir-premium-footer__trust {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.1);
  }
  
  .ir-premium-footer__trust-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 24px;
  }
  
  .ir-premium-footer__payments {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  
  .ir-premium-footer__trust-label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: #525252;
  }
  
  .ir-premium-footer.color-scheme-3 .ir-premium-footer__trust-label {
    color: rgba(255, 255, 255, 0.7);
  }
  
  .ir-premium-footer__payment-icons {
    display: flex;
    gap: 8px;
  }
  
  .ir-premium-footer__payment-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .ir-premium-footer__trust-badges {
    display: flex;
    gap: 24px;
  }
  
  .ir-premium-footer__badge {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #525252;
  }
  
  .ir-premium-footer.color-scheme-3 .ir-premium-footer__badge {
    color: rgba(255, 255, 255, 0.8);
  }
  
  .ir-premium-footer__badge svg {
    color: #22c55e;
  }
  
  /* Bottom Bar */
  .ir-premium-footer__bottom {
    padding: 24px 0;
  }
  
  .ir-premium-footer__bottom-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }
  
  .ir-premium-footer__copyright {
    font-size: 0.875rem;
    color: #737373;
    margin: 0;
  }
  
  .ir-premium-footer.color-scheme-3 .ir-premium-footer__copyright {
    color: rgba(255, 255, 255, 0.6);
  }
  
  .ir-premium-footer__legal ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 24px;
  }
  
  .ir-premium-footer__legal a {
    font-size: 0.875rem;
    color: #737373;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  
  .ir-premium-footer__legal a:hover {
    color: #0f172a;
  }
  
  .ir-premium-footer.color-scheme-3 .ir-premium-footer__legal a {
    color: rgba(255, 255, 255, 0.6);
  }
  
  .ir-premium-footer.color-scheme-3 .ir-premium-footer__legal a:hover {
    color: white;
  }
  
  /* Responsive */
  @media screen and (max-width: 1100px) {
    .ir-premium-footer__container {
      grid-template-columns: 1fr 1.5fr;
      gap: 48px;
    }
    
    .ir-premium-footer__newsletter {
      grid-column: 1 / -1;
      max-width: 480px;
    }
  }
  
  @media screen and (max-width: 749px) {
    .ir-premium-footer__main {
      padding: 48px 0 32px;
    }
    
    .ir-premium-footer__container {
      grid-template-columns: 1fr;
      padding: 0 24px;
      gap: 40px;
    }
    
    .ir-premium-footer__nav {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    
    .ir-premium-footer__trust-container,
    .ir-premium-footer__bottom-container {
      padding: 0 24px;
      flex-direction: column;
      text-align: center;
    }
    
    .ir-premium-footer__trust-badges {
      flex-wrap: wrap;
      justify-content: center;
    }
    
    .ir-premium-footer__legal ul {
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>

