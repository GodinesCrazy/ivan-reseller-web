{%- comment -%}
  IVAN RESELLER - Premium Editorial Hero
  Advanced layout with product density and lifestyle framing.
{%- endcomment -%}

{%- liquid
  assign hero_product = section.settings.featured_product
  if hero_product == blank
    assign hero_product = collections['all'].products[0]
  endif
-%}

<section class="ir-hero-premium" data-color-scheme="{{ section.settings.color_scheme }}">
  <div class="ir-hero-premium__container">
    <div class="ir-hero-premium__grid">
      <!-- Content Side -->
      <div class="ir-hero-premium__content">
        <div class="ir-hero-premium__badge">
          <span class="ir-hero-premium__dot"></span>
          {{ section.settings.eyebrow }}
        </div>
        
        <h1 class="ir-hero-premium__title">
          {{ section.settings.title }}
        </h1>
        
        <p class="ir-hero-premium__description">
          {{ section.settings.description }}
        </p>
        
        <div class="ir-hero-premium__actions">
          <a href="{{ section.settings.button_link }}" class="ir-hero-premium__btn ir-hero-premium__btn--primary">
            {{ section.settings.button_text }}
          </a>
          {% if section.settings.secondary_button_text != blank %}
            <a href="{{ section.settings.secondary_button_link }}" class="ir-hero-premium__btn ir-hero-premium__btn--secondary">
              {{ section.settings.secondary_button_text }}
            </a>
          {% endif %}
        </div>

        <!-- Trust Mini List -->
        <div class="ir-hero-premium__trust-mini">
          <div class="ir-hero-premium__trust-item">
            <svg viewBox="0 0 24 24" fill="none" class="ir-hero-premium__trust-icon"><path d="M20 6L9 17L4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Verified Utility</span>
          </div>
          <div class="ir-hero-premium__trust-item">
            <svg viewBox="0 0 24 24" fill="none" class="ir-hero-premium__trust-icon"><path d="M20 6L9 17L4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Premium Curation</span>
          </div>
          <div class="ir-hero-premium__trust-item">
            <svg viewBox="0 0 24 24" fill="none" class="ir-hero-premium__trust-icon"><path d="M20 6L9 17L4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Clear Logistics</span>
          </div>
        </div>
      </div>

      <!-- Visual Side -->
      <div class="ir-hero-premium__visual">
        <div class="ir-hero-premium__image-wrap">
          {% if section.settings.image != blank %}
            {{ section.settings.image | image_url: width: 1400 | image_tag: class: 'ir-hero-premium__image', loading: 'eager' }}
          {% else %}
            <div class="ir-hero-premium__image-placeholder">
              <span>{{ hero_product.title | default: 'Premium Accessories' }}</span>
            </div>
          {% endif %}
          
          <!-- Floating Product Card -->
          {% if hero_product != blank %}
            <a href="{{ hero_product.url }}" class="ir-hero-premium__card">
              <div class="ir-hero-premium__card-image">
                {{ hero_product.featured_image | image_url: width: 200 | image_tag: loading: 'lazy' }}
              </div>
              <div class="ir-hero-premium__card-info">
                <span class="ir-hero-premium__card-kicker">Featured</span>
                <p class="ir-hero-premium__card-title">{{ hero_product.title }}</p>
                <p class="ir-hero-premium__card-price">{{ hero_product.price | money }}</p>
              </div>
              <div class="ir-hero-premium__card-arrow">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .ir-hero-premium {
    position: relative;
    padding: var(--ir-spacing-xl) 0 var(--ir-spacing-3xl);
    background: linear-gradient(180deg, #F8FAFC 0%, #FFFFFF 100%);
    overflow: hidden;
  }
  
  .ir-hero-premium__container {
    width: var(--ir-content-width);
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }
  
  .ir-hero-premium__grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: var(--ir-spacing-xl);
    align-items: center;
  }
  
  .ir-hero-premium__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: var(--ir-white);
    border: 1px solid var(--ir-gray-200);
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--ir-gray-600);
    text-transform: uppercase;
    margin-bottom: var(--ir-spacing-md);
    box-shadow: var(--ir-shadow-xs);
  }
  
  .ir-hero-premium__dot {
    width: 6px;
    height: 6px;
    background: var(--ir-accent);
    border-radius: 50%;
  }
  
  .ir-hero-premium__title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: 0;
    color: var(--ir-navy);
    margin: 0 0 var(--ir-spacing-sm);
  }
  
  .ir-hero-premium__description {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--ir-gray-600);
    max-width: 480px;
    margin-bottom: var(--ir-spacing-lg);
  }
  
  .ir-hero-premium__actions {
    display: flex;
    gap: 16px;
    margin-bottom: var(--ir-spacing-xl);
  }
  
  .ir-hero-premium__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    border-radius: 100px;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .ir-hero-premium__btn--primary {
    background: var(--ir-navy);
    color: var(--ir-white);
    box-shadow: 0 4px 14px 0 rgba(15, 23, 42, 0.2);
  }
  
  .ir-hero-premium__btn--primary:hover {
    background: #1e293b;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(15, 23, 42, 0.25);
  }
  
  .ir-hero-premium__btn--secondary {
    border: 1px solid var(--ir-gray-300);
    color: var(--ir-gray-700);
    background: var(--ir-white);
  }
  
  .ir-hero-premium__btn--secondary:hover {
    border-color: var(--ir-gray-400);
    background: var(--ir-gray-50);
  }
  
  .ir-hero-premium__trust-mini {
    display: flex;
    gap: 24px;
    padding-top: var(--ir-spacing-lg);
    border-top: 1px solid var(--ir-gray-100);
  }
  
  .ir-hero-premium__trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--ir-gray-500);
    font-size: 0.8125rem;
    font-weight: 500;
  }
  
  .ir-hero-premium__trust-icon {
    width: 16px;
    height: 16px;
    color: var(--ir-accent);
  }
  
  .ir-hero-premium__visual {
    position: relative;
  }
  
  .ir-hero-premium__image-wrap {
    position: relative;
    border-radius: 24px;
    overflow: visible; /* to allow floating card pop out */
  }
  
  .ir-hero-premium__image {
    width: 100%;
    height: auto;
    border-radius: 24px;
    box-shadow: var(--ir-shadow-xl);
    display: block;
  }
  
  .ir-hero-premium__image-placeholder {
    aspect-ratio: 4/3;
    background: #E2E8F0;
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 700;
    color: #94A3B8;
  }
  
  .ir-hero-premium__card {
    position: absolute;
    bottom: -40px;
    right: -20px;
    width: 280px;
    background: var(--ir-white);
    padding: 12px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    text-decoration: none;
    transition: transform 0.3s ease;
    z-index: 10;
  }
  
  .ir-hero-premium__card:hover {
    transform: translate(-5px, -5px);
  }
  
  .ir-hero-premium__card-image {
    width: 64px;
    height: 64px;
    border-radius: 8px;
    overflow: hidden;
    background: var(--ir-gray-100);
    flex-shrink: 0;
  }
  
  .ir-hero-premium__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .ir-hero-premium__card-info {
    flex-grow: 1;
    overflow: hidden;
  }
  
  .ir-hero-premium__card-kicker {
    display: block;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--ir-accent);
    letter-spacing: 0.05em;
    margin-bottom: 2px;
  }
  
  .ir-hero-premium__card-title {
    margin: 0;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--ir-navy);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  .ir-hero-premium__card-price {
    margin: 2px 0 0;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ir-gray-500);
  }
  
  .ir-hero-premium__card-arrow {
    width: 24px;
    height: 24px;
    color: var(--ir-gray-300);
  }
  
  @media screen and (max-width: 991px) {
    .ir-hero-premium__grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .ir-hero-premium__container {
      max-width: 600px;
    }
    .ir-hero-premium__description {
      margin-left: auto;
      margin-right: auto;
    }
    .ir-hero-premium__actions {
      justify-content: center;
    }
    .ir-hero-premium__trust-mini {
      justify-content: center;
    }
    .ir-hero-premium__card {
      right: 0;
      left: 0;
      margin: 0 auto;
      bottom: -30px;
    }
  }
</style>

{% schema %}
{
  "name": "IR - Premium Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Curated Daily Essentials"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Practical upgrades for your everyday life."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Expertly selected gadgets, workspace accessories, and travel tools designed to solve real problems with premium quality."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Useful Finds"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary Button Text",
      "default": "View Catalog"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Hero Image"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured Sidebar Product"
    }
  ],
  "presets": [
    {
      "name": "IR - Premium Hero",
      "category": "Ivan Reseller"
    }
  ]
}
{% endschema %}
