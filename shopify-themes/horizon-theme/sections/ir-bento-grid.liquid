{%- comment -%}
  IVAN RESELLER - Bento Category Grid
  Modern, weighted grid for showcasing collections or product categories.
{%- endcomment -%}

<section class="ir-bento-section">
  <div class="ir-bento-container">
    <div class="ir-bento-header">
      <h2 class="ir-bento-title">{{ section.settings.title }}</h2>
      <p class="ir-bento-subtitle">{{ section.settings.subtitle }}</p>
    </div>

    <div class="ir-bento-grid">
      {% for block in section.blocks %}
        {%- liquid
          assign visual_products = collections[section.settings.fallback_collection].products | default: collections['all'].products
          assign visual_product = visual_products[forloop.index0] | default: visual_products.first
        -%}
        <div class="ir-bento-item ir-bento-item--{{ block.settings.size }}" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.link }}" class="ir-bento-link">
            {% if block.settings.image != blank %}
              <div class="ir-bento-image-wrap">
                {{ block.settings.image | image_url: width: 1200 | image_tag: class: 'ir-bento-image', loading: 'lazy' }}
              </div>
            {% elsif visual_product != blank and visual_product.featured_image != blank %}
              <div class="ir-bento-product-visual ir-bento-product-visual--{{ block.settings.visual_style }}">
                <div class="ir-bento-product-visual__halo"></div>
                <div class="ir-bento-product-visual__image-card">
                  {{
                    visual_product.featured_image
                    | image_url: width: 900
                    | image_tag:
                      class: 'ir-bento-product-visual__image',
                      loading: 'lazy',
                      widths: '360, 540, 720, 900',
                      sizes: '(min-width: 990px) 34vw, 90vw',
                      alt: visual_product.title
                  }}
                </div>
                <div class="ir-bento-product-visual__spec ir-bento-product-visual__spec--top">
                  <span>{{ block.settings.visual_badge_1 }}</span>
                </div>
                <div class="ir-bento-product-visual__spec ir-bento-product-visual__spec--bottom">
                  <span>{{ visual_product.price | money }}</span>
                </div>
              </div>
            {% else %}
              <div class="ir-bento-product-visual ir-bento-product-visual--{{ block.settings.visual_style }}">
                <div class="ir-bento-product-visual__halo"></div>
                
                {%- liquid
                  assign category_asset = 'cat-' | append: block.settings.visual_style | append: '.png'
                  assign has_asset = false
                  if block.settings.visual_style == 'power' or block.settings.visual_style == 'phones' or block.settings.visual_style == 'workspace' or block.settings.visual_style == 'travel' or block.settings.visual_style == 'pets'
                    assign has_asset = true
                  endif
                -%}

                {% if has_asset %}
                  <div class="ir-bento-product-visual__image-card" style="background: transparent; box-shadow: none; transform: none; top: 50%; right: 5%; transform: translateY(-50%); width: 45%;">
                    <img src="{{ category_asset | asset_url }}" class="ir-bento-product-visual__image" style="width: 100%; height: 100%; object-fit: contain; filter: drop-shadow(0 10px 20px rgba(0,0,0,0.15));" loading="lazy" alt="{{ block.settings.title }}">
                  </div>
                {% else %}
                  <div class="ir-bento-product-visual__device">
                    <span></span>
                    <span></span>
                    <span></span>
                  </div>
                {% endif %}

                <div class="ir-bento-product-visual__spec ir-bento-product-visual__spec--top">
                  <span>{{ block.settings.visual_badge_1 }}</span>
                </div>
                <div class="ir-bento-product-visual__spec ir-bento-product-visual__spec--bottom">
                  <span>{{ block.settings.visual_badge_2 }}</span>
                </div>
              </div>
            {% endif %}
            
            <div class="ir-bento-content">
              <span class="ir-bento-label">{{ block.settings.label }}</span>
              <h3 class="ir-bento-heading">{{ block.settings.title }}</h3>
              <p class="ir-bento-text">{{ block.settings.description }}</p>
              <span class="ir-bento-button">Explore &rarr;</span>
            </div>
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .ir-bento-section {
    padding: clamp(5rem, 8vw, 8rem) 0;
    background: #f7f7f3;
  }
  
  .ir-bento-container {
    width: var(--ir-content-width);
    margin: 0 auto;
  }
  
  .ir-bento-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }
  
  .ir-bento-title {
    max-width: 12ch;
    font-size: clamp(2.2rem, 4vw, 4.4rem);
    line-height: 0.98;
    font-weight: 760;
    color: #111111;
    margin: 0;
    letter-spacing: 0;
    text-wrap: balance;
  }
  
  .ir-bento-subtitle {
    max-width: 30rem;
    color: #55524d;
    font-size: 1.04rem;
    line-height: 1.65;
    margin: 0;
  }
  
  .ir-bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 250px;
    gap: 18px;
  }
  
  .ir-bento-item {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    background: #111111;
    border: 1px solid rgba(17, 17, 17, 0.08);
    box-shadow: 0 18px 54px rgba(17, 17, 17, 0.08);
    transition: transform 0.32s ease, box-shadow 0.32s ease;
  }
  
  .ir-bento-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 30px 90px rgba(17,17,17,0.16);
  }
  
  .ir-bento-item--large {
    grid-column: span 2;
    grid-row: span 2;
  }
  
  .ir-bento-item--wide {
    grid-column: span 2;
  }
  
  .ir-bento-item--tall {
    grid-row: span 2;
  }
  
  .ir-bento-link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    position: relative;
  }
  
  .ir-bento-image-wrap {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  
  .ir-bento-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  
  .ir-bento-item:hover .ir-bento-image {
    transform: scale(1.05);
  }
  
  .ir-bento-content {
    position: absolute;
    inset: 0;
    z-index: 2;
    padding: clamp(1.3rem, 2.2vw, 2rem);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: linear-gradient(180deg, rgba(5, 6, 8, 0) 34%, rgba(5, 6, 8, 0.74) 100%);
  }
  
  .ir-bento-label {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.11em;
    color: rgba(255,255,255,0.72);
    margin-bottom: 0.35rem;
  }
  
  .ir-bento-heading {
    max-width: 15ch;
    font-size: clamp(1.35rem, 2vw, 1.8rem);
    line-height: 1.05;
    font-weight: 760;
    color: var(--ir-white);
    margin: 0 0 0.65rem;
    letter-spacing: 0;
    text-wrap: balance;
  }
  
  .ir-bento-text {
    font-size: 0.94rem;
    color: rgba(255,255,255,0.74);
    margin: 0 0 1rem;
    max-width: 280px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .ir-bento-button {
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--ir-white);
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.3s ease 0.1s;
  }
  
  .ir-bento-item:hover .ir-bento-button {
    opacity: 1;
    transform: translateX(0);
  }
  
  .ir-bento-product-visual {
    position: absolute;
    inset: 0;
    overflow: hidden;
    isolation: isolate;
    background:
      radial-gradient(circle at 72% 22%, rgba(255, 255, 255, 0.22), transparent 30%),
      linear-gradient(145deg, #16181d 0%, #2d2a23 54%, #8a6538 130%);
  }

  .ir-bento-product-visual--travel {
    background:
      radial-gradient(circle at 76% 24%, rgba(255,255,255,0.2), transparent 30%),
      linear-gradient(145deg, #111827 0%, #2f3b3b 58%, #9a6b3c 130%);
  }

  .ir-bento-product-visual--tech {
    background:
      radial-gradient(circle at 70% 16%, rgba(255,255,255,0.2), transparent 28%),
      linear-gradient(145deg, #070b14 0%, #1f2937 52%, #2f6f5e 130%);
  }

  .ir-bento-product-visual--daily {
    background:
      radial-gradient(circle at 70% 20%, rgba(255,255,255,0.18), transparent 28%),
      linear-gradient(145deg, #171717 0%, #3f3f35 58%, #b88746 125%);
  }

  .ir-bento-product-visual::before {
    content: '';
    position: absolute;
    inset: 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 10px;
    z-index: 1;
  }

  .ir-bento-product-visual::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(110deg, rgba(255,255,255,0.08), transparent 36%),
      radial-gradient(circle at 12% 86%, rgba(255,255,255,0.1), transparent 24%);
    z-index: 1;
  }

  .ir-bento-product-visual__halo {
    position: absolute;
    width: 19rem;
    aspect-ratio: 1;
    right: -4rem;
    top: -4rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.16);
    filter: blur(1px);
    z-index: 0;
  }

  .ir-bento-product-visual__image-card {
    position: absolute;
    right: clamp(1.1rem, 3vw, 2.5rem);
    top: clamp(1rem, 3vw, 2rem);
    width: min(52%, 19rem);
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.24);
    transform: rotate(3deg);
    z-index: 2;
  }

  .ir-bento-item--large .ir-bento-product-visual__image-card {
    width: min(48%, 21rem);
    right: 2.5rem;
    top: 2.25rem;
  }

  .ir-bento-product-visual__image {
    width: 86%;
    height: 86%;
    object-fit: contain;
    filter: drop-shadow(0 14px 24px rgba(0,0,0,0.18));
  }

  .ir-bento-product-visual__spec {
    position: absolute;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.13);
    color: rgba(255, 255, 255, 0.86);
    font-size: 0.72rem;
    font-weight: 760;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    backdrop-filter: blur(14px);
  }

  .ir-bento-product-visual__spec--top {
    left: 1.5rem;
    top: 1.5rem;
  }

  .ir-bento-product-visual__spec--bottom {
    right: 1.5rem;
    bottom: 1.5rem;
  }

  .ir-bento-product-visual__device {
    position: absolute;
    right: 2rem;
    top: 2rem;
    width: min(42%, 13rem);
    aspect-ratio: 0.72;
    border-radius: 22px;
    background: linear-gradient(180deg, rgba(255,255,255,0.88), rgba(235,235,230,0.92));
    box-shadow: 0 26px 70px rgba(0,0,0,0.26);
    transform: rotate(5deg);
    z-index: 2;
  }

  .ir-bento-product-visual__device span {
    position: absolute;
    left: 18%;
    right: 18%;
    height: 7px;
    border-radius: 999px;
    background: rgba(17, 17, 17, 0.16);
  }

  .ir-bento-product-visual__device span:nth-child(1) { top: 24%; }
  .ir-bento-product-visual__device span:nth-child(2) { top: 42%; }
  .ir-bento-product-visual__device span:nth-child(3) { top: 60%; }
  }
  
  @media screen and (max-width: 1100px) {
    .ir-bento-header {
      align-items: flex-start;
      flex-direction: column;
    }

    .ir-bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media screen and (max-width: 749px) {
    .ir-bento-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: minmax(300px, auto);
    }
    .ir-bento-item--large, 
    .ir-bento-item--wide,
    .ir-bento-item--tall {
      grid-column: span 1;
      grid-row: span 1;
    }
    .ir-bento-content {
      padding: 24px;
    }

    .ir-bento-product-visual__image-card {
      width: min(48%, 16rem);
    }
  }
</style>

{% schema %}
{
  "name": "IR - Bento Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Carefully selected upgrades for every part of your day."
    },
    {
      "type": "collection",
      "id": "fallback_collection",
      "label": "Products to use when category images are empty"
    }
  ],
  "blocks": [
    {
      "type": "category_item",
      "name": "Category Item",
      "settings": [
        {
          "type": "select",
          "id": "size",
          "label": "Grid Size",
          "options": [
            { "value": "small", "label": "Small" },
            { "value": "wide", "label": "Wide" },
            { "value": "tall", "label": "Tall" },
            { "value": "large", "label": "Large" }
          ],
          "default": "small"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Small Label",
          "default": "Essentials"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Workspace"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Clean and functional tools for your desk."
        },
        {
          "type": "select",
          "id": "visual_style",
          "label": "Fallback visual style",
          "options": [
            { "value": "power", "label": "Power" },
            { "value": "phones", "label": "Phones" },
            { "value": "workspace", "label": "Workspace" },
            { "value": "travel", "label": "Travel" },
            { "value": "tech", "label": "Tech" },
            { "value": "daily", "label": "Daily" },
            { "value": "pets", "label": "Pets" }
          ],
          "default": "workspace"
        },
        {
          "type": "text",
          "id": "visual_badge_1",
          "label": "Visual badge 1",
          "default": "Curated"
        },
        {
          "type": "text",
          "id": "visual_badge_2",
          "label": "Visual badge 2",
          "default": "Ready"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "IR - Bento Grid",
      "category": "Ivan Reseller",
      "blocks": [
        { "type": "category_item", "settings": { "size": "large" } },
        { "type": "category_item", "settings": { "size": "small" } },
        { "type": "category_item", "settings": { "size": "small" } },
        { "type": "category_item", "settings": { "size": "wide" } }
      ]
    }
  ]
}
{% endschema %}
