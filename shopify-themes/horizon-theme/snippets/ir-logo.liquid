{%- comment -%}
  IvanReseller premium retail wordmark.
  Clean monogram + strong wordmark for electronics-commerce use.
{%- endcomment -%}

<a href="{{ routes.root_url }}" class="ir-logo-link" aria-label="{{ shop.name }} - Home">
  <svg class="ir-logo-svg ir-logo-full" viewBox="0 0 292 56" fill="none" xmlns="http://www.w3.org/2000/svg" role="img">
    <title>IvanReseller</title>
    <defs>
      <linearGradient id="irMarkGradient-{{ section.id | default: 'main' }}" x1="4" y1="6" x2="48" y2="50" gradientUnits="userSpaceOnUse">
        <stop stop-color="#0F766E"/>
        <stop offset="1" stop-color="#1E3A8A"/>
      </linearGradient>
    </defs>
    <rect x="3" y="6" width="44" height="44" rx="11" fill="url(#irMarkGradient-{{ section.id | default: 'main' }})"/>
    <path d="M17 17V39" stroke="white" stroke-width="4" stroke-linecap="round"/>
    <path d="M29 17H36C40 17 42 19.2 42 22.6C42 26 39.7 28.2 36.1 28.2H29V17Z" stroke="white" stroke-width="3.3" stroke-linejoin="round"/>
    <path d="M29 28L41 39" stroke="white" stroke-width="3.3" stroke-linecap="round"/>
    <path d="M11 44H40" stroke="rgba(255,255,255,0.34)" stroke-width="2" stroke-linecap="round"/>
    <text x="62" y="35" font-family="Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif" font-size="27" font-weight="840" fill="#111827" letter-spacing="0">Ivan</text>
    <text x="125" y="35" font-family="Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif" font-size="27" font-weight="560" fill="#374151" letter-spacing="0">Reseller</text>
  </svg>

  <svg class="ir-logo-svg ir-logo-compact" viewBox="0 0 204 44" fill="none" xmlns="http://www.w3.org/2000/svg" role="img">
    <title>IvanReseller</title>
    <defs>
      <linearGradient id="irCompactGradient-{{ section.id | default: 'main' }}" x1="3" y1="4" x2="39" y2="40" gradientUnits="userSpaceOnUse">
        <stop stop-color="#0F766E"/>
        <stop offset="1" stop-color="#1E3A8A"/>
      </linearGradient>
    </defs>
    <rect x="2" y="4" width="36" height="36" rx="9" fill="url(#irCompactGradient-{{ section.id | default: 'main' }})"/>
    <path d="M14 13V31" stroke="white" stroke-width="3.4" stroke-linecap="round"/>
    <path d="M24 13H30C33 13 34.8 14.7 34.8 17.3C34.8 20 33 21.7 30.1 21.7H24V13Z" stroke="white" stroke-width="2.8" stroke-linejoin="round"/>
    <path d="M24 22L34 31" stroke="white" stroke-width="2.8" stroke-linecap="round"/>
    <text x="49" y="29" font-family="Inter, -apple-system, BlinkMacSystemFont, sans-serif" font-size="21" font-weight="820" fill="#111827" letter-spacing="0">Ivan</text>
    <text x="98" y="29" font-family="Inter, -apple-system, BlinkMacSystemFont, sans-serif" font-size="21" font-weight="540" fill="#374151" letter-spacing="0">Reseller</text>
  </svg>

  <svg class="ir-logo-svg ir-logo-icon-only" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" role="img">
    <title>IvanReseller</title>
    <rect x="2" y="2" width="36" height="36" rx="9" fill="#111827"/>
    <path d="M14 11V29" stroke="white" stroke-width="3.3" stroke-linecap="round"/>
    <path d="M23 11H29C32 11 34 12.8 34 15.5C34 18.2 32 20 29.1 20H23V11Z" stroke="white" stroke-width="2.7" stroke-linejoin="round"/>
    <path d="M23 20L33 29" stroke="white" stroke-width="2.7" stroke-linecap="round"/>
  </svg>
</a>

<style>
  .ir-logo-link {
    display: inline-flex;
    align-items: center;
    min-width: 0;
    text-decoration: none;
    transition: opacity 0.18s ease, transform 0.18s ease;
  }

  .ir-logo-link:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .ir-logo-svg {
    width: auto;
    height: 40px;
    display: block;
  }

  .ir-logo-full {
    height: 48px;
  }

  .ir-logo-compact,
  .ir-logo-icon-only {
    display: none;
  }

  @media screen and (max-width: 989px) {
    .ir-logo-full {
      display: none;
    }

    .ir-logo-compact {
      display: block;
      height: 38px;
    }
  }

  @media screen and (max-width: 380px) {
    .ir-logo-compact {
      display: none;
    }

    .ir-logo-icon-only {
      display: block;
      height: 36px;
    }
  }
</style>
