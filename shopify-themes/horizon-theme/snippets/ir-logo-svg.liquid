{%- comment -%}
  IVAN RESELLER - Brand Logo SVG
  Premium wordmark with optional icon
{%- endcomment -%}

{% assign logo_style = logo_style | default: 'full' %}
{% assign logo_color = logo_color | default: '#0f172a' %}
{% assign logo_height = logo_height | default: 32 %}

{% if logo_style == 'full' %}
  <svg class="ir-logo" width="{{ logo_height | times: 5.5 | round }}" height="{{ logo_height }}" viewBox="0 0 220 40" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- Icon: Shopping Cart + AI Circuit -->
    <g transform="translate(0, 4)">
      <!-- Cart body -->
      <path d="M2 2h4l3 18h14l3-12H8" stroke="{{ logo_color }}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      <!-- Cart wheel -->
      <circle cx="10" cy="26" r="3" stroke="{{ logo_color }}" stroke-width="2.5" fill="none"/>
      <circle cx="22" cy="26" r="3" stroke="{{ logo_color }}" stroke-width="2.5" fill="none"/>
      <!-- AI Circuit element -->
      <circle cx="28" cy="8" r="4" fill="{{ logo_color }}"/>
      <path d="M28 4V2M28 14V16M22 8h-4M36 8h4M24 4l-2-2M32 12l2 2M24 12l-2 2M32 4l2-2" stroke="{{ logo_color }}" stroke-width="1.5" stroke-linecap="round"/>
    </g>
    <!-- Wordmark: Ivan Reseller -->
    <g transform="translate(46, 8)">
      <!-- Ivan -->
      <text x="0" y="20" font-family="Inter, -apple-system, BlinkMacSystemFont, sans-serif" font-size="18" font-weight="700" fill="{{ logo_color }}" letter-spacing="-0.03em">Ivan</text>
      <!-- Reseller -->
      <text x="44" y="20" font-family="Inter, -apple-system, BlinkMacSystemFont, sans-serif" font-size="18" font-weight="500" fill="{{ logo_color }}" letter-spacing="-0.03em">Reseller</text>
    </g>
  </svg>
{% elsif logo_style == 'icon' %}
  <svg class="ir-logo ir-logo--icon" width="{{ logo_height }}" height="{{ logo_height }}" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- Background circle -->
    <rect x="2" y="2" width="36" height="36" rx="10" fill="{{ logo_color }}"/>
    <!-- Cart icon -->
    <path d="M10 12h3l2.5 15h13l2.5-10H14" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    <circle cx="16" cy="31" r="2" fill="white"/>
    <circle cx="26" cy="31" r="2" fill="white"/>
    <!-- AI sparkle -->
    <path d="M28 8l1-2 1 2 2 1-2 1-1 2-1-2-2-1 2-1z" fill="#22c55e"/>
  </svg>
{% elsif logo_style == 'wordmark' %}
  <svg class="ir-logo" width="{{ logo_height | times: 5 }}" height="{{ logo_height }}" viewBox="0 0 180 36" fill="none" xmlns="http://www.w3.org/2000/svg">
    <text x="0" y="26" font-family="Inter, -apple-system, BlinkMacSystemFont, sans-serif" font-size="22" font-weight="700" fill="{{ logo_color }}" letter-spacing="-0.03em">Ivan</text>
    <text x="54" y="26" font-family="Inter, -apple-system, BlinkMacSystemFont, sans-serif" font-size="22" font-weight="500" fill="{{ logo_color }}" letter-spacing="-0.03em">Reseller</text>
  </svg>
{% endif %}

<style>
  .ir-logo {
    display: block;
    height: auto;
  }
  
  .header__heading-logo .ir-logo,
  .header__heading-link .ir-logo {
    height: 100%;
    width: auto;
  }
</style>
