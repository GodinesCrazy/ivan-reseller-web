{%- comment -%} PawVault category gallery — editorial asymmetric 3-col bento grid. {%- endcomment -%}

<section class="pv-cats">
  <div class="pv-cats__container">

    <div class="pv-cats__header">
      <p class="pv-cats__eyebrow">{{ section.settings.eyebrow | default: 'Shop by routine' }}</p>
      <h2 class="pv-cats__title">{{ section.settings.title | default: 'Everything your pet needs, organized your way.' }}</h2>
      <p class="pv-cats__text">{{ section.settings.text | default: 'Start by pet type or by the routines that matter most.' }}</p>
    </div>

    <div class="pv-cats__grid">
      {% for block in section.blocks %}
        {%- liquid
          case forloop.index
            when 1
              assign fallback_image = 'pv-cat-dogs.jpg' | asset_url
            when 2
              assign fallback_image = 'pv-cat-cats.jpg' | asset_url
            when 3
              assign fallback_image = 'pv-cat-grooming.jpg' | asset_url
            else
              assign fallback_image = 'pv-cat-comfort.jpg' | asset_url
          endcase
        -%}
        <a
          href="{{ block.settings.link | default: routes.all_products_collection_url }}"
          class="pv-cat-card"
          {{ block.shopify_attributes }}
        >
          <div class="pv-cat-card__media">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 1200
                | image_tag:
                  class: 'pv-cat-card__image',
                  loading: 'lazy',
                  alt: block.settings.image.alt | default: block.settings.name
              }}
            {% else %}
              <img
                src="{{ fallback_image }}"
                alt="{{ block.settings.name | default: 'Pet category' }}"
                class="pv-cat-card__image"
                loading="lazy"
                width="720"
                height="900"
              >
            {% endif %}
          </div>
          <div class="pv-cat-card__overlay"></div>
          <div class="pv-cat-card__content">
            <div class="pv-cat-card__body">
              <h3 class="pv-cat-card__name">{{ block.settings.name | default: 'Category' }}</h3>
              <p class="pv-cat-card__desc">{{ block.settings.desc }}</p>
            </div>
            <span class="pv-cat-card__cta">
              {{ block.settings.cta | default: 'Explore' }}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>
      {% endfor %}
    </div>

  </div>
</section>

<style>
  .pv-cats {
    padding: clamp(5rem, 9vw, 8rem) 0;
    background: #f7f4ee;
  }

  .pv-cats__container {
    width: min(1280px, calc(100% - 40px));
    margin: 0 auto;
  }

  .pv-cats__header {
    max-width: 44rem;
    margin-bottom: 2.75rem;
  }

  .pv-cats__eyebrow {
    margin: 0 0 0.85rem;
    color: #b47b2d;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .pv-cats__title {
    margin: 0;
    color: #0f1f35;
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .pv-cats__text {
    margin: 1rem 0 0;
    max-width: 38rem;
    color: #5d6c7c;
    font-size: 1rem;
    line-height: 1.7;
  }

  /* ── EDITORIAL ASYMMETRIC GRID ─────────────────── */
  .pv-cats__grid {
    display: grid;
    grid-template-columns: 1.35fr 0.85fr 1.15fr;
    grid-template-rows: 1fr 1fr;
    min-height: 640px;
    gap: 1rem;
  }

  /* Card 1 (Dogs) — tall left */
  .pv-cat-card:nth-child(1) { grid-column: 1; grid-row: 1 / 3; }
  /* Card 2 (Cats) — top center */
  .pv-cat-card:nth-child(2) { grid-column: 2; grid-row: 1; }
  /* Card 3 (Grooming) — bottom center */
  .pv-cat-card:nth-child(3) { grid-column: 2; grid-row: 2; }
  /* Card 4 (Comfort) — tall right */
  .pv-cat-card:nth-child(4) { grid-column: 3; grid-row: 1 / 3; }

  /* ── CARD BASE ─────────────────────────────────── */
  .pv-cat-card {
    position: relative;
    overflow: hidden;
    display: flex;
    border-radius: 24px;
    text-decoration: none;
    color: #ffffff;
    box-shadow: 0 16px 36px rgba(16, 35, 59, 0.1);
    transition: box-shadow 250ms ease;
  }

  .pv-cat-card:hover {
    box-shadow: 0 26px 56px rgba(16, 35, 59, 0.18);
  }

  .pv-cat-card__media,
  .pv-cat-card__overlay {
    position: absolute;
    inset: 0;
  }

  .pv-cat-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 800ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .pv-cat-card:hover .pv-cat-card__image {
    transform: scale(1.07);
  }

  .pv-cat-card__overlay {
    background: linear-gradient(
      180deg,
      rgba(8, 18, 36, 0.02) 0%,
      rgba(8, 18, 36, 0.38) 50%,
      rgba(8, 18, 36, 0.82) 100%
    );
  }

  .pv-cat-card__content {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 1rem;
    padding: 1.75rem;
  }

  .pv-cat-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .pv-cat-card__name {
    margin: 0;
    font-size: clamp(1.35rem, 2vw, 2.1rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .pv-cat-card__desc {
    margin: 0;
    max-width: 22rem;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  /* Short center cards: hide description to keep compact */
  .pv-cat-card:nth-child(2) .pv-cat-card__desc,
  .pv-cat-card:nth-child(3) .pv-cat-card__desc {
    display: none;
  }

  .pv-cat-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    width: fit-content;
    padding: 0.6rem 1.1rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.13);
    border: 1px solid rgba(255, 255, 255, 0.28);
    color: #ffffff;
    font-size: 0.875rem;
    font-weight: 650;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: background 220ms ease, transform 220ms ease;
  }

  .pv-cat-card:hover .pv-cat-card__cta {
    background: rgba(255, 255, 255, 0.22);
    transform: translateX(3px);
  }

  /* ── RESPONSIVE ─────────────────────────────────── */
  @media (max-width: 899px) {
    .pv-cats__grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 22rem 22rem;
      min-height: 0;
    }
    .pv-cat-card:nth-child(1) { grid-column: 1; grid-row: 1; }
    .pv-cat-card:nth-child(2) { grid-column: 2; grid-row: 1; }
    .pv-cat-card:nth-child(3) { grid-column: 1; grid-row: 2; }
    .pv-cat-card:nth-child(4) { grid-column: 2; grid-row: 2; }
    .pv-cat-card:nth-child(2) .pv-cat-card__desc,
    .pv-cat-card:nth-child(3) .pv-cat-card__desc {
      display: block;
    }
  }

  @media (max-width: 599px) {
    .pv-cats__grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }
    .pv-cat-card:nth-child(n) {
      grid-column: 1;
      grid-row: auto;
      min-height: 22rem;
    }
  }
</style>

{% schema %}
{
  "name": "PV - Category Gallery",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by routine" },
    { "type": "text", "id": "title", "label": "Title", "default": "Everything your pet needs, organized your way." },
    { "type": "textarea", "id": "text", "label": "Intro text", "default": "Start by pet type or by the routines that matter most — grooming, feeding, play and everyday comfort." }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "name", "label": "Category name", "default": "Dogs" },
        { "type": "textarea", "id": "desc", "label": "Description", "default": "Leashes, play, comfort and daily essentials." },
        { "type": "text", "id": "cta", "label": "CTA label", "default": "Explore" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "PV - Category Gallery",
      "category": "PawVault",
      "blocks": [
        { "type": "category", "settings": { "name": "Dogs", "desc": "Harnesses, leashes, play toys and daily essentials for your pup.", "cta": "Shop dogs" } },
        { "type": "category", "settings": { "name": "Cats", "desc": "Beds, enrichment and calm home upgrades for your cat.", "cta": "Shop cats" } },
        { "type": "category", "settings": { "name": "Grooming", "desc": "Brushes, trimmers and bath-time essentials.", "cta": "Shop grooming" } },
        { "type": "category", "settings": { "name": "Comfort & Feeding", "desc": "Beds, bowls and home staples for daily pet life.", "cta": "Shop comfort" } }
      ]
    }
  ]
}
{% endschema %}
