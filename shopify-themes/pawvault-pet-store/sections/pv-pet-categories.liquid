{%- comment -%} PawVault — Prominent category navigation for storefront discovery. {%- endcomment -%}

<div class="pv-cstrip">
  <div class="pv-cstrip__head">
    <span>Shop by pet need</span>
  </div>
  <div class="pv-cstrip__scroll">
    {%- for block in section.blocks -%}
      {%- liquid
        case block.settings.icon
          when 'dog'
            assign icon_svg = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 5.172C10 3.782 8.423 2.679 6.5 3c-2.823.47-4.113 6.006-4 7 .08.703 1.725 1.722 3.656 1 1.261-.472 1.96-1.45 2.344-2.5"/><path d="M14.267 5.172c0-1.39 1.577-2.493 3.5-2.172 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 1-1.261-.472-1.96-1.45-2.344-2.5"/><path d="M8 14v.5A3.5 3.5 0 0 0 11.5 18v0h1a3.5 3.5 0 0 0 3.5-3.5V14"/><path d="M6.5 9.5C8 9 10 9.2 12 10c2-.8 4-1 5.5-.5"/></svg>'
          when 'cat'
            assign icon_svg = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5c.67 0 1.35.09 2 .26 1.78-2 5.03-2.84 6.42-2.26 1.4.58-.42 7-.42 7 .57 1.07 1 2.24 1 3.44C21 17.9 16.97 21 12 21s-9-3-9-7.56c0-1.25.5-2.4 1-3.44 0 0-1.89-6.42-.5-7 1.39-.58 4.72.23 6.5 2.23A9.04 9.04 0 0 1 12 5z"/><path d="M8 14v.5M16 14v.5"/></svg>'
          when 'scissors'
            assign icon_svg = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>'
          when 'bed'
            assign icon_svg = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/></svg>'
          when 'bowl'
            assign icon_svg = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M7 12h10"/></svg>'
          when 'star'
            assign icon_svg = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>'
          when 'toy'
            assign icon_svg = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v8M8 12h8"/></svg>'
          else
            assign icon_svg = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>'
        endcase
      -%}
      <a
        href="{{ block.settings.link | default: routes.all_products_collection_url }}"
        class="pv-cstrip__item"
        {{ block.shopify_attributes }}
      >
        <span class="pv-cstrip__icon">{{ icon_svg }}</span>
        <span class="pv-cstrip__label">{{ block.settings.label | default: 'Category' }}</span>
      </a>
    {%- endfor -%}
  </div>
</div>

<style>
  .pv-cstrip {
    background: linear-gradient(180deg, #ffffff 0%, #fbf8f0 100%);
    border-top: 1px solid var(--pv-border);
    border-bottom: 3px solid var(--pv-gold);
    overflow: hidden;
    padding: 1.1rem 0 1.35rem;
  }

  .pv-cstrip__head {
    width: min(1320px, calc(100% - 40px));
    margin: 0 auto 0.85rem;
    color: #b47b2d;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .pv-cstrip__scroll {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(132px, 1fr);
    align-items: center;
    gap: 0.8rem;
    width: min(1320px, calc(100% - 40px));
    margin: 0 auto;
    overflow-x: auto;
    padding: 0.1rem 0.1rem 0.25rem;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .pv-cstrip__scroll::-webkit-scrollbar { display: none; }

  .pv-cstrip__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    min-height: 104px;
    padding: 1rem 1.2rem;
    text-decoration: none;
    color: var(--pv-text);
    background: #ffffff;
    border: 1px solid rgba(16, 35, 59, 0.1);
    border-radius: 12px;
    box-shadow: 0 10px 26px rgba(16, 35, 59, 0.08);
    transition: transform 150ms ease, box-shadow 150ms ease, border-color 150ms ease, color 150ms ease;
  }

  .pv-cstrip__item:hover {
    transform: translateY(-2px);
    border-color: rgba(242, 169, 59, 0.55);
    box-shadow: 0 16px 34px rgba(16, 35, 59, 0.12);
    color: var(--pv-navy);
  }

  .pv-cstrip__item:hover .pv-cstrip__icon {
    color: var(--pv-gold);
  }

  .pv-cstrip__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    color: var(--pv-navy);
    background: rgba(242, 169, 59, 0.16);
    border-radius: 999px;
    transition: color 150ms ease, background 150ms ease;
  }

  .pv-cstrip__label {
    font-size: 0.88rem;
    font-weight: 900;
    letter-spacing: 0;
    white-space: nowrap;
  }

  @media (max-width: 749px) {
    .pv-cstrip { padding: 0.95rem 0 1.1rem; }
    .pv-cstrip__head { width: calc(100% - 28px); }
    .pv-cstrip__scroll {
      width: calc(100% - 28px);
      grid-auto-columns: minmax(104px, 35vw);
      gap: 0.65rem;
    }

    .pv-cstrip__item {
      min-height: 92px;
      padding: 0.85rem 0.75rem;
    }

    .pv-cstrip__icon {
      width: 38px;
      height: 38px;
    }

    .pv-cstrip__label { font-size: 0.78rem; }
  }
</style>

{% schema %}
{
  "name": "PV — Category Strip",
  "tag": "div",
  "blocks": [
    {
      "type": "cat",
      "name": "Category",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "dog",      "label": "Dog" },
            { "value": "cat",      "label": "Cat" },
            { "value": "scissors", "label": "Grooming" },
            { "value": "bed",      "label": "Beds" },
            { "value": "bowl",     "label": "Feeding" },
            { "value": "toy",      "label": "Toy" },
            { "value": "star",     "label": "Bestsellers" },
            { "value": "heart",    "label": "Heart" }
          ],
          "default": "dog"
        },
        { "type": "text", "id": "label", "label": "Label",   "default": "Dogs" },
        { "type": "url",  "id": "link",  "label": "URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "PV — Category Strip",
      "blocks": [
        { "type": "cat", "settings": { "icon": "dog",      "label": "Dogs" } },
        { "type": "cat", "settings": { "icon": "cat",      "label": "Cats" } },
        { "type": "cat", "settings": { "icon": "scissors", "label": "Grooming" } },
        { "type": "cat", "settings": { "icon": "bed",      "label": "Beds" } },
        { "type": "cat", "settings": { "icon": "bowl",     "label": "Feeding" } },
        { "type": "cat", "settings": { "icon": "toy",      "label": "Toys" } },
        { "type": "cat", "settings": { "icon": "star",     "label": "Bestsellers" } }
      ]
    }
  ]
}
{% endschema %}
