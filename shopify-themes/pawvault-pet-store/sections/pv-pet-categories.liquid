{%- comment -%} PawVault — Pet Categories Grid. Pure CSS. Zero product image dependency. {%- endcomment -%}

<section class="pv-cats">
  <div class="pv-cats__container">
    <div class="pv-cats__header">
      <p class="pv-cats__eyebrow">{{ section.settings.eyebrow | default: 'Shop by Category' }}</p>
      <h2 class="pv-cats__title">{{ section.settings.title | default: 'Built for pets who deserve better.' }}</h2>
    </div>

    <div class="pv-cats__grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link | default: '/collections/all' }}"
           class="pv-cat pv-cat--{{ block.settings.color }}"
           {{ block.shopify_attributes }}>
          <div class="pv-cat__icon-wrap">
            <span class="pv-cat__icon">{{ block.settings.icon | default: '🐾' }}</span>
          </div>
          <div class="pv-cat__body">
            <h3 class="pv-cat__name">{{ block.settings.name | default: 'Category' }}</h3>
            <p class="pv-cat__desc">{{ block.settings.desc }}</p>
          </div>
          <span class="pv-cat__arrow" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .pv-cats {
    padding: clamp(5rem, 8vw, 8rem) 0;
    background: #f8fafc;
  }

  .pv-cats__container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 80px);
  }

  .pv-cats__header {
    text-align: center;
    margin-bottom: 52px;
  }

  .pv-cats__eyebrow {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #f59e0b;
    margin: 0 0 14px;
  }

  .pv-cats__title {
    font-size: clamp(1.75rem, 4vw, 2.625rem);
    font-weight: 800;
    color: #0f172a;
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.1;
  }

  .pv-cats__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  @media (max-width: 899px) { .pv-cats__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 499px) { .pv-cats__grid { grid-template-columns: 1fr; } }

  .pv-cat {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 22px 20px;
    border-radius: 16px;
    text-decoration: none;
    transition: all 0.22s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1.5px solid transparent;
    position: relative;
    overflow: hidden;
  }

  .pv-cat:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.09);
  }

  .pv-cat--amber  { background: #fffbeb; border-color: #fde68a; }
  .pv-cat--amber:hover  { background: #fef3c7; border-color: #f59e0b; }

  .pv-cat--sage   { background: #f0fdf4; border-color: #bbf7d0; }
  .pv-cat--sage:hover   { background: #dcfce7; border-color: #4ade80; }

  .pv-cat--rose   { background: #fff1f2; border-color: #fecdd3; }
  .pv-cat--rose:hover   { background: #ffe4e6; border-color: #fb7185; }

  .pv-cat--sky    { background: #f0f9ff; border-color: #bae6fd; }
  .pv-cat--sky:hover    { background: #e0f2fe; border-color: #38bdf8; }

  .pv-cat--violet { background: #faf5ff; border-color: #e9d5ff; }
  .pv-cat--violet:hover { background: #f3e8ff; border-color: #c084fc; }

  .pv-cat--peach  { background: #fff7ed; border-color: #fed7aa; }
  .pv-cat--peach:hover  { background: #ffedd5; border-color: #fb923c; }

  .pv-cat__icon-wrap {
    width: 54px;
    height: 54px;
    border-radius: 14px;
    background: rgba(255,255,255,0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    backdrop-filter: blur(4px);
  }

  .pv-cat__icon { font-size: 1.75rem; line-height: 1; }

  .pv-cat__body { flex: 1; min-width: 0; }

  .pv-cat__name {
    font-size: 1rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 4px;
    letter-spacing: -0.01em;
  }

  .pv-cat__desc {
    font-size: 0.8125rem;
    color: #64748b;
    margin: 0;
    line-height: 1.4;
  }

  .pv-cat__arrow {
    color: #cbd5e1;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .pv-cat:hover .pv-cat__arrow {
    color: #0f172a;
    transform: translateX(3px);
  }
</style>

{% schema %}
{
  "name": "PV — Pet Categories",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by Category" },
    { "type": "text", "id": "title", "label": "Title", "default": "Built for pets who deserve better." }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🐕" },
        { "type": "text", "id": "name", "label": "Category Name", "default": "Dogs" },
        { "type": "text", "id": "desc", "label": "Short Description", "default": "Collars, leashes and accessories" },
        { "type": "url", "id": "link", "label": "Link" },
        {
          "type": "select",
          "id": "color",
          "label": "Card Color",
          "options": [
            { "value": "amber",  "label": "Amber (warm gold)" },
            { "value": "sage",   "label": "Sage (soft green)" },
            { "value": "rose",   "label": "Rose (soft pink)" },
            { "value": "sky",    "label": "Sky (light blue)" },
            { "value": "violet", "label": "Violet (soft purple)" },
            { "value": "peach",  "label": "Peach (warm orange)" }
          ],
          "default": "amber"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PV — Pet Categories",
      "category": "PawVault",
      "blocks": [
        { "type": "category", "settings": { "icon": "🐕", "name": "Dogs",         "desc": "Collars, leashes and accessories",     "color": "amber"  } },
        { "type": "category", "settings": { "icon": "🐈", "name": "Cats",         "desc": "Cat trees, beds and enrichment toys",  "color": "sage"   } },
        { "type": "category", "settings": { "icon": "✂️", "name": "Grooming",     "desc": "Brushes, shampoos and nail clippers",  "color": "rose"   } },
        { "type": "category", "settings": { "icon": "🥣", "name": "Feeding",      "desc": "Bowls, feeders and water fountains",   "color": "sky"    } },
        { "type": "category", "settings": { "icon": "🎾", "name": "Toys",         "desc": "Interactive and enrichment toys",      "color": "violet" } },
        { "type": "category", "settings": { "icon": "🛏️", "name": "Beds & Comfort","desc": "Cozy beds, mats and blankets",        "color": "peach"  } }
      ]
    }
  ]
}
{% endschema %}
