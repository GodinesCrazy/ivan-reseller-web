{%- comment -%} PawVault — Trust Bar. Compact horizontal strip with 4 trust signals. {%- endcomment -%}

<div class="pv-tbar">
  <div class="pv-tbar__inner">

    <div class="pv-tbar__item">
      <svg class="pv-tbar__icon" width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b" aria-hidden="true">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
      <span><strong>Curated</strong>&nbsp;pet essentials</span>
    </div>

    <span class="pv-tbar__sep" aria-hidden="true"></span>

    <div class="pv-tbar__item">
      <svg class="pv-tbar__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
      </svg>
      <span>Free shipping on orders over&nbsp;<strong>$50</strong></span>
    </div>

    <span class="pv-tbar__sep" aria-hidden="true"></span>

    <div class="pv-tbar__item">
      <svg class="pv-tbar__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.59"/>
      </svg>
      <span><strong>30-day</strong>&nbsp;easy returns</span>
    </div>

    <span class="pv-tbar__sep" aria-hidden="true"></span>

    <div class="pv-tbar__item">
      <svg class="pv-tbar__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      <span>Secure&nbsp;<strong>checkout</strong></span>
    </div>

  </div>
</div>

<style>
  .pv-tbar {
    background: #ffffff;
    border-top: 1px solid rgba(16, 35, 59, 0.07);
    border-bottom: 1px solid rgba(16, 35, 59, 0.07);
  }

  .pv-tbar__inner {
    width: min(1280px, calc(100% - 40px));
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    min-height: 62px;
    padding: 12px 0;
    gap: 0;
  }

  .pv-tbar__item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 28px;
    font-size: 0.875rem;
    color: #52606d;
    white-space: nowrap;
  }

  .pv-tbar__item strong {
    color: #0f1f35;
    font-weight: 700;
  }

  .pv-tbar__icon {
    flex-shrink: 0;
    color: #f59e0b;
  }

  .pv-tbar__sep {
    display: block;
    width: 1px;
    height: 18px;
    background: rgba(16, 35, 59, 0.12);
    flex-shrink: 0;
  }

  @media (max-width: 899px) {
    .pv-tbar__sep { display: none; }
    .pv-tbar__item { padding: 7px 18px; }
  }

  @media (max-width: 599px) {
    .pv-tbar__inner {
      justify-content: flex-start;
      overflow-x: auto;
      flex-wrap: nowrap;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-left: 16px;
      padding-right: 16px;
    }
    .pv-tbar__inner::-webkit-scrollbar { display: none; }
    .pv-tbar__item:not(:last-child) {
      border-right: 1px solid rgba(16, 35, 59, 0.1);
    }
  }
</style>

{% schema %}
{
  "name": "PV — Trust Bar",
  "tag": "div",
  "settings": [],
  "presets": [{ "name": "PV — Trust Bar", "category": "PawVault" }]
}
{% endschema %}
