{%- liquid
  assign src = collections[section.settings.collection]
  if src == blank or src.products_count == 0
    assign src = collections.all
  endif
  assign lim = section.settings.products_to_show | default: 8 | plus: 0
  assign shown = 0
-%}

<section class="pvgrid">
  <div class="pvgrid__head">
    <div class="pvgrid__head-inner">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="pvgrid__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="pvgrid__title">{{ section.settings.title | default: 'Featured Products' }}</h2>
      </div>
      <a href="{{ src.url | default: routes.all_products_collection_url }}" class="pvgrid__all">
        View all products
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  <div class="pvgrid__body">
    <div class="pvgrid__grid">
      {%- for p in src.products limit: 60 -%}
        {%- unless p.available -%}
          {%- continue -%}
        {%- endunless -%}
        {%- if shown >= lim -%}
          {%- break -%}
        {%- endif -%}
        {%- assign shown = shown | plus: 1 -%}
        {%- liquid
          assign img        = p.featured_image
          assign on_sale    = false
          if p.compare_at_price > p.price
            assign on_sale = true
          endif
          assign first_var = p.selected_or_first_available_variant
        -%}

        <div class="pvcard">
          <a href="{{ p.url }}" class="pvcard__media-link" tabindex="-1" aria-hidden="true">
            <div class="pvcard__media">
              {%- if img != blank -%}
                {{
                  img
                  | image_url: width: 600
                  | image_tag:
                    class: 'pvcard__img',
                    loading: 'lazy',
                    alt: img.alt | default: p.title,
                    widths: '300,450,600'
                }}
              {%- else -%}
                <div class="pvcard__no-img" aria-hidden="true">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                </div>
              {%- endif -%}
              {%- if on_sale -%}
                <span class="pvcard__badge pvcard__badge--sale">Sale</span>
              {%- elsif p.tags contains 'new' or p.tags contains 'New' -%}
                <span class="pvcard__badge pvcard__badge--new">New</span>
              {%- endif -%}
            </div>
          </a>

          <div class="pvcard__info">
            <a href="{{ p.url }}" class="pvcard__name">{{ p.title }}</a>

            <div class="pvcard__bottom">
              <div class="pvcard__prices">
                <span class="pvcard__price">{{ p.price | money }}</span>
                {%- if on_sale -%}
                  <s class="pvcard__compare">{{ p.compare_at_price | money }}</s>
                {%- endif -%}
              </div>

              {%- form 'product', p, class: 'pvcard__form' -%}
                <input type="hidden" name="id" value="{{ first_var.id }}">
                <button
                  type="submit"
                  name="add"
                  class="pvcard__atc"
                  {%- unless first_var.available -%}disabled{%- endunless -%}
                  aria-label="Add {{ p.title | escape }} to cart"
                >
                  {%- if first_var.available -%}
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                    Add
                  {%- else -%}
                    Sold Out
                  {%- endif -%}
                </button>
              {%- endform -%}
            </div>
          </div>
        </div>

      {%- endfor -%}

      {%- if shown == 0 -%}
        <div class="pvgrid__empty">
          <p>No in-stock products are available in this collection right now.</p>
          <a href="{{ routes.all_products_collection_url }}" class="pvgrid__all">Browse all</a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .pvgrid {
    background: #fafaf8;
    padding: 0 0 clamp(2.5rem, 5vw, 4rem);
  }

  .pvgrid__head {
    background: #ffffff;
    border-bottom: 1px solid var(--pv-border);
    margin-bottom: 1.5rem;
  }

  .pvgrid__head-inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    width: min(1400px, calc(100% - 40px));
    margin: 0 auto;
    padding: clamp(1.5rem, 3vw, 2rem) 0;
    flex-wrap: wrap;
  }

  .pvgrid__eyebrow {
    margin: 0 0 0.35rem;
    color: #b47b2d;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .pvgrid__title {
    margin: 0;
    color: var(--pv-navy);
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .pvgrid__all {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--pv-navy);
    text-decoration: none;
    white-space: nowrap;
    border-bottom: 1.5px solid rgba(15, 31, 53, 0.25);
    padding-bottom: 1px;
    transition: color 150ms ease, border-color 150ms ease;
  }

  .pvgrid__all:hover { color: var(--pv-gold); border-color: var(--pv-gold); }

  .pvgrid__body {
    width: min(1400px, calc(100% - 40px));
    margin: 0 auto;
  }

  .pvgrid__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .pvgrid__empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 3rem 1rem;
    color: var(--pv-muted);
  }

  /* ── PRODUCT CARD ──────────────────────────────────── */
  .pvcard {
    background: #ffffff;
    border: 1px solid var(--pv-border);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 180ms ease, transform 180ms ease;
  }

  .pvcard:hover {
    box-shadow: 0 12px 28px rgba(16, 35, 59, 0.09);
    transform: translateY(-3px);
  }

  .pvcard__media-link { display: block; }

  .pvcard__media {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: #f3f3f0;
  }

  .pvcard__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 500ms ease;
  }

  .pvcard:hover .pvcard__img { transform: scale(1.04); }

  .pvcard__no-img {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #c8d0da;
  }

  .pvcard__badge {
    position: absolute;
    top: 8px;
    left: 8px;
    padding: 0.28rem 0.6rem;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .pvcard__badge--sale { background: #ef4444; color: #ffffff; }
  .pvcard__badge--new  { background: var(--pv-gold); color: var(--pv-navy); }

  .pvcard__info {
    padding: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .pvcard__name {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 0.875rem;
    font-weight: 650;
    color: var(--pv-navy);
    text-decoration: none;
    line-height: 1.4;
  }

  .pvcard__name:hover { color: var(--pv-gold); }

  .pvcard__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: auto;
    flex-wrap: wrap;
  }

  .pvcard__prices {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .pvcard__price {
    font-size: 0.9375rem;
    font-weight: 800;
    color: var(--pv-navy);
  }

  .pvcard__compare {
    font-size: 0.78rem;
    color: #8a9ab0;
    text-decoration: line-through;
  }

  .pvcard__form { display: contents; }

  .pvcard__atc {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    height: 34px;
    padding: 0 0.9rem;
    border-radius: 999px;
    border: none;
    background: var(--pv-navy);
    color: #ffffff;
    font-size: 0.78rem;
    font-weight: 750;
    cursor: pointer;
    white-space: nowrap;
    transition: background 150ms ease, transform 150ms ease;
    flex-shrink: 0;
  }

  .pvcard__atc:hover { background: var(--pv-gold); color: var(--pv-navy); transform: scale(1.03); }
  .pvcard__atc:disabled { background: #d1d5db; color: #6b7280; cursor: not-allowed; transform: none; }

  /* ── RESPONSIVE ───────────────────────────────────── */
  @media (max-width: 1199px) {
    .pvgrid__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }

  @media (max-width: 749px) {
    .pvgrid__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.75rem; }
    .pvcard__atc { padding: 0 0.65rem; font-size: 0.72rem; }
  }

  @media (max-width: 449px) {
    .pvgrid__grid { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "PV — Product Grid",
  "tag": "section",
  "settings": [
    { "type": "text",       "id": "eyebrow", "label": "Eyebrow",   "default": "Shop now" },
    { "type": "text",       "id": "title",   "label": "Heading",   "default": "Featured Products" },
    { "type": "collection", "id": "collection", "label": "Collection (blank = all products)" },
    {
      "type": "select",
      "id": "products_to_show",
      "label": "Products to show",
      "options": [
        { "value": "4",  "label": "4" },
        { "value": "8",  "label": "8" },
        { "value": "12", "label": "12" },
        { "value": "16", "label": "16" }
      ],
      "default": "8"
    }
  ],
  "presets": [{ "name": "PV — Product Grid" }]
}
{% endschema %}
