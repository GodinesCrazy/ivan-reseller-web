{%- comment -%} PawVault collection hero. {%- endcomment -%}

{%- liquid
  assign products_count = collection.products_count | default: 0
  assign hero_image = section.settings.image
  if hero_image == blank and collection.image != blank
    assign hero_image = collection.image
  endif
-%}

<section class="ir-collection-hero">
  <div class="ir-collection-hero__container">
    <div class="ir-collection-hero__copy">
      <p class="ir-collection-hero__eyebrow">{{ section.settings.eyebrow | default: 'PawVault catalog' }}</p>
      <h1 class="ir-collection-hero__title">{{ collection.title | default: 'Shop pet essentials' }}</h1>
      <p class="ir-collection-hero__text">
        {%- if collection.description != blank -%}
          {{ collection.description | strip_html }}
        {%- else -%}
          {{ section.settings.description }}
        {%- endif -%}
      </p>
      <div class="ir-collection-hero__meta" aria-label="Collection highlights">
        <span>{{ products_count }} products</span>
        <span>Dogs, cats and care routines</span>
        <span>Secure checkout</span>
      </div>
    </div>

    <div class="ir-collection-hero__panel">
      {%- if hero_image != blank -%}
        {{
          hero_image
          | image_url: width: 1000
          | image_tag:
            class: 'ir-collection-hero__image',
            loading: 'eager',
            widths: '480, 720, 1000',
            sizes: '(min-width: 990px) 42vw, 100vw',
            alt: collection.title
        }}
      {%- else -%}
        <img
          src="https://images.unsplash.com/photo-1511044568932-338cba0ad803?auto=format&fit=crop&w=1000&q=85"
          alt="{{ collection.title | default: 'PawVault collection' }}"
          class="ir-collection-hero__image"
          width="1000"
          height="1200"
        >
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PV - Collection Hero",
  "tag": "section",
  "class": "ir-collection-hero-section",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "PawVault catalog" },
    { "type": "textarea", "id": "description", "label": "Fallback description", "default": "Curated accessories, grooming tools, feeding picks and comfort essentials for dogs and cats." },
    { "type": "image_picker", "id": "image", "label": "Optional hero image" }
  ],
  "presets": [
    { "name": "PV - Collection Hero" }
  ]
}
{% endschema %}
