{%- comment -%}
  Ivan Reseller - Premium Collection Hero
  Adds retail-grade catalog context while leaving native filtering and grids intact.
{%- endcomment -%}

{%- liquid
  assign products_count = collection.products_count | default: 0
  assign hero_image = section.settings.image
  if hero_image == blank and collection.image != blank
    assign hero_image = collection.image
  endif
-%}

<section class="ir-collection-hero">
  <div class="ir-collection-hero__container">
    <div class="ir-collection-hero__copy">
      <p class="ir-collection-hero__eyebrow">{{ section.settings.eyebrow | default: 'Curated Catalog' }}</p>
      <h1 class="ir-collection-hero__title">{{ collection.title | default: 'Shop Ivan Reseller' }}</h1>
      <p class="ir-collection-hero__text">
        {%- if collection.description != blank -%}
          {{ collection.description | strip_html }}
        {%- else -%}
          {{ section.settings.description }}
        {%- endif -%}
      </p>
      <div class="ir-collection-hero__meta" aria-label="Collection highlights">
        <span>{{ products_count }} products</span>
        <span>Tech, travel, desk, everyday</span>
        <span>Secure checkout</span>
      </div>
    </div>

    <div class="ir-collection-hero__panel">
      {%- if hero_image != blank -%}
        {{
          hero_image
          | image_url: width: 1000
          | image_tag:
            class: 'ir-collection-hero__image',
            loading: 'eager',
            widths: '480, 720, 1000',
            sizes: '(min-width: 990px) 42vw, 100vw',
            alt: collection.title
        }}
      {%- else -%}
        <div class="ir-collection-hero__abstract" aria-hidden="true">
          <span>Desk</span>
          <span>Travel</span>
          <span>Tech</span>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "IR - Collection Hero",
  "tag": "section",
  "class": "ir-collection-hero-section",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Curated Catalog"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Fallback description",
      "default": "Purposeful accessories for travel, workspace, tech protection, and daily carry. Browse a tighter catalog with clear product information and secure checkout."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Optional hero image"
    }
  ],
  "presets": [
    {
      "name": "IR - Collection Hero"
    }
  ]
}
{% endschema %}
