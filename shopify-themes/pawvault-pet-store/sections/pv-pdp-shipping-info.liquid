{%- liquid
  assign threshold    = section.settings.free_threshold   | default: '50'
  assign delivery     = section.settings.delivery_days    | default: '3–7 business days'
  assign return_days  = section.settings.return_days      | default: '30 days'
  assign ships_from   = section.settings.ships_from       | default: 'USA'
-%}

<div class="pv-ship-info section-{{ section.id }}">
  <div class="pv-ship-info__inner">

    <details class="pv-ship-info__row" open>
      <summary class="pv-ship-info__trigger">
        <span class="pv-ship-info__trigger-left">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/>
            <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
          </svg>
          Shipping &amp; delivery
        </span>
        <svg class="pv-ship-info__caret" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </summary>
      <div class="pv-ship-info__body">
        <ul class="pv-ship-info__list">
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Free shipping on orders over <strong>${{ threshold }}</strong></span>
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Estimated delivery: <strong>{{ delivery }}</strong> across the USA</span>
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Ships from <strong>{{ ships_from }}</strong> — no international delays</span>
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Tracking number sent via email once shipped</span>
          </li>
        </ul>
      </div>
    </details>

    <details class="pv-ship-info__row">
      <summary class="pv-ship-info__trigger">
        <span class="pv-ship-info__trigger-left">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.59"/>
          </svg>
          Returns &amp; exchanges
        </span>
        <svg class="pv-ship-info__caret" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </summary>
      <div class="pv-ship-info__body">
        <ul class="pv-ship-info__list">
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span><strong>{{ return_days }} hassle-free returns</strong> — no questions asked</span>
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Items must be unused and in original condition</span>
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Refund processed within 5–7 business days of receipt</span>
          </li>
        </ul>
      </div>
    </details>

  </div>
</div>

{% schema %}
{
  "name": "PDP — Shipping Info",
  "tag": "section",
  "class": "pv-ship-info-section",
  "settings": [
    {
      "type": "text",
      "id": "free_threshold",
      "label": "Free shipping threshold ($)",
      "default": "50"
    },
    {
      "type": "text",
      "id": "delivery_days",
      "label": "Estimated delivery",
      "default": "3–7 business days"
    },
    {
      "type": "text",
      "id": "return_days",
      "label": "Return window",
      "default": "30 days"
    },
    {
      "type": "text",
      "id": "ships_from",
      "label": "Ships from location",
      "default": "USA"
    }
  ],
  "presets": [
    {
      "name": "PDP — Shipping Info"
    }
  ]
}
{% endschema %}
