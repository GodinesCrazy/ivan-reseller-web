{%- comment -%} PawVault product trust panel. {%- endcomment -%}

<div class="ir-product-trust-section">
  <div class="ir-product-trust__panel">
    <p class="ir-product-trust__eyebrow">Before checkout</p>
    <h2 class="ir-product-trust__heading">Pet-parent clarity, secure payment, and post-purchase support.</h2>

    {%- if section.settings.show_guarantee -%}
      <div class="ir-guarantee-badge">
        <span class="ir-guarantee-badge__icon">✓</span>
        <div class="ir-guarantee-badge__content">
          <div class="ir-guarantee-badge__title">{{ section.settings.guarantee_title }}</div>
          <div class="ir-guarantee-badge__text">{{ section.settings.guarantee_text }}</div>
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.show_benefits and section.blocks.size > 0 -%}
      <div class="ir-product-benefits">
        {% for block in section.blocks %}
          {% if block.type == 'benefit' %}
            <div class="ir-product-benefits__item" {{ block.shopify_attributes }}>
              <span class="ir-product-benefits__check">✓</span>
              <span class="ir-product-benefits__text">{{ block.settings.text }}</span>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {%- endif -%}

    {%- if section.settings.show_stock_indicator -%}
      <div class="ir-stock-indicator">
        <span class="ir-stock-indicator__dot"></span>
        <span class="ir-stock-indicator__text">{{ section.settings.stock_text }}</span>
        <span class="ir-stock-indicator__subtext">{{ section.settings.stock_subtext }}</span>
      </div>
    {%- endif -%}

    {%- if section.settings.show_trust_bar -%}
      <div class="ir-product-trust__bar">
        {% for block in section.blocks %}
          {% if block.type == 'trust_item' %}
            <div class="ir-product-trust__item" {{ block.shopify_attributes }}>
              <span class="ir-product-trust__icon">{{ block.settings.icon }}</span>
              <span>{{ block.settings.text }}</span>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {%- endif -%}

    {%- if section.settings.show_payment_trust -%}
      <div class="ir-payment-trust">
        <p class="ir-payment-trust__text">{{ section.settings.payment_text }}</p>
        <ul class="ir-payment-trust__icons" role="list">
          {%- liquid
            assign rendered_payment_icons = false
          -%}

          {%- for type in shop.enabled_payment_types -%}
            {%- case type -%}
              {%- when 'visa' -%}
                {%- if section.settings.show_visa -%}
                  {%- assign rendered_payment_icons = true -%}
                  <li class="ir-payment-trust__icon-wrap">
                    {{ type | payment_type_svg_tag: class: 'icon icon--full-color ir-payment-trust__icon-svg' }}
                  </li>
                {%- endif -%}
              {%- when 'master', 'mastercard' -%}
                {%- if section.settings.show_mastercard -%}
                  {%- assign rendered_payment_icons = true -%}
                  <li class="ir-payment-trust__icon-wrap">
                    {{ type | payment_type_svg_tag: class: 'icon icon--full-color ir-payment-trust__icon-svg' }}
                  </li>
                {%- endif -%}
              {%- when 'american_express', 'amex' -%}
                {%- if section.settings.show_amex -%}
                  {%- assign rendered_payment_icons = true -%}
                  <li class="ir-payment-trust__icon-wrap">
                    {{ type | payment_type_svg_tag: class: 'icon icon--full-color ir-payment-trust__icon-svg' }}
                  </li>
                {%- endif -%}
              {%- when 'paypal' -%}
                {%- if section.settings.show_paypal -%}
                  {%- assign rendered_payment_icons = true -%}
                  <li class="ir-payment-trust__icon-wrap">
                    {{ type | payment_type_svg_tag: class: 'icon icon--full-color ir-payment-trust__icon-svg' }}
                  </li>
                {%- endif -%}
            {%- endcase -%}
          {%- endfor -%}

          {%- unless rendered_payment_icons -%}
            <li class="ir-payment-trust__method-text">Payment methods appear securely during checkout.</li>
          {%- endunless -%}
        </ul>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "PV - Product Trust",
  "tag": "section",
  "class": "ir-product-trust-section",
  "settings": [
    { "type": "header", "content": "Guarantee badge" },
    { "type": "checkbox", "id": "show_guarantee", "label": "Show guarantee badge", "default": true },
    { "type": "text", "id": "guarantee_title", "label": "Guarantee title", "default": "30-day support" },
    { "type": "text", "id": "guarantee_text", "label": "Guarantee text", "default": "If something feels off after delivery, we keep the support process clear and simple." },
    { "type": "header", "content": "Benefits" },
    { "type": "checkbox", "id": "show_benefits", "label": "Show benefits list", "default": true },
    { "type": "header", "content": "Availability note" },
    { "type": "checkbox", "id": "show_stock_indicator", "label": "Show availability note", "default": true },
    { "type": "text", "id": "stock_text", "label": "Availability title", "default": "Ready for your next pet-care upgrade" },
    { "type": "text", "id": "stock_subtext", "label": "Availability subtext", "default": "Choose your options, add to cart, and checkout with confidence." },
    { "type": "header", "content": "Trust row" },
    { "type": "checkbox", "id": "show_trust_bar", "label": "Show trust row", "default": true },
    { "type": "header", "content": "Payment icons" },
    { "type": "checkbox", "id": "show_payment_trust", "label": "Show payment block", "default": true },
    { "type": "text", "id": "payment_text", "label": "Payment text", "default": "Secure checkout with trusted payment methods" },
    { "type": "checkbox", "id": "show_visa", "label": "Show Visa", "default": true },
    { "type": "checkbox", "id": "show_mastercard", "label": "Show Mastercard", "default": true },
    { "type": "checkbox", "id": "show_amex", "label": "Show Amex", "default": true },
    { "type": "checkbox", "id": "show_paypal", "label": "Show PayPal", "default": true }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Thoughtful details for real pet-parent routines" }
      ]
    },
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon", "default": "01" },
        { "type": "text", "id": "text", "label": "Text", "default": "Clear delivery updates" }
      ]
    }
  ],
  "presets": [
    {
      "name": "PV - Product Trust",
      "blocks": [
        { "type": "benefit", "settings": { "text": "Pet-focused picks chosen for everyday use" } },
        { "type": "benefit", "settings": { "text": "Fast support cues before and after checkout" } },
        { "type": "benefit", "settings": { "text": "Protected payment and straightforward returns" } },
        { "type": "trust_item", "settings": { "icon": "01", "text": "Reliable shipping updates" } },
        { "type": "trust_item", "settings": { "icon": "02", "text": "Straightforward return support" } },
        { "type": "trust_item", "settings": { "icon": "03", "text": "Secure checkout experience" } }
      ]
    }
  ]
}
{% endschema %}
