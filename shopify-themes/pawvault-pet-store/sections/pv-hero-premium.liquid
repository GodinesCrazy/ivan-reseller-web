{%- comment -%} PawVault hero with image-led editorial layout and premium pet-store cues. {%- endcomment -%}

{%- liquid
  assign hero_image_main = section.settings.image_main
  assign hero_image_top = section.settings.image_top
  assign hero_image_bottom = section.settings.image_bottom
  assign hero_main_fallback = 'pv-hero-main.jpg' | asset_url
  assign hero_top_fallback = 'pv-hero-top.jpg' | asset_url
  assign hero_bottom_fallback = 'pv-hero-bottom.jpg' | asset_url
-%}

<section class="pv-hero">
  <div class="pv-hero__orb pv-hero__orb--gold" aria-hidden="true"></div>
  <div class="pv-hero__orb pv-hero__orb--mint" aria-hidden="true"></div>

  <div class="pv-hero__container">
    <div class="pv-hero__copy">
      <div class="pv-hero__eyebrow-row">
        <span class="pv-hero__eyebrow">{{ section.settings.eyebrow | default: 'PawVault - Premium Pet Store' }}</span>
        <span class="pv-hero__signal">{{ section.settings.signal | default: 'Curated for dogs and cats' }}</span>
      </div>

      <h1 class="pv-hero__headline">
        {{ section.settings.line1 | default: 'Your pet deserves' }}
        <span class="pv-hero__accent">{{ section.settings.line2 | default: 'the good stuff.' }}</span>
        {%- if section.settings.line3 != blank -%}{{ section.settings.line3 }}{%- endif -%}
      </h1>

      <p class="pv-hero__sub">
        {{ section.settings.description | default: 'Premium accessories, grooming essentials and everyday supplies for dogs and cats - chosen for comfort, safety and daily use in real American homes.' }}
      </p>

      <div class="pv-hero__chips">
        <span class="pv-hero__chip">Dogs</span>
        <span class="pv-hero__chip">Cats</span>
        <span class="pv-hero__chip">Grooming</span>
        <span class="pv-hero__chip">Beds</span>
        <span class="pv-hero__chip">Feeding</span>
      </div>

      <div class="pv-hero__ctas">
        <a href="{{ section.settings.btn1_link | default: '/collections/all' }}" class="pv-hero__btn pv-hero__btn--primary">
          {{ section.settings.btn1_text | default: 'Shop Pet Supplies' }}
        </a>
        <a href="{{ section.settings.btn2_link | default: '/collections/all' }}" class="pv-hero__btn pv-hero__btn--secondary">
          {{ section.settings.btn2_text | default: 'Browse Best Sellers' }}
        </a>
      </div>

      <div class="pv-hero__stats" aria-label="PawVault highlights">
        <div class="pv-hero__stat">
          <strong>{{ section.settings.stat_1_value | default: 'Free' }}</strong>
          <span>{{ section.settings.stat_1_label | default: 'shipping over $50' }}</span>
        </div>
        <div class="pv-hero__stat">
          <strong>{{ section.settings.stat_2_value | default: '30-day' }}</strong>
          <span>{{ section.settings.stat_2_label | default: 'easy returns' }}</span>
        </div>
        <div class="pv-hero__stat">
          <strong>{{ section.settings.stat_3_value | default: 'USA' }}</strong>
          <span>{{ section.settings.stat_3_label | default: 'English storefront' }}</span>
        </div>
      </div>
    </div>

    <div class="pv-hero__visual">
      <div class="pv-hero__visual-main">
        {% if hero_image_main != blank %}
          {{
            hero_image_main
            | image_url: width: 1600
            | image_tag:
              class: 'pv-hero__image',
              loading: 'eager',
              alt: hero_image_main.alt | default: 'Happy dog with premium accessories'
          }}
        {% else %}
          <img
            src="{{ hero_main_fallback }}"
            alt="Happy dog with premium accessories"
            class="pv-hero__image"
            loading="eager"
            width="800"
            height="980"
          >
        {% endif %}

        <div class="pv-hero__floating-card pv-hero__floating-card--main">
          <span class="pv-hero__floating-kicker">{{ section.settings.overlay_kicker | default: 'PawVault Edit' }}</span>
          <strong>{{ section.settings.overlay_title | default: 'Clean essentials for everyday pet life' }}</strong>
          <span>{{ section.settings.overlay_text | default: 'Thoughtful picks for play, feeding, grooming and comfort.' }}</span>
        </div>
      </div>

      <div class="pv-hero__visual-stack">
        <article class="pv-hero__mini-card">
          <div class="pv-hero__mini-media">
            {% if hero_image_top != blank %}
              {{
                hero_image_top
                | image_url: width: 900
                | image_tag:
                  class: 'pv-hero__mini-image',
                  loading: 'lazy',
                  alt: hero_image_top.alt | default: 'Dog and owner with pet accessories'
              }}
            {% else %}
              <img
                src="{{ hero_top_fallback }}"
                alt="Dog and owner with pet accessories"
                class="pv-hero__mini-image"
                loading="lazy"
                width="520"
                height="360"
              >
            {% endif %}
          </div>
          <div class="pv-hero__mini-body">
            <span class="pv-hero__mini-label">Top picks for dogs</span>
            <p>Quality accessories built for daily routines — leashes, beds, feeding and play.</p>
          </div>
        </article>

        <article class="pv-hero__mini-card pv-hero__mini-card--split">
          <div class="pv-hero__mini-body">
            <span class="pv-hero__mini-label">Made for cats too</span>
            <p>Premium comfort and enrichment picks for cats of every personality.</p>
          </div>
          <div class="pv-hero__mini-media">
            {% if hero_image_bottom != blank %}
              {{
                hero_image_bottom
                | image_url: width: 900
                | image_tag:
                  class: 'pv-hero__mini-image',
                  loading: 'lazy',
                  alt: hero_image_bottom.alt | default: 'Cat resting in a cozy bed'
              }}
            {% else %}
              <img
                src="{{ hero_bottom_fallback }}"
                alt="Cat resting in a cozy bed"
                class="pv-hero__mini-image"
                loading="lazy"
                width="520"
                height="360"
              >
            {% endif %}
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

<style>
  .pv-hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at top left, rgba(245, 165, 36, 0.16), transparent 28%),
      linear-gradient(180deg, #fffdf9 0%, #f8fafc 52%, #ffffff 100%);
    padding: clamp(2rem, 4vw, 3rem) 0 clamp(4rem, 8vw, 7rem);
  }

  .pv-hero__orb {
    position: absolute;
    border-radius: 999px;
    filter: blur(90px);
    opacity: 0.45;
    pointer-events: none;
  }

  .pv-hero__orb--gold {
    width: 280px;
    height: 280px;
    background: rgba(245, 165, 36, 0.26);
    top: 4%;
    right: 6%;
  }

  .pv-hero__orb--mint {
    width: 240px;
    height: 240px;
    background: rgba(143, 214, 148, 0.3);
    left: 4%;
    bottom: 6%;
  }

  .pv-hero__container {
    position: relative;
    z-index: 1;
    width: min(1280px, calc(100% - 40px));
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 560px);
    gap: clamp(2.25rem, 5vw, 4.75rem);
    align-items: center;
  }

  .pv-hero__copy {
    max-width: 610px;
  }

  .pv-hero__eyebrow-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    margin-bottom: 1.25rem;
  }

  .pv-hero__eyebrow,
  .pv-hero__signal,
  .pv-hero__mini-label,
  .pv-hero__floating-kicker {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .pv-hero__eyebrow {
    color: #b7791f;
  }

  .pv-hero__signal {
    color: #1f4d2d;
    background: rgba(143, 214, 148, 0.16);
    border: 1px solid rgba(143, 214, 148, 0.45);
    border-radius: 999px;
    padding: 0.45rem 0.8rem;
    letter-spacing: 0.08em;
  }

  .pv-hero__headline {
    margin: 0;
    color: #122033;
    font-size: clamp(2.8rem, 6vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
    font-weight: 820;
  }

  .pv-hero__headline span {
    display: block;
  }

  .pv-hero__accent {
    color: #f59e0b;
  }

  .pv-hero__sub {
    margin: 1.4rem 0 0;
    max-width: 42rem;
    color: #52606d;
    font-size: clamp(1rem, 1.4vw, 1.14rem);
    line-height: 1.8;
  }

  .pv-hero__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin: 1.75rem 0 0;
  }

  .pv-hero__chip {
    border-radius: 999px;
    border: 1px solid rgba(18, 32, 51, 0.08);
    background: rgba(255, 255, 255, 0.9);
    color: #364152;
    font-size: 0.82rem;
    font-weight: 650;
    padding: 0.62rem 0.95rem;
  }

  .pv-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2rem;
  }

  .pv-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0.95rem 1.5rem;
    border-radius: 999px;
    text-decoration: none;
    font-size: 0.96rem;
    font-weight: 760;
    transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease, color 180ms ease;
  }

  .pv-hero__btn--primary {
    background: #122033;
    color: #ffffff;
    box-shadow: 0 14px 32px rgba(18, 32, 51, 0.16);
  }

  .pv-hero__btn--primary:hover {
    transform: translateY(-2px);
    background: #1c2d44;
  }

  .pv-hero__btn--secondary {
    background: #ffffff;
    color: #122033;
    border: 1px solid rgba(18, 32, 51, 0.12);
  }

  .pv-hero__btn--secondary:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(18, 32, 51, 0.1);
  }

  .pv-hero__stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
    margin-top: 2rem;
  }

  .pv-hero__stat {
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(18, 32, 51, 0.07);
    padding: 1rem 1.05rem;
    box-shadow: 0 16px 32px rgba(18, 32, 51, 0.06);
  }

  .pv-hero__stat strong {
    display: block;
    color: #122033;
    font-size: 1.05rem;
    font-weight: 760;
  }

  .pv-hero__stat span {
    display: block;
    margin-top: 0.2rem;
    color: #52606d;
    font-size: 0.84rem;
    line-height: 1.45;
  }

  .pv-hero__visual {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 0.7fr;
    gap: 1rem;
    align-items: stretch;
  }

  .pv-hero__visual-main,
  .pv-hero__mini-card {
    position: relative;
    overflow: hidden;
    border-radius: 30px;
    box-shadow: 0 24px 54px rgba(18, 32, 51, 0.12);
  }

  .pv-hero__visual-main {
    min-height: 620px;
    background: #e9eef5;
  }

  .pv-hero__image,
  .pv-hero__mini-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pv-hero__floating-card {
    position: absolute;
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
    display: grid;
    gap: 0.35rem;
    padding: 1rem 1.05rem;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.75);
  }

  .pv-hero__floating-kicker,
  .pv-hero__mini-label {
    color: #b7791f;
  }

  .pv-hero__floating-card strong {
    color: #122033;
    font-size: 1rem;
    letter-spacing: -0.02em;
  }

  .pv-hero__floating-card span:last-child,
  .pv-hero__mini-body p {
    color: #52606d;
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .pv-hero__visual-stack {
    display: grid;
    gap: 1rem;
  }

  .pv-hero__mini-card {
    display: grid;
    grid-template-rows: 1.1fr auto;
    background: #ffffff;
    min-height: 300px;
  }

  .pv-hero__mini-card--split {
    grid-template-rows: auto 1fr;
  }

  .pv-hero__mini-media {
    min-height: 170px;
    background: #e9eef5;
  }

  .pv-hero__mini-body {
    padding: 1rem 1rem 1.15rem;
  }

  .pv-hero__mini-body p {
    margin: 0.45rem 0 0;
  }

  @media (max-width: 1099px) {
    .pv-hero__container {
      grid-template-columns: 1fr;
    }

    .pv-hero__copy {
      max-width: none;
    }
  }

  @media (max-width: 749px) {
    .pv-hero {
      padding-top: 1rem;
    }

    .pv-hero__container {
      width: min(100%, calc(100% - 24px));
      gap: 1.5rem;
    }

    .pv-hero__visual {
      grid-template-columns: 1fr;
    }

    .pv-hero__visual-main {
      min-height: 460px;
    }

    .pv-hero__stats {
      grid-template-columns: 1fr;
    }

    .pv-hero__btn {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "PV - Hero Premium",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "PawVault - Premium Pet Store" },
    { "type": "text", "id": "signal", "label": "Signal Badge", "default": "Curated for dogs and cats" },
    { "type": "text", "id": "line1", "label": "Headline Line 1", "default": "Beautiful essentials" },
    { "type": "text", "id": "line2", "label": "Headline Line 2", "default": "for happy pets" },
    { "type": "text", "id": "line3", "label": "Headline Line 3", "default": "and calmer homes." },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Premium accessories, grooming essentials and everyday supplies for dogs and cats - chosen for comfort, safety and daily use in real American homes." },
    { "type": "text", "id": "btn1_text", "label": "Primary Button", "default": "Shop Pet Supplies" },
    { "type": "url", "id": "btn1_link", "label": "Primary Button Link" },
    { "type": "text", "id": "btn2_text", "label": "Secondary Button", "default": "Browse Best Sellers" },
    { "type": "url", "id": "btn2_link", "label": "Secondary Button Link" },
    { "type": "text", "id": "stat_1_value", "label": "Stat 1 Value", "default": "Free" },
    { "type": "text", "id": "stat_1_label", "label": "Stat 1 Label", "default": "shipping over $50" },
    { "type": "text", "id": "stat_2_value", "label": "Stat 2 Value", "default": "30-day" },
    { "type": "text", "id": "stat_2_label", "label": "Stat 2 Label", "default": "easy returns" },
    { "type": "text", "id": "stat_3_value", "label": "Stat 3 Value", "default": "USA" },
    { "type": "text", "id": "stat_3_label", "label": "Stat 3 Label", "default": "English storefront" },
    { "type": "text", "id": "overlay_kicker", "label": "Overlay Kicker", "default": "PawVault Edit" },
    { "type": "text", "id": "overlay_title", "label": "Overlay Title", "default": "Clean essentials for everyday pet life" },
    { "type": "text", "id": "overlay_text", "label": "Overlay Text", "default": "Thoughtful picks for play, feeding, grooming and comfort." },
    { "type": "image_picker", "id": "image_main", "label": "Main Hero Image" },
    { "type": "image_picker", "id": "image_top", "label": "Top Support Image" },
    { "type": "image_picker", "id": "image_bottom", "label": "Bottom Support Image" }
  ],
  "presets": [
    {
      "name": "PV - Hero Premium",
      "category": "PawVault"
    }
  ]
}
{% endschema %}
