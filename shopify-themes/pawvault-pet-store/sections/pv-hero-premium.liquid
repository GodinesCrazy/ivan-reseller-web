{%- liquid
  assign cta1_url  = section.settings.cta1_url  | default: routes.all_products_collection_url
  assign cta2_url  = section.settings.cta2_url  | default: routes.all_products_collection_url

  assign featured_col = collections[section.settings.featured_collection]
  if featured_col == blank or featured_col.products_count == 0
    assign featured_col = collections.all
  endif
  assign fp = featured_col.products.first
-%}

<section class="pvh">
  <div class="pvh__wrap">

    {%- comment -%} LEFT — pitch {%- endcomment -%}
    <div class="pvh__left">

      <div class="pvh__promo-tag">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        {{ section.settings.badge | default: 'Free shipping on orders over $50 — USA wide' }}
      </div>

      <h1 class="pvh__h1">
        {{ section.settings.line1 | default: 'Everything your' }}<br>
        <em class="pvh__em">{{ section.settings.line2 | default: 'pet needs.' }}</em>
      </h1>

      <p class="pvh__sub">{{ section.settings.subline | default: 'Hand-picked accessories, grooming essentials and daily care for dogs and cats — chosen for real pet parents.' }}</p>

      <div class="pvh__actions">
        <a href="{{ cta1_url }}" class="pvh__btn pvh__btn--primary">
          {{ section.settings.cta1_text | default: 'Shop All Products' }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="{{ cta2_url }}" class="pvh__btn pvh__btn--ghost">
          {{ section.settings.cta2_text | default: 'View Deals' }}
        </a>
      </div>

      <div class="pvh__trust-row">
        <div class="pvh__trust-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>30-day returns</span>
        </div>
        <div class="pvh__trust-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Pet-safe products</span>
        </div>
        <div class="pvh__trust-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="#f59e0b" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <span>4.8 / 5 rating</span>
        </div>
      </div>

    </div>

    {%- comment -%} RIGHT — featured product card {%- endcomment -%}
    <div class="pvh__right">

      {%- if fp != blank -%}
        <div class="pvh__fp">
          <span class="pvh__fp-label">Featured right now</span>
          <a href="{{ fp.url }}" class="pvh__fp-media">
            {%- if fp.featured_image != blank -%}
              {{ fp.featured_image | image_url: width: 700 | image_tag: class: 'pvh__fp-img', loading: 'eager', alt: fp.featured_image.alt | default: fp.title }}
            {%- else -%}
              <div class="pvh__fp-no-img">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                <span>Add product image<br>in Shopify Admin</span>
              </div>
            {%- endif -%}
          </a>
          <div class="pvh__fp-info">
            <a href="{{ fp.url }}" class="pvh__fp-name">{{ fp.title | truncate: 50 }}</a>
            <div class="pvh__fp-bottom">
              <span class="pvh__fp-price">{{ fp.price | money }}</span>
              {%- form 'product', fp, class: 'pvh__fp-form' -%}
                <input type="hidden" name="id" value="{{ fp.selected_or_first_available_variant.id }}">
                <button type="submit" name="add" class="pvh__fp-atc"
                  {%- unless fp.selected_or_first_available_variant.available -%}disabled{%- endunless -%}>
                  {%- if fp.selected_or_first_available_variant.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
                </button>
              {%- endform -%}
            </div>
          </div>
        </div>

      {%- else -%}

        <div class="pvh__placeholder">
          <div class="pvh__pl-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.35)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          </div>
          <p class="pvh__pl-text">Add products in<br><strong>Shopify Admin → Products</strong><br>to display them here.</p>
          <div class="pvh__stats-grid">
            <div class="pvh__stat"><strong>2,000+</strong><span>pet families</span></div>
            <div class="pvh__stat"><strong>4.8★</strong><span>avg rating</span></div>
            <div class="pvh__stat"><strong>Free</strong><span>shipping $50+</span></div>
            <div class="pvh__stat"><strong>30-day</strong><span>returns</span></div>
          </div>
        </div>

      {%- endif -%}

    </div>

  </div>
</section>

<style>
  .pvh {
    background: var(--pv-navy);
    border-bottom: 3px solid var(--pv-gold);
  }

  .pvh__wrap {
    display: grid;
    grid-template-columns: 1fr 440px;
    min-height: 460px;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* LEFT */
  .pvh__left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(3rem, 6vw, 5rem) clamp(2rem, 4vw, 3.5rem) clamp(3rem, 6vw, 5rem) clamp(2rem, 5vw, 5rem);
    gap: 0;
  }

  .pvh__promo-tag {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    width: fit-content;
    padding: 0.4rem 0.9rem;
    margin-bottom: 1.5rem;
    border-radius: 6px;
    background: rgba(242, 169, 59, 0.18);
    border: 1px solid rgba(242, 169, 59, 0.35);
    color: #fcd87a;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    font-family: var(--pv-font);
  }

  .pvh__h1 {
    margin: 0;
    color: #ffffff;
    font-size: clamp(2.6rem, 5vw, 4.2rem);
    font-weight: 900;
    line-height: 1.03;
    letter-spacing: -0.05em;
    font-family: var(--pv-font) !important;
  }

  .pvh__em {
    font-style: normal;
    color: var(--pv-gold);
  }

  .pvh__sub {
    margin: 1.25rem 0 0;
    max-width: 38rem;
    color: rgba(255, 255, 255, 0.55);
    font-size: 1.05rem;
    line-height: 1.7;
    font-family: var(--pv-font);
  }

  .pvh__actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .pvh__btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    height: 50px;
    padding: 0 1.6rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform 140ms ease, opacity 140ms ease, background 140ms ease;
    font-family: var(--pv-font);
  }

  .pvh__btn:hover { transform: translateY(-2px); }

  .pvh__btn--primary {
    background: var(--pv-gold);
    color: var(--pv-navy);
  }

  .pvh__btn--primary:hover { background: #f5b84a; }

  .pvh__btn--ghost {
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .pvh__btn--ghost:hover { background: rgba(255, 255, 255, 0.13); }

  .pvh__trust-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-top: 1.75rem;
  }

  .pvh__trust-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.82rem;
    font-weight: 500;
    font-family: var(--pv-font);
  }

  /* RIGHT — featured product */
  .pvh__right {
    position: relative;
    display: flex;
    align-items: stretch;
    background: rgba(255, 255, 255, 0.04);
    border-left: 1px solid rgba(255, 255, 255, 0.07);
  }

  .pvh__fp {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .pvh__fp-label {
    display: block;
    padding: 0.9rem 1.25rem 0.7rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pv-gold);
    font-family: var(--pv-font);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .pvh__fp-media {
    display: block;
    flex: 1;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.03);
  }

  .pvh__fp-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms ease;
  }

  .pvh__fp-media:hover .pvh__fp-img { transform: scale(1.03); }

  .pvh__fp-no-img {
    width: 100%;
    height: 100%;
    min-height: 260px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    color: rgba(255, 255, 255, 0.3);
    font-size: 0.82rem;
    text-align: center;
    line-height: 1.6;
    font-family: var(--pv-font);
  }

  .pvh__fp-info {
    padding: 1rem 1.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    background: rgba(0, 0, 0, 0.15);
  }

  .pvh__fp-name {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    margin-bottom: 0.75rem;
    line-height: 1.4;
    font-family: var(--pv-font);
  }

  .pvh__fp-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .pvh__fp-price {
    font-size: 1.25rem;
    font-weight: 800;
    color: #ffffff;
    font-family: var(--pv-font);
  }

  .pvh__fp-form { display: contents; }

  .pvh__fp-atc {
    display: inline-flex;
    align-items: center;
    height: 38px;
    padding: 0 1.1rem;
    border-radius: 7px;
    border: none;
    background: var(--pv-gold);
    color: var(--pv-navy);
    font-size: 0.85rem;
    font-weight: 800;
    cursor: pointer;
    font-family: var(--pv-font);
    transition: background 140ms ease, transform 140ms ease;
  }

  .pvh__fp-atc:hover { background: #f5b84a; transform: scale(1.02); }
  .pvh__fp-atc:disabled { background: #3d5570; color: #7a91aa; cursor: not-allowed; transform: none; }

  /* Placeholder when no products */
  .pvh__placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 2.5rem 2rem;
    gap: 1.5rem;
    text-align: center;
  }

  .pvh__pl-icon {
    width: 72px;
    height: 72px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pvh__pl-text {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.85rem;
    line-height: 1.75;
    font-family: var(--pv-font);
  }

  .pvh__pl-text strong {
    color: rgba(255, 255, 255, 0.65);
    font-weight: 600;
  }

  .pvh__stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    width: 100%;
  }

  .pvh__stat {
    padding: 0.9rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    text-align: center;
    font-family: var(--pv-font);
  }

  .pvh__stat strong {
    display: block;
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--pv-gold);
  }

  .pvh__stat span {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.4);
    font-weight: 500;
  }

  @media (max-width: 959px) {
    .pvh__wrap { grid-template-columns: 1fr; min-height: auto; }
    .pvh__right { border-left: none; border-top: 1px solid rgba(255,255,255,0.07); max-height: 320px; }
    .pvh__left { padding: 2.5rem 1.5rem 2rem; }
    .pvh__h1 { font-size: clamp(2.2rem, 6vw, 3rem); }
  }

  @media (max-width: 479px) {
    .pvh__btn { width: 100%; justify-content: center; }
    .pvh__actions { flex-direction: column; }
    .pvh__stats-grid { grid-template-columns: 1fr 1fr; }
  }
</style>

{% schema %}
{
  "name": "PV — Hero",
  "tag": "section",
  "settings": [
    { "type": "text",       "id": "badge",    "label": "Top badge",        "default": "Free shipping on orders over $50 — USA wide" },
    { "type": "text",       "id": "line1",    "label": "Headline line 1",  "default": "Everything your" },
    { "type": "text",       "id": "line2",    "label": "Headline line 2 (gold)", "default": "pet needs." },
    { "type": "textarea",   "id": "subline",  "label": "Subline",          "default": "Hand-picked accessories, grooming essentials and daily care for dogs and cats." },
    { "type": "text",       "id": "cta1_text","label": "Primary CTA",      "default": "Shop All Products" },
    { "type": "url",        "id": "cta1_url", "label": "Primary CTA link" },
    { "type": "text",       "id": "cta2_text","label": "Secondary CTA",    "default": "View Deals" },
    { "type": "url",        "id": "cta2_url", "label": "Secondary CTA link" },
    { "type": "collection", "id": "featured_collection", "label": "Featured collection (right panel — first product shown)" }
  ],
  "presets": [{ "name": "PV — Hero" }]
}
{% endschema %}
