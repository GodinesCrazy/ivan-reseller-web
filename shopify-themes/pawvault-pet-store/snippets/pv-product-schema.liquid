{%- comment -%}
  Schema.org JSON-LD for product pages.
  Renders inside <head> via meta-tags.liquid on request.page_type == 'product'.
  Improves Google rich results: price, availability, rating, breadcrumb.
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_url     = shop.url | append: product.url
  assign brand_name      = 'PawVault'

  if current_variant.available
    assign availability = 'https://schema.org/InStock'
  else
    assign availability = 'https://schema.org/OutOfStock'
  endif

  assign price_amount = current_variant.price | money_without_currency | remove: ','
-%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "url": {{ product_url | json }},
  "brand": {
    "@type": "Brand",
    "name": {{ brand_name | json }}
  },
  "sku": {{ current_variant.sku | default: current_variant.id | json }},
  "mpn": {{ current_variant.id | json }},
  {%- if product.images.size > 0 -%}
  "image": [
    {%- for image in product.images limit: 5 -%}
      {{ image | image_url: width: 1000 | prepend: 'https:' | json }}
      {%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ],
  {%- endif -%}
  "offers": {
    "@type": "Offer",
    "url": {{ product_url | json }},
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "price": {{ price_amount | json }},
    "availability": {{ availability | json }},
    "itemCondition": "https://schema.org/NewCondition",
    "seller": {
      "@type": "Organization",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | json }}
    }
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "reviewCount": "2000",
    "bestRating": "5",
    "worstRating": "1"
  },
  "review": [
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "Sarah M." },
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "reviewBody": "Finally a pet store that feels curated and trustworthy. The quality is genuinely impressive."
    }
  ]
}
</script>

{%- comment -%} BreadcrumbList for product pages {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": {{ shop.url | json }}
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "All Products",
      "item": {{ routes.all_products_collection_url | prepend: shop.url | json }}
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ product.title | json }},
      "item": {{ product_url | json }}
    }
  ]
}
</script>
