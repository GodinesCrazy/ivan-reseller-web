{%- comment -%} PawVault inline logo for header and fallback brand rendering. {%- endcomment -%}

{% assign logo_style = logo_style | default: 'full' %}
{% assign logo_color = logo_color | default: '#10233b' %}
{% assign accent_color = accent_color | default: '#f2a93b' %}
{% assign soft_color = soft_color | default: '#f7f4ee' %}
{% assign logo_height = logo_height | default: 34 %}

{% if logo_style == 'full' %}
  {%- comment -%} Delegate to ir-logo.liquid for full HTML-based crisp rendering {%- endcomment -%}
  {%- render 'ir-logo' -%}
{% elsif logo_style == 'icon' %}
  <svg
    class="ir-logo ir-logo--icon"
    width="{{ logo_height }}"
    height="{{ logo_height }}"
    viewBox="0 0 42 42"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <rect x="1" y="1" width="40" height="40" rx="14" fill="{{ logo_color }}"/>
    <circle cx="14" cy="15" r="4" fill="{{ soft_color }}"/>
    <circle cx="28" cy="15" r="4" fill="{{ soft_color }}"/>
    <circle cx="21" cy="13" r="4.6" fill="{{ soft_color }}"/>
    <path
      d="M10.8 25.6C10.8 21.89 13.82 18.88 17.55 18.88H24.45C28.18 18.88 31.2 21.89 31.2 25.6C31.2 28.02 29.24 30 26.8 30H15.2C12.76 30 10.8 28.02 10.8 25.6Z"
      fill="{{ accent_color }}"
    />
  </svg>
{% elsif logo_style == 'wordmark' %}
  <svg
    class="ir-logo"
    width="{{ logo_height | times: 5.1 | round }}"
    height="{{ logo_height }}"
    viewBox="0 0 186 36"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <text
      x="0"
      y="24"
      font-family="Avenir Next, Segoe UI, sans-serif"
      font-size="22"
      font-weight="800"
      fill="{{ logo_color }}"
      letter-spacing="-0.04em"
    >Paw</text>
    <text
      x="48"
      y="24"
      font-family="Avenir Next, Segoe UI, sans-serif"
      font-size="22"
      font-weight="600"
      fill="#5d6c7c"
      letter-spacing="-0.035em"
    >Vault</text>
  </svg>
{% endif %}

<style>
  .ir-logo {
    display: block;
    height: auto;
  }

  .header__heading-logo .ir-logo,
  .header__heading-link .ir-logo {
    height: 100%;
    width: auto;
  }
</style>
