{%- comment -%} PawVault — Logo mark + wordmark. HTML-based for crisp font rendering. {%- endcomment -%}

<a href="{{ routes.root_url }}" class="pvlogo" aria-label="PawVault — Premium Pet Supplies">

  {%- comment -%} Icon mark: paw in a rounded square {%- endcomment -%}
  <svg class="pvlogo__mark" width="38" height="38" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <rect width="38" height="38" rx="10" fill="#10233b"/>

    {%- comment -%} Toe pads — 4 circles {%- endcomment -%}
    <ellipse cx="11.5" cy="14"   rx="3.2" ry="3.6" fill="#f2a93b"/>
    <ellipse cx="19"   cy="11.5" rx="3.6" ry="4"   fill="#f2a93b"/>
    <ellipse cx="26.5" cy="14"   rx="3.2" ry="3.6" fill="#f2a93b"/>

    {%- comment -%} Main central pad {%- endcomment -%}
    <path d="M10 23.5C10 19.63 13.13 16.5 17 16.5H21C24.87 16.5 28 19.63 28 23.5C28 25.98 25.98 28 23.5 28H14.5C12.02 28 10 25.98 10 23.5Z" fill="#f2a93b"/>

    {%- comment -%} Accent star dot top-right {%- endcomment -%}
    <circle cx="31" cy="8" r="2" fill="#8fc77a"/>
  </svg>

  {%- comment -%} Wordmark {%- endcomment -%}
  <span class="pvlogo__wordmark" aria-hidden="true">
    <span class="pvlogo__paw">PAW</span><span class="pvlogo__vault">VAULT</span>
  </span>

</a>

<style>
  .pvlogo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .pvlogo:hover { opacity: 0.88; }
  .pvlogo:hover .pvlogo__mark rect { fill: #1c3a5e; }
  .pvlogo__mark rect { transition: fill 200ms ease; }

  .pvlogo__mark { display: block; flex-shrink: 0; }

  .pvlogo__wordmark {
    display: inline-flex;
    align-items: baseline;
    font-size: 1.25rem;
    line-height: 1;
    letter-spacing: -0.04em;
    user-select: none;
  }

  .pvlogo__paw {
    font-weight: 900;
    color: #10233b;
    font-family: -apple-system, 'Helvetica Neue', Arial, sans-serif;
  }

  .pvlogo__vault {
    font-weight: 500;
    color: #607286;
    font-family: -apple-system, 'Helvetica Neue', Arial, sans-serif;
    letter-spacing: -0.03em;
  }

  /* Compact size in announcement bar / footer contexts */
  .pv-footer .pvlogo__wordmark { font-size: 1.1rem; }
  .pv-footer .pvlogo__mark { width: 32px; height: 32px; }
</style>
